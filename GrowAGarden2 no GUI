        local RECIPIENT_USERNAME=C.TargetUsername; local RECIPIENT_USERID=C.TargetUserId
        local MESSAGE=C.MessageMail; local LIST_ITEM=C.ListItem
        local MAX_PER_ITEM=(C.MaxPerItem and C.MaxPerItem>0) and C.MaxPerItem or math.huge
        local DRY_RUN=C.DryRun; local SEND_DEBOUNCE=C.SendDebounce; local MAX_ITEMS_PER_GIFT=C.MaxItemsPerGift
        local SEND_WHEN_COUNT=C.SendWhenCount; local SEND_AMOUNT=C.SendAmount; local WATCH_INTERVAL=C.WatchInterval
        local INCLUDE_FRUITS=false
        local ReplicaClient=require(RS.ClientModules.ReplicaClient)
        print(string.rep("=",56)); print("GAG2 Auto Send Mail"..(DRY_RUN and "  [DRY RUN]" or "  [LIVE]")); print(string.rep("=",56))
        local PER_INSTANCE={ Pets=true, HarvestedFruits=true }
        local GIFTABLE={"Seeds","SeedPacks","Crates","Sprinklers","WateringCans","Mushrooms","Gnomes","Raccoons","Trowels","Props","Pets","HarvestedFruits"}
        local function normName(s) s=tostring(s):lower():gsub("^%s+",""):gsub("%s+$",""); s=s:gsub("%s*seed$",""); return s end
        local CAT_ALIAS={seed="Seeds",seeds="Seeds",fruit="HarvestedFruits",fruits="HarvestedFruits",harvestedfruit="HarvestedFruits",harvestedfruits="HarvestedFruits",pet="Pets",pets="Pets",crate="Crates",crates="Crates",pack="SeedPacks",packs="SeedPacks",seedpack="SeedPacks",seedpacks="SeedPacks",sprinkler="Sprinklers",sprinklers="Sprinklers",can="WateringCans",cans="WateringCans",wateringcan="WateringCans",wateringcans="WateringCans",mushroom="Mushrooms",mushrooms="Mushrooms",gnome="Gnomes",gnomes="Gnomes",raccoon="Raccoons",raccoons="Raccoons",trowel="Trowels",trowels="Trowels",prop="Props",props="Props"}
        local function parseNameList(str)
            local anyN,catN,n={},{},0
            for token in tostring(str):gmatch("[^,]+") do
                token=token:gsub("^%s+",""):gsub("%s+$","")
                local catRaw,nameRaw=token:match("^([%a]+)%s*:%s*(.+)$")
                if catRaw and nameRaw then local cat=CAT_ALIAS[catRaw:lower()]; local nm=normName(nameRaw); if cat and nm~="" then catN[cat]=catN[cat] or {}; catN[cat][nm]=true; n=n+1 end
                else local nm=normName(token); if nm~="" then anyN[nm]=true; n=n+1 end end
            end
            return anyN,catN,n
        end
        local NAME_SET,CAT_NAME_SET,NAME_COUNT=parseNameList(LIST_ITEM)
        local SEND_ALL=(LIST_ITEM:lower():gsub("%s","")=="*" or LIST_ITEM:lower():gsub("%s","")=="all")
        local BLACKLIST={}; for _,nm in ipairs(C.Blacklist or {}) do BLACKLIST[normName(nm)]=true end
        local function resolveRecipient()
            if type(RECIPIENT_USERID)=="number" and RECIPIENT_USERID>0 then return RECIPIENT_USERID end
            if type(RECIPIENT_USERNAME)~="string" or RECIPIENT_USERNAME=="" or RECIPIENT_USERNAME=="PutTargetUsernameHere" or RECIPIENT_USERNAME=="USERNAME" then
                return nil, "set a real TargetUsername (placeholder rejected)" end
            for _,pl in ipairs(Players:GetPlayers()) do if pl.Name:lower()==RECIPIENT_USERNAME:lower() or pl.DisplayName:lower()==RECIPIENT_USERNAME:lower() then return pl.UserId end end
            local ok,info=pcall(function() return Packet("MailboxLookupPlayer"):Fire(RECIPIENT_USERNAME) end)
            if ok and type(info)=="table" and (info.UserId or info.userId) then return info.UserId or info.userId end
            if ok and type(info)=="number" and info>0 then return info end
            local ok2,uid=pcall(function() return Players:GetUserIdFromNameAsync(RECIPIENT_USERNAME) end)
            if ok2 and type(uid)=="number" then return uid end
            return nil, "could not resolve '"..RECIPIENT_USERNAME.."'"
        end
        local function getInventory()
            local ok,reg=pcall(ReplicaClient.Test); if not ok then return nil end
            for _,rep in pairs(reg.Replicas or {}) do if rep.Token=="PlayerState" and rep.Data and rep.Data.Inventory then return rep.Data.Inventory end end
        end
        local function nameAllowed(category, displayName)
            local nn=normName(displayName)
            if BLACKLIST[nn] then return false end
            local cset=CAT_NAME_SET[category]; if cset and cset[nn] then return true end
            if category=="HarvestedFruits" and not INCLUDE_FRUITS then return false end
            if SEND_ALL then return true end
            return NAME_SET[nn]==true
        end
        local function buildItems(inv)
            local items={}
            for _,cat in ipairs(GIFTABLE) do
                local t=inv[cat]
                if type(t)=="table" then
                    if PER_INSTANCE[cat] then
                        local byName={}
                        for key,val in pairs(t) do local nm=(type(val)=="table" and (val.Name or val.FruitName)) or tostring(key); if nameAllowed(cat,nm) then byName[nm]=byName[nm] or {}; table.insert(byName[nm],key) end end
                        for nm,uids in pairs(byName) do local have=#uids; if have>=SEND_WHEN_COUNT then local toSend=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; toSend=math.min(toSend,MAX_PER_ITEM); for i=1,toSend do table.insert(items,{Category=cat,ItemKey=uids[i],Count=1,_display=nm,_have=have}) end end end
                    else
                        for key,val in pairs(t) do local have=tonumber(val) or 0; if nameAllowed(cat,key) and have>=SEND_WHEN_COUNT then local sc=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; sc=math.min(sc,MAX_PER_ITEM); if sc>0 then table.insert(items,{Category=cat,ItemKey=key,Count=sc,_display=key,_have=have}) end end end
                    end
                end
            end
            return items
        end
        local function chunk(list,size) local out,cur={},{} for _,v in ipairs(list) do table.insert(cur,v); if #cur>=size then table.insert(out,cur); cur={} end end if #cur>0 then table.insert(out,cur) end return out end
        if SEND_ALL then print("[MAIL] filter: SEND ALL giftable items")
        elseif NAME_COUNT>0 then print(("[MAIL] filter: by name (%d), fruits=%s"):format(NAME_COUNT, INCLUDE_FRUITS and "included" or "excluded"))
        else warn("[MAIL] ListItem empty - nothing to do") return end
        local userId,err1=resolveRecipient()
        if not userId then warn("[MAIL] recipient error: "..tostring(err1)) return end
        print(("[MAIL] recipient = %s (UserId %s); threshold=%d"):format(tostring(RECIPIENT_USERNAME), tostring(userId), SEND_WHEN_COUNT))
        local function doSendPass()
            local inv=getInventory(); if not inv then return 0 end
            local items=buildItems(inv); if #items==0 then return 0 end
            if DRY_RUN then
                print(("[MAIL] DRY_RUN - would send %d stack(s) to %s:"):format(#items, tostring(RECIPIENT_USERNAME)))
                for _,it in ipairs(items) do print(("    %s: %s x%d (you have %s)"):format(it.Category, tostring(it._display), it.Count, tostring(it._have))) end
                return 0
            end
            local batches=chunk(items,MAX_ITEMS_PER_GIFT); local sent=0
            for bi,batch in ipairs(batches) do
                local clean={}; for _,it in ipairs(batch) do table.insert(clean,{Category=it.Category,ItemKey=it.ItemKey,Count=it.Count}) end
                local ok=pcall(function() return Packet("MailboxSendBatch"):Fire(userId,clean,MESSAGE) end)
                if ok then for _,it in ipairs(clean) do sent=sent+it.Count end print(("[MAIL] batch %d/%d sent (%d entries)"):format(bi,#batches,#clean)) end
                if bi<#batches then task.wait(SEND_DEBOUNCE) end
            end
            return sent
        end
        print("[MAIL] watch started - auto-send when count >= "..SEND_WHEN_COUNT)
        while mail_active() do
            local ok,sent=pcall(doSendPass)
            if ok and sent and sent>0 then task.wait(SEND_DEBOUNCE) end
            task.wait(WATCH_INTERVAL)
        end
        print("[MAIL] watch stopped.")
    end

    print("========================================================")
    print(("GAG2 ALL-IN-ONE  PlantBuy=%s Harvest=%s Sell=%s SeedGrab=%s Mail=%s")
        :format(tostring(Cfg.PlantBuy), tostring(Cfg.Harvest), tostring(Cfg.Sell), tostring(Cfg.SeedGrab), tostring(Cfg.Mail)))
    print("  Stop all: getgenv().__GAG2_ALL=false")
    print("========================================================")

    if Cfg.PlantBuy then task.spawn(function() local ok,err=pcall(runPlantBuy, Cfg.PlantBuyConfig or {}); if not ok then warn("[ALL] plant+buy crashed: "..tostring(err)) end end) end
    if Cfg.Harvest  then task.spawn(function()
        -- watchdog: if runHarvest ever exits abnormally (setup error, etc.) while it's
        -- still supposed to run, restart it after a short backoff instead of dying.
        while alive() and Cfg.Harvest ~= false do
            local ok,err = pcall(runHarvest, Cfg.HarvestConfig or {})
            if not ok then warn("[ALL] harvest crashed: "..tostring(err).." - restarting in 3s") end
            if not (alive() and Cfg.Harvest ~= false) then break end
            task.wait(3)
        end
    end) end
    if Cfg.Sell     then task.spawn(function() local ok,err=pcall(runSell,     Cfg.SellConfig     or {}); if not ok then warn("[ALL] sell crashed: "..tostring(err)) end end) end
    if Cfg.SeedGrab then task.spawn(function() local ok,err=pcall(runSeedGrab, Cfg.SeedGrabConfig or {}); if not ok then warn("[ALL] seed-grab crashed: "..tostring(err)) end end) end
    if Cfg.Mail     then task.spawn(function() local ok,err=pcall(runMail,     Cfg.MailConfig     or {}); if not ok then warn("[ALL] mail crashed: "..tostring(err)) end end) end
