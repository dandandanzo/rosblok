  -- collect giftable batch entries for ONE spec's item (capped to its remaining session count). Pets = unequipped only.
  local function collectForSpec(inv, spec)
    local left = spec.count and (spec.count - spec.sent) or math.huge
    if left <= 0 then return {} end
    local items={}
    for _,cat in ipairs(GIFTABLE) do
      if left <= 0 then break end
      local t=inv[cat]
      if type(t)=="table" then
        if PER_INSTANCE[cat] then
          local equippedIds, eqOk = {}, false
          if cat=="Pets" then
            local ok,eq=pcall(function() return Net.Pets.GetEquippedPets:Fire() end)
            if ok and type(eq)=="table" then eqOk=true; for _,e in ipairs(eq) do local id=(type(e)=="table" and e.Id) or e; if id then equippedIds[tostring(id)]=true end end end
          end
          for key,val in pairs(t) do
            if left <= 0 then break end
            local nm=(type(val)=="table" and (val.Name or val.FruitName)) or tostring(key)
            if normName(nm)==spec.norm then
              local skip=false
              if cat=="Pets" then if eqOk then skip=(equippedIds[tostring(key)]==true) else skip=(type(val)=="table" and val.Equipped==true) end end
              if not skip then table.insert(items,{Category=cat,ItemKey=key,Count=1,_display=nm}); left=left-1 end
            end
          end
        else
          for key,val in pairs(t) do
            if left <= 0 then break end
            if normName(key)==spec.norm then
              local have=tonumber(val) or 0
              local send=math.min(have, left)
              if send>0 then table.insert(items,{Category=cat,ItemKey=key,Count=send,_display=key}); left=left-send end
            end
          end
        end
      end
    end
    return items
  end
