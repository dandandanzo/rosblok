                local t0=os.clock(); repeat task.wait(0.2) until maxPets()>before or not active() or os.clock()-t0>5
                if maxPets()>before then print(("[SLOT] bought pet slot -> %d/%d (cost ~%d)"):format(maxPets(),target,price))
                else dbg("slot buy not confirmed (afford/max?)"); break end
