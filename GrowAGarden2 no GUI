local function runEquipPets(C)
  local active = activeFor("EquipPets")
  local function dbg(...) if miscDebug() then print("[EQUIP]", ...) end end
  local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
  if not replica then warn("[EQUIP] PlayerState replica unavailable - aborting"); return end

  local want = {}; for _,n in ipairs(C.ListEquip or {}) do want[n] = (want[n] or 0) + 1 end
  local wantRar = {}; for _,r in ipairs(C.EquipRarities or {}) do wantRar[tostring(r):lower()] = true end
  local hasRar = next(wantRar) ~= nil
  if next(want)==nil and not hasRar then warn("[EQUIP] ListEquip + EquipRarities both empty - aborting"); return end

  local PetData = require(RS.SharedData.PetData)   
  local function petRarity(name) local e=PetData[name]; return (e and tostring(e.Rarity or "")) or "" end
  local function rarWanted(name) return hasRar and wantRar[petRarity(name):lower()] == true end

  local function capNow() return tonumber(lp:GetAttribute("MaxEquippedPets")) or 3 end
  local function isWanted(n) return (want[n] or 0) > 0 or rarWanted(n) end
  local function ownedPets()   -- {id=, name=} for every owned pet
    local out={}; local d=replica.Data; local pets=d and d.Inventory and d.Inventory.Pets
    if type(pets)=="table" then for _,p in pairs(pets) do if type(p)=="table" and p.Id and p.Name then out[#out+1]={id=p.Id, name=p.Name} end end end
    return out
  end
  -- MEASURED equip contract (everything is by pet Id, NOT by name - the *ByName remotes silently
  -- fail with the "No Inventory folder for pet X" toast, which is exactly what the user hit):
  --   EQUIP   = Net.Pets.RequestToggleFollower:Fire(id)  (toggles an UNequipped pet -> equipped)
  --   UNEQUIP = Net.Pets.RequestUnequip:Fire(id)
  --   STATE   = Net.Pets.GetEquippedPets (entries carry .Id + .Name)
  -- The Inventory.Pets[].Equipped flag is never updated in this game, so it must NOT be read.
  local function equippedList()
    local list={}; local ok,e=pcall(function() return Net.Pets.GetEquippedPets:Fire() end)
    if ok and type(e)=="table" then for _,p in pairs(e) do if type(p)=="table" and p.Id then list[#list+1]={id=p.Id, name=tostring(p.Name or "?")} end end end
    return list
  end
  local function isEquipped(id) for _,p in ipairs(equippedList()) do if p.id==id then return true end end return false end
  local function equipById(id, name)
    pcall(function() Net.Pets.RequestToggleFollower:Fire(id) end)   -- toggles an UNequipped pet -> equipped
    local t0=os.clock(); repeat task.wait(0.3) until isEquipped(id) or not active() or os.clock()-t0>4
    if isEquipped(id) then print(("[EQUIP] equipped %s (%s)"):format(name, petRarity(name))); return true end
    dbg("equip not confirmed for "..name); return false
  end
  local function unequipById(id, name)
    pcall(function() Net.Pets.RequestUnequip:Fire(id) end)
    local t0=os.clock(); repeat task.wait(0.3) until not isEquipped(id) or not active() or os.clock()-t0>4
    if not isEquipped(id) then print(("[EQUIP] unequipped %s (not wanted)"):format(name)); return true end
    return false
  end
  print("[EQUIP] started")
  while active() do
    local cap = capNow()
    local eqList = equippedList()
    local eqIds, eqByName, total = {}, {}, #eqList
    for _,p in ipairs(eqList) do eqIds[p.id]=true; eqByName[p.name]=(eqByName[p.name] or 0)+1 end
    -- 1) unequip unwanted pets -- but ONLY enough to free slots for wanted pets we ACTUALLY OWN and
    -- can equip. If we don't own any wanted pet yet (e.g. fresh account before the configured species
    -- is obtained), DON'T unequip anything -> never leave the player with 0 pets equipped.
    local owned = ownedPets()
    local wantedAvail = 0
    for _,op in ipairs(owned) do if (not eqIds[op.id]) and isWanted(op.name) then wantedAvail = wantedAvail + 1 end end
    local unequipBudget = math.max(0, wantedAvail - (cap - total))   -- # of unwanted to drop = wanted-owned that won't fit in free slots
    for _,p in ipairs(eqList) do
      if not active() or unequipBudget<=0 then break end
      if not isWanted(p.name) then
        if unequipById(p.id, p.name) then total=total-1; eqIds[p.id]=nil; eqByName[p.name]=(eqByName[p.name] or 1)-1; unequipBudget=unequipBudget-1 end
      end
    end
    -- 2) equip ListEquip species up to their requested counts (priority over rarity fillers)
    for _,op in ipairs(owned) do
      if not active() or total>=cap then break end
      if (not eqIds[op.id]) and (want[op.name] or 0) > (eqByName[op.name] or 0) then
        if equipById(op.id, op.name) then total=total+1; eqIds[op.id]=true; eqByName[op.name]=(eqByName[op.name] or 0)+1 end
      end
    end
    -- 3) fill remaining slots with any OWNED pet of a wanted rarity (equip-by-rarity)
    if hasRar then
      for _,op in ipairs(owned) do
        if not active() or total>=cap then break end
        if (not eqIds[op.id]) and (want[op.name] or 0)==0 and rarWanted(op.name) then
          if equipById(op.id, op.name) then total=total+1; eqIds[op.id]=true; eqByName[op.name]=(eqByName[op.name] or 0)+1 end
        end
      end
    end
    for _=1, math.max(3, 20) do if not active() then return end task.wait(1) end
  end
  print("[EQUIP] stopped.")
end

local function runRedeemCodes(C)
  local function dbg(...) if miscDebug() then print("[CODE]", ...) end end
  local codes = C.ListCodes or {}
  if #codes == 0 then dbg("no codes listed - skip"); return end
  -- Misc starts at execute (pre-spawn); wait until loaded so codes aren't wasted
  repeat task.wait(1) until not alive() or (lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and lp:GetAttribute("LoadingScreenActive") ~= true)
  if not alive() then return end
  print(("[CODE] redeeming %d code(s)"):format(#codes))
  for _, code in ipairs(codes) do
    if not alive() then return end
    code = tostring(code):gsub("^%s+",""):gsub("%s+$","")
    if code ~= "" then
      local ok, res = pcall(function() return Net.Settings.SubmitCode:InvokeServer(code) end)
      if ok then
        print(("[CODE] '%s' -> %s"):format(code, tostring(res)))
      else
        pcall(function() Net.Settings.SubmitCode:Fire(code) end)  
        print(("[CODE] '%s' submitted (fire)"):format(code))
      end
      task.wait(1.5)   
    end
  end
  print("[CODE] done.")
end


local function runGuard()
  local function active() return alive() end
  local function isNight()
    local w = workspace:GetAttribute("ActiveWeather")
    return type(w)=="string" and w:lower():find("moon") ~= nil
  end
  -- gardenCenter/pivotCenter now shared file-scope (pivotGardenCenter). isNight stays local.

  task.spawn(function()
    local VIM; pcall(function() VIM = game:GetService("VirtualInputManager") end)
    if not VIM then return end
    local function pressAnyKey()
      pcall(function()
        VIM:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
        VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        VIM:SendMouseButtonEvent(100,100,0,true,  game, 0)
        VIM:SendMouseButtonEvent(100,100,0,false, game, 0)
      end)
    end
    local t0, announced = os.clock(), false
    while active() and os.clock()-t0 < 90 do
      if lp:GetAttribute("LoadingScreenActive") == true then
        if not announced then print("[GUARD] auto-pressing through loading screen"); announced = true end
        pressAnyKey(); task.wait(0.25)
      elseif lp:GetAttribute("OfflineCutscenePlaying") == true then
        pcall(function() VIM:SendMouseButtonEvent(100,100,0,true,game,0) end)
        local h = os.clock()
        while active() and lp:GetAttribute("OfflineCutscenePlaying")==true and os.clock()-h < 1.5 do task.wait(0.05) end
        pcall(function() VIM:SendMouseButtonEvent(100,100,0,false,game,0) end)
        print("[GUARD] held to skip offline-growth cutscene"); task.wait(0.5)
      else
        task.wait(0.3)
      end
    end
  end)

  task.spawn(function()
    local function trulySpawned()
      if lp:GetAttribute("LoadingScreenActive") == true then return false end
      if lp:GetAttribute("OfflineCutscenePlaying") == true then return false end
      if lp:GetAttribute("CutsceneInputBlocked") == true then return false end
      local char = lp.Character
      local hrp  = char and char:FindFirstChild("HumanoidRootPart")
      local hum  = char and char:FindFirstChildOfClass("Humanoid")
      if not (hrp and hum) then return false end
      if hum.Health <= 0 then return false end
      local st = hum:GetState()
      if st == Enum.HumanoidStateType.Dead or st == Enum.HumanoidStateType.None then return false end
      return true
    end
    local t0 = os.clock()
    while active() and not trulySpawned() and os.clock()-t0 < 120 do task.wait(0.3) end
    if not active() then return end
    task.wait(1.0)
    pivotGardenCenter("after spawn")   -- one-time on join
    -- SOFT night/event pivot (NOT a freeze): pivot to center ONCE when night starts (saat night)
    -- and ONCE when the gold/rainbow event ends (night->day). Only fires at the transitions, so it
    -- never interferes with seed-collecting mid-night.
    local wasNight = nil
    while active() do
      local n = isNight()
      if wasNight ~= nil and n ~= wasNight then
        if n then
          pivotGardenCenter("night start")   -- malam mulai: pivot langsung
        else
          -- event habis (malam->siang): tunggu 10 detik (biar claim seed terakhir + transisi
          -- settle dulu, jadi pivot gak ke-override) baru pivot. spawn terpisah biar loop
          -- tetep watch weather selama nunggu.
          task.spawn(function()
            for _=1,10 do if not active() then return end task.wait(1) end
            if active() and not isNight() then pivotGardenCenter("event ended (+10s)") end
          end)
        end
      end
      wasNight = n
      for _=1, 2 do if not active() then return end task.wait(1) end
    end
  end)
  -- RETURN-HOME failsafe (StreamingEnabled places): if the character drifts far from the plot
  -- (e.g. left at a gold-seed spot after a Moon event) the garden streams out and its fruit FREEZE
  -- (Age stops, server rejects harvest on the stale instances) -> harvest/plant silently die. Pull
  -- the char back whenever it's IDLE (not mid seed-event, not mid grab/claim) so the plot stays
  -- streamed-in. This is the one re-pin that's actually needed here; it does NOT freeze/anchor.
  task.spawn(function()
    local DRIFT = 150
    task.wait(8)   -- let the after-spawn pivot settle first
    while active() do
      if not (seedEventActive or os.clock()<grabUntil or os.clock()<noAnchorUntil or os.clock()<buyPetsUntil) then
        local c = gardenCenterPos(); local r = getRoot()
        if c and r then
          local d = r.Position - c; d = Vector3.new(d.X, 0, d.Z)
          if d.Magnitude > DRIFT then pivotGardenCenter(("drifted %d -> home"):format(math.floor(d.Magnitude))) end
        end
      end
      for _=1,3 do if not active() then return end task.wait(1) end   -- check ~every 3s
    end
  end)
  print("[GUARD] started (hold-to-skip + after-spawn pivot + soft night/event pivot + return-home failsafe)")
end

local function runFpsBoost(C)
  local active = activeFor("Misc")
  local Lighting = game:GetService("Lighting")
  local conns       = {}
  local removed     = {}   -- [plantsFolder] = plot (restore other gardens on stop)
  local hiddenChars = {}   -- [player] = {ch=Character, parent=Instance} (per-player keying = no respawn leak)
  local myPlotName  = "Plot"..tostring(lp:GetAttribute("PlotId"))
  local ownPF       = nil  -- my plot's Plants folder (set when HideOwnPlants on; for restore on stop)

  if C.FpsBoost ~= false then
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    pcall(function() game:GetService("UserSettings"):GetService("UserGameSettings").SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end)
    pcall(function() Lighting.GlobalShadows = false end)
    pcall(function() Lighting.Technology = Enum.Technology.Compatibility end)
    for _,e in ipairs(Lighting:GetDescendants()) do
      if e:IsA("PostEffect") or e:IsA("Atmosphere") then pcall(function() e.Enabled = false end) end
    end
    local ter = workspace:FindFirstChildOfClass("Terrain")
    if ter then pcall(function() ter.WaterWaveSize=0; ter.WaterWaveSpeed=0; ter.WaterReflectance=0; ter.WaterTransparency=0.9; ter.Decoration=false end) end
    -- cheaper lighting: kill image-based lighting + clouds (Brightness left alone to avoid a dark screen)
    pcall(function() Lighting.EnvironmentDiffuseScale = 0; Lighting.EnvironmentSpecularScale = 0 end)
    if ter then local cl = ter:FindFirstChildOfClass("Clouds"); if cl then pcall(function() cl:Destroy() end) end end

    -- (remove-OTHER-gardens moved OUT of FpsBoost into its own HideOtherPlants block below)

    local function killFx(d)
      if d:IsA("ParticleEmitter") or d:IsA("Beam") or d:IsA("Trail") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
        pcall(function() d.Enabled = false end)
      elseif d:IsA("BasePart") then
        pcall(function() d.LocalTransparencyModifier = 1; d.CastShadow = false end)
      end
    end
    for _,fn in ipairs({"RainDrops","RainSplashes","LightningEffects","StormRainDrops","StormSplashes"}) do
      local f = workspace:FindFirstChild(fn)
      if f then
        for _,d in ipairs(f:GetDescendants()) do killFx(d) end
        conns[#conns+1] = f.DescendantAdded:Connect(function(d) if active() then killFx(d) end end)
      end
    end
    for _,ln in ipairs({"RainEffect","LightningEffect","RainbowEffect","FlameEffect","StarEffect"}) do
      local e = Lighting:FindFirstChild(ln)
      if e and e:IsA("PostEffect") then
        pcall(function() e.Enabled = false end)
        conns[#conns+1] = e:GetPropertyChangedSignal("Enabled"):Connect(function() if active() and e.Enabled then pcall(function() e.Enabled=false end) end end)
      end
    end

    -- Always-on FPS wins: shadows off + particles/fx killed. Texture/material LOW-POLY is now an
    -- opt-in (MiscConfig.LowPolyTextures): when true, flatten Material->SmoothPlastic + strip mesh
    -- textures / decals / PBR (SurfaceAppearance). Sound/SFX muting REMOVED on request.
    local LOWPOLY = C.LowPolyTextures == true
    local function flatten(d)
      if d:IsA("BasePart") then
        pcall(function() d.CastShadow = false end)                                    -- shadows off (perf)
        if LOWPOLY then
          pcall(function() d.Material = Enum.Material.SmoothPlastic; d.Reflectance = 0 end)
          if d:IsA("MeshPart") then pcall(function() d.TextureID = "" end) end       -- mesh texture
        end
      elseif d:IsA("SpecialMesh") then if LOWPOLY then pcall(function() d.TextureId = "" end) end   -- legacy mesh texture
      elseif d:IsA("Decal") or d:IsA("Texture") then if LOWPOLY then pcall(function() d.Transparency = 1 end) end
      elseif d:IsA("SurfaceAppearance") then if LOWPOLY then pcall(function() d:Destroy() end) end   -- PBR maps
      elseif d:IsA("ParticleEmitter") or d:IsA("Trail") or d:IsA("Beam") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
        pcall(function() d.Enabled = false end)                                       -- kill ALL particles/fx
      end
    end
    local function flattenSubtree(root)
      if not root then return end
      local n = 0
      for _,d in ipairs(root:GetDescendants()) do
        if not active() then return end
        flatten(d); n = n + 1; if n % 300 == 0 then task.wait() end
      end
    end
    -- New instances stream in CONSTANTLY (fruit growth across the map, VFX, weather, etc.), so
    -- flattening each one synchronously in the event was steady CPU churn. Coalesce into a set and
    -- drain it in a bounded, yield-batched loop (<=200 per yield) so it can NEVER spike. Snapshot-
    -- swap the set each pass so new arrivals don't mutate the table mid-iteration.
    local pending = {}
    local pendingN = 0
    local PENDING_CAP = 4000
    -- (A) During a seed event the char teleports across the whole map -> StreamingEnabled streams in
    --     huge instance counts that ALL fire DescendantAdded. Those instances are far away and stream
    --     back OUT when we return home, so flattening them is wasted work that backlogs for ages AFTER
    --     the event = the post-event FPS drop. Skip queueing entirely while a seed event is live.
    -- (B) Hard-cap the queue so the backlog can NEVER grow unbounded from any cause. The one-time
    --     flattenSubtree + the periodic HideOwnPlants re-hide keep the home garden covered regardless.
    local function queueFlatten(d)
      if not active() or seedEventActive then return end
      if pendingN >= PENDING_CAP then return end
      if not pending[d] then pending[d] = true; pendingN = pendingN + 1 end
    end
    conns[#conns+1] = workspace.DescendantAdded:Connect(queueFlatten)
    task.spawn(function()
      while active() do
        if next(pending) then
          local batch = pending; pending = {}; pendingN = 0   -- swap: new arrivals go to the fresh table
          local n = 0
          for d in pairs(batch) do
            if not active() then break end
            if d.Parent then flatten(d) end   -- skip if it already despawned
            n = n + 1; if n % 200 == 0 then task.wait() end
          end
        end
        task.wait(0.4)
      end
    end)
    task.spawn(function()
      flattenSubtree(workspace)   -- whole map: shadows off + particles killed (+ low-poly textures if LowPolyTextures)
      print(("[MISC] fps flatten applied (shadows+particles off%s)"):format(LOWPOLY and ", LOW-POLY textures ON" or ", textures kept"))
    end)

    -- (#2) nuke transient cosmetic VFX models (harvest/sell pops, blizzard beams); they
    -- respawn constantly with nonstop harvest, so removing them on spawn frees real FPS
    local JUNK = { PopVFXModel = true, BlizzardBeams = true, PopVFX = true }
    local function killJunk(c) if JUNK[c.Name] then pcall(function() c:Destroy() end) end end
    for _,c in ipairs(workspace:GetChildren()) do killJunk(c) end
    conns[#conns+1] = workspace.ChildAdded:Connect(function(c) if active() then killJunk(c) end end)

    -- (hide-OTHER-players moved OUT of FpsBoost into its own HideOtherPlayers block below)

    print("[MISC] fps boost applied (quality lowest, shadows/effects off, particles+weather off)")
  end

  -- HIDE OTHER PLAYERS (independent of FpsBoost): un-parent other players' characters (transparency
  -- wouldn't free FPS). Restored on stop. Keyed by PLAYER so a respawn overwrites the old (destroyed)
  -- Character ref -> no leak. Set HideOtherPlayers=false to keep other players visible.
  if C.HideOtherPlayers then
    local Plrs = game:GetService("Players")
    local function hideChar(p, ch) if ch and ch.Parent then hiddenChars[p] = {ch=ch, parent=ch.Parent}; pcall(function() ch.Parent = nil end) end end
    local function onPlr(p)
      if p == lp then return end
      if p.Character then hideChar(p, p.Character) end
      conns[#conns+1] = p.CharacterAdded:Connect(function(ch) if active() then task.wait(0.3); hideChar(p, ch) end end)
    end
    for _,p in ipairs(Plrs:GetPlayers()) do onPlr(p) end
    conns[#conns+1] = Plrs.PlayerAdded:Connect(function(p) if active() then onPlr(p) end end)
    conns[#conns+1] = Plrs.PlayerRemoving:Connect(function(p) hiddenChars[p] = nil end)   -- drop leavers (no stale key)
    print("[MISC] hide-other-players armed (other players' characters hidden client-side)")
  end

  -- HIDE OTHER PLANTS (independent of FpsBoost): un-parent OTHER players' gardens' Plants folders
  -- (the big render cost). Waits for PlotId first so it never un-parents YOUR own garden. Restored on
  -- stop. Set HideOtherPlants=false to keep other gardens visible.
  if C.HideOtherPlants then
    for _=1,60 do if lp:GetAttribute("PlotId") or not active() then break end task.wait(0.5) end
    myPlotName = "Plot"..tostring(lp:GetAttribute("PlotId"))
    local function removePlot(plot)
      if plot.Name == myPlotName then return end
      local pf = plot:FindFirstChild("Plants")
      if pf and not removed[pf] then removed[pf] = plot; pcall(function() pf.Parent = nil end) end
    end
    local gardens = workspace:WaitForChild("Gardens", 30)
    if gardens then
      for _,plot in ipairs(gardens:GetChildren()) do if active() then removePlot(plot) end end
      conns[#conns+1] = gardens.ChildAdded:Connect(function(plot)
        if active() and plot.Name ~= myPlotName then
          local pf = plot:WaitForChild("Plants", 30)
          if pf and active() then removePlot(plot) end
        end
      end)
      -- (C) StreamingEnabled recreates plot/Plants instances on every stream cycle. We un-parent the
      --     Plants folder (pf.Parent=nil) but keep its ref in `removed` for restore-on-stop, so when
      --     the plot streams OUT the detached folder is NOT destroyed with it -> `removed` leaks dead
      --     refs (event teleporting causes many cycles). Prune entries whose PLOT is gone (plot.Parent
      --     ==nil = streamed out / destroyed); the ones we merely hid keep plot.Parent==Gardens.
      task.spawn(function()
        while active() do
          for pf,plot in pairs(removed) do if not plot.Parent then removed[pf] = nil end end
          task.wait(5)
        end
      end)
    end
    print("[MISC] hide-other-plants armed (other players' gardens hidden client-side)")
  end

  -- HIDE OWN PLANTS (independent of FpsBoost): make YOUR plot's plants invisible client-side so a
  -- packed garden (esp. compact mode) doesn't tank FPS / clutter the view. Plants stay in the tree
  -- -> harvest/sell keep working. A periodic yield-batched re-hide (not per-fruit events) catches
  -- new plants + regrown fruit without the CPU churn that per-instance DescendantAdded would cause.
  if C.HideOwnPlants then
    for _=1,60 do if lp:GetAttribute("PlotId") or not active() then break end task.wait(0.5) end
    local myPlot = workspace:FindFirstChild("Gardens") and workspace.Gardens:FindFirstChild("Plot"..tostring(lp:GetAttribute("PlotId")))
    ownPF = myPlot and myPlot:FindFirstChild("Plants")
    if ownPF then
      print("[MISC] hide-own-plants armed (your garden hidden client-side; harvest still works)")
      task.spawn(function()
        while active() do
          local n = 0
          for _,pl in ipairs(ownPF:GetChildren()) do
            for _,d in ipairs(pl:GetDescendants()) do
              if not active() then return end
              if d:IsA("BasePart") then if d.LocalTransparencyModifier ~= 1 then pcall(function() d.LocalTransparencyModifier = 1 end) end
              elseif d:IsA("ParticleEmitter") or d:IsA("Beam") or d:IsA("Trail") then if d.Enabled then pcall(function() d.Enabled = false end) end end
              n = n + 1; if n % 300 == 0 then task.wait() end
            end
          end
          task.wait(3)
        end
      end)
    end
  end

  -- keepalive + cleanup: restore other gardens + players (+ own plants) on stop
  while active() do task.wait(2) end
  for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
  for pf,plot in pairs(removed) do pcall(function() pf.Parent = plot end) end          -- restore other gardens
  for _,info in pairs(hiddenChars) do pcall(function() info.ch.Parent = info.parent end) end  -- restore other players
  if ownPF then for _,pl in ipairs(ownPF:GetChildren()) do for _,d in ipairs(pl:GetDescendants()) do if d:IsA("BasePart") then pcall(function() d.LocalTransparencyModifier = 0 end) end end end end  -- un-hide own plants
  print("[MISC] fps boost stopped (other gardens + players restored)")
end

-- The rest of Misc (character guard / anti-fling / anti-afk / auto-reconnect / redeem) runs
-- only AFTER spawn -- unlike FpsBoost which starts at execute.
local function runMisc(C)
  local active = activeFor("Misc")
  local conns = {}

  -- CHARACTER GUARD REMOVED on request: no night/moon freeze, no garden-center re-pin, no
  -- anti-gravity on grab, no anti-fling. The character runs under normal physics + server control.
  -- (grabUntil / noAnchorUntil / seedEventActive are still set by the grab loops but unused here
  -- now = harmless; the grab/seed/plant movement helpers zero their own velocity on each teleport.)

  if C.AntiAfk then
    -- AGGRESSIVE anti-AFK / anti-kick / anti-server-hop (ported from the claim-mail script). NO auto-jump.
    -- Neutralizes the game's anti-afk (RequestHop + AntiAfkFlags), kills the Idled kick, and blocks the
    -- server-shutdown / idle-timer / move-server namecalls so the session stays put indefinitely.
    local okVIM, VIM = pcall(function() return game:GetService("VirtualInputManager") end)
    local function killHop()
      local ok, N = pcall(require, RS.SharedModules.Networking)
      if not ok or type(N) ~= "table" then return end
      local rh = N.AntiAfk and N.AntiAfk.RequestHop
      if type(rh) ~= "table" or rh.__hopKilled then return end
      rh.Fire = function() end; rh.__hopKilled = true
    end
    local function killFlag()
      local ok, flags = pcall(require, RS.SharedModules.Flags.AntiAfkFlags)
      if not ok or type(flags) ~= "table" or type(flags.Enabled) ~= "table" then return end
      pcall(function() flags.Enabled.Get = function() return false end end)
      pcall(function() flags.IdleSeconds.Get = function() return math.huge end end)
    end
    local function fakeInput()
      if not (okVIM and VIM) then return end
      pcall(function()
        VIM:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game); task.wait(0.05)
        VIM:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
      end)
    end
    local function clearSignal(sig)
      local node = sig.Next
      while node and node ~= sig do node.Function = nil; node = node.Next end
      sig.Next = sig; sig.Previous = sig
    end
    pcall(function() clearSignal(Net.AntiAfk.RequestHop.OnClientEvent) end)
    pcall(function()
      if type(getconnections) == "function" then
        for _, conn in pairs(getconnections(lp.Idled)) do pcall(function() conn:Disable() end) end
      end
    end)
    pcall(function()
      local VirtualUser = game:GetService("VirtualUser")
      conns[#conns+1] = lp.Idled:Connect(function()
        pcall(function() VirtualUser:ClickButton2(Vector2.new(math.random(0,1000), math.random(0,1000))) end)
      end)
    end)
    pcall(function()
      -- Install the __namecall hook ONCE per session. Re-exec re-runs runMisc; without this guard
      -- each re-exec stacks a new hook over the previous gen's (never undone) -> closure leak +
      -- every namecall in the game pays N stacked hooks after N re-execs.
      if not G.__gag2_nc_hooked and type(hookmetamethod) == "function" and type(newcclosure) == "function" and type(checkcaller) == "function" then
        G.__gag2_nc_hooked = true
        local blocked = { ["Server Closing"] = true, ["Idle Tracking: Update Timer"] = true, ["Move Server"] = true }
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
          if not checkcaller() and blocked[tostring(self)] then return nil end
          return oldNamecall(self, ...)
        end))
      end
    end)
    killFlag()
    task.spawn(function() while active() do pcall(killHop); pcall(killFlag); task.wait(10) end end)
    task.spawn(function() while active() do fakeInput(); task.wait(60) end end)
    print("[MISC] anti-afk armed (aggressive: anti idle-kick + server-hop + namecall block; no auto-jump)")
  end

  if C.AutoReconnect then
    local TP = game:GetService("TeleportService")
    local GuiService = game:GetService("GuiService")
    local rejoining = false
    local function rejoin()
      if rejoining then return end; rejoining = true
      task.wait(0.5)
      pcall(function() TP:Teleport(game.PlaceId, lp) end)
    end
    conns[#conns+1] = GuiService.ErrorMessageChanged:Connect(function(msg)
      if msg and tostring(msg) ~= "" then task.spawn(rejoin) end
    end)
    print("[MISC] auto-reconnect armed (note: a hard network drop can kill the VM before it fires)")
  end

  while active() do task.wait(2) end
  for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
  pcall(function() local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if h then h.Anchored = false end end)  -- never leave frozen
  print("[MISC] stopped (character unfrozen)")
end

