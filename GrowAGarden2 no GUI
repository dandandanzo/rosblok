    local HttpService = game:GetService("HttpService")
    local function webhookPost(url, bodyTable, messageId, label)
        if Cfg.Webhook == false then return false end
        if type(url) ~= "string" or url == "" or url:find("PUT_YOUR") then return false end
        local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
        if not req then warn("[WEBHOOK] executor has no HTTP request function"); return false end
        local wc = Cfg.WebhookConfig or {}
        if type(bodyTable) == "table" and not bodyTable.username then
            bodyTable.username = (type(wc.Username)=="string" and wc.Username~="") and wc.Username or "GAG2"
        end
        local function fire(method, fullUrl)
            return pcall(function()
                return req({ Url = fullUrl, Method = method,
                      Headers = { ["Content-Type"] = "application/json" },
                      Body = HttpService:JSONEncode(bodyTable) })
            end)
        end
        local editing = type(messageId)=="string" and messageId~=""
        local method  = editing and "PATCH" or "POST"
        local fullUrl = editing and (url.."/messages/"..messageId) or (url.."?wait=true")
        local ok, res = fire(method, fullUrl)
        if not ok then return false end
        local status = res and (res.StatusCode or res.Status or res.status_code)
        if editing and status and status >= 400 then
            method, fullUrl = "POST", url.."?wait=true"
            ok, res = fire(method, fullUrl); if not ok then return false end
        end
        if method == "POST" and res and res.Body then
            local okj, data = pcall(function() return HttpService:JSONDecode(tostring(res.Body)) end)
            if okj and type(data)=="table" and data.id then
                print(("[WEBHOOK] %s message id = %s  (paste into WebhookConfig.%sMessageID to edit this message in place)")
                    :format(tostring(label or "?"), tostring(data.id), tostring(label or "")))
            end
        end
        return true
    end

    local function runPlantBuy(C)
        local function active() return alive() and Cfg.Plant ~= false end
        local function dbg(...) if miscDebug() then print("[PB]", ...) end end

        local P_Buy = Packet("PurchaseSeed")
        local PlayerStateClient = require(RS.ClientModules.PlayerStateClient)
        local SeedData = require(RS.SharedModules.SeedData)
        local PRICE = {}
        for _, e in pairs(SeedData) do if type(e)=="table" and e.SeedName then PRICE[e.SeedName] = tonumber(e.PurchasePrice) or 0 end end

        local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("SeedShop", 20)
        if not SS then warn("[PB] StockValues.SeedShop not found - plant+buy aborting"); return end
        local ITEMS = SS:WaitForChild("Items", 20)

        local replica = PlayerStateClient:WaitForLocalReplica(PlayerStateClient, 30)
        if not replica then warn("[PB] PlayerState replica unavailable - plant+buy aborting"); return end
        local function data() return replica.Data end
        local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end
        local function invCount(n) local d=data(); local s=d and d.Inventory and d.Inventory.Seeds; return (s and s[n]) or 0 end
        local function purchasedCount(n) local d=data(); local p=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Seeds; return (p and p[n]) or 0 end
        local function stockRemaining(n) local v=ITEMS:FindFirstChild(n); local mx=(v and v:IsA("ValueBase") and v.Value) or 0; return math.max(0, mx - purchasedCount(n)) end

        -- spatial hash: O(1) spacing checks (vs scanning EVERY plant per candidate cell)
        local function makeHash(cell) return { cell = cell, b = {} } end
        local function hAdd(h, x, z)
            local k = math.floor(x/h.cell)..","..math.floor(z/h.cell)
            local t = h.b[k]; if not t then t = {}; h.b[k] = t end
            t[#t+1] = Vector2.new(x, z)
        end
        local function hFar(h, x, z, minSp)
            local cx, cz = math.floor(x/h.cell), math.floor(z/h.cell)
            local v = Vector2.new(x, z)
            for dx = -1, 1 do for dz = -1, 1 do
                local t = h.b[(cx+dx)..","..(cz+dz)]
                if t then for _, o in ipairs(t) do if (o - v).Magnitude < minSp then return false end end end
            end end
            return true
        end

        local function plantedCount(name)
            local plot=getPlot(); local plants=plot and plot:FindFirstChild("Plants")
            if not plants then return 0 end
            local c=0 for _,pl in ipairs(plants:GetChildren()) do if pl:GetAttribute("SeedName")==name then c=c+1 end end
            return c
        end
        local function findSeedTool(name)
            local bp=lp:FindFirstChildOfClass("Backpack")
            if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
            if lp.Character then for _,t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
        end

        local KEEPBUY = {}
        for _, s in ipairs(C.KeepBuyingAfterTarget or {}) do KEEPBUY[tostring(s)] = true end
        local function wantPlant(n, t) return plantedCount(n) < t end
        local function wantBuy(n, t)
            if KEEPBUY[n] then return true end
            return (plantedCount(n) + invCount(n)) < t
        end

        local function buySeed(name, cap)
            local price = PRICE[name] or 0
            local bought = 0
            while active() do
                if cap and cap>0 and bought>=cap then break end
                if stockRemaining(name) <= 0 then break end
                if sheckles() < price then break end
                local before = purchasedCount(name)
                pcall(function() P_Buy:Fire(name) end)
                local t0=os.clock()
                repeat task.wait(0.1) until purchasedCount(name)>before or not active() or os.clock()-t0>1.5
                if purchasedCount(name)>before then bought=bought+1 else break end
            end
            return bought
        end

        local function plantTopUp(name, target)
            local plot=getPlot(); if not plot then return 0 end
            local plants=plot:FindFirstChild("Plants"); if not plants then return 0 end
            local need = target - plantedCount(name)
            if need<=0 then return 0 end
            need = math.min(need, invCount(name))
            if need<=0 then return 0 end
            local tool=findSeedTool(name); if not tool then dbg("no seed tool for", name); return 0 end
            local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid"); if hum then pcall(function() hum:EquipTool(tool) end) end
            task.wait(0.2)
            local areas={}
            for _,p in ipairs(CS:GetTagged("PlantArea")) do if p:IsDescendantOf(plot) and p:IsA("BasePart") then areas[#areas+1]=p end end
            if #areas==0 then return 0 end
            local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Include; rp.FilterDescendantsInstances=areas
            local hash = makeHash(1.2)
            for _,pl in ipairs(plants:GetChildren()) do local ok,cf=pcall(function() return pl:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end end
            local function farEnough(x,z) return hFar(hash, x, z, 1.2) end
            -- shuffle PlantArea order so a need-capped scan isn't biased to the first/corner plot
            for i=#areas,2,-1 do local j=math.random(i); areas[i],areas[j]=areas[j],areas[i] end
            local added=0
            local conn=plants.ChildAdded:Connect(function(m)
                task.defer(function()
                    for _=1,20 do if m:GetAttribute("SeedName") then break end task.wait(0.05) end
                    if m:GetAttribute("SeedName")==name then added=added+1
                        local ok,cf=pcall(function() return m:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end
                    end
                end)
            end)
            local CAP = math.min(need * 4 + 30, 2000)   -- only scan roughly what we still need
            local spots, scanned = {}, 0
            for _,part in ipairs(areas) do
                if #spots >= CAP then break end
                local hx,hz = part.Size.X/2-1, part.Size.Z/2-1
                local lx = -hx + math.random()*1.2   -- random phase (avoid corner bias when capped)
                while lx <= hx do
                    local lz = -hz + math.random()*1.2
                    while lz <= hz do
                        local wp = (part.CFrame*CFrame.new(lx, part.Size.Y/2+0.2, lz)).Position
                        if farEnough(wp.X, wp.Z) then
                            local hit = workspace:Raycast(wp+Vector3.new(0,5,0), Vector3.new(0,-20,0), rp)
                            if hit then spots[#spots+1] = hit.Position; if #spots >= CAP then break end end
                        end
                        scanned = scanned + 1
                        if scanned % 200 == 0 then task.wait() end
                        lz = lz + 1.2
                    end
                    if #spots >= CAP then break end
                    lx = lx + 1.2
                end
            end
            for i = #spots, 2, -1 do local j = math.random(i); spots[i], spots[j] = spots[j], spots[i] end  -- shuffle
            if #spots == 0 then dbg(("no free spot for %s (garden full at spacing %.2f)"):format(name, 1.2)) end
            local placed = 0
            for _,pos in ipairs(spots) do
                if not active() or placed >= need then break end
                if farEnough(pos.X, pos.Z) then          
                    local before = added
                    hAdd(hash, pos.X, pos.Z)
                    pcall(function() Packet("PlantSeed"):Fire(pos, name, tool) end)
                    local t0 = os.clock()
                    repeat task.wait(0.1) until added>before or not active() or os.clock()-t0>1.5
                    if added>before then placed=placed+1 end
                    task.wait(0.25)
                end
            end
            conn:Disconnect()
            return placed
        end

        do local n={} for k,v in pairs(C.Targets) do n[#n+1]=k.."="..tostring(v) end
        print("[PB] plant+buy started; targets: "..(table.concat(n,", ")=="" and "(none)" or table.concat(n,", "))
                .."  keepBuying: "..((C.KeepBuyingAfterTarget and #C.KeepBuyingAfterTarget>0) and table.concat(C.KeepBuyingAfterTarget,", ") or "(none)")) end

        while active() do
            for name, target in pairs(C.Targets) do
                if not active() then break end
                if wantBuy(name, target) then local b=buySeed(name, 0); if b>0 then dbg(("bought %s x%d (inv %d)"):format(name,b,invCount(name))) end end
                if wantPlant(name, target) then local p=plantTopUp(name, target); if p>0 then print(("[PB] planted %s x%d (now %d/%d)"):format(name,p,plantedCount(name),target)) end
                else dbg(("%s target met (%d/%d) - plant stopped%s"):format(name, plantedCount(name), target, KEEPBUY[name] and ", still buying" or ", buy stopped")) end
            end
            for _=1, math.max(3, 20) do if not active() then return end task.wait(1) end
        end
        print("[PB] stopped.")
    end

    local function runHarvest(C)
        local function active() return alive() and Cfg.Harvest ~= false end
        local function dbg(...) if miscDebug() then print("[HARV]", ...) end end

        local P_Collect = Packet("CollectFruit")
        local MUTONLY={} for _,s in ipairs(C.MutationOnly or {}) do MUTONLY[tostring(s):lower()]=true end
        local MUT_SET={} for _,m in ipairs(C.Mutations or {}) do MUT_SET[tostring(m):lower()]=true end
        local function mutationOf(inst)
            local m=inst:GetAttribute("Mutation")
            if m==nil or m=="" or m=="None" then return nil end
            if next(MUT_SET)~=nil and not MUT_SET[tostring(m):lower()] then return nil end
            return tostring(m)
        end

        local _plot
        local function myPlot()
            if _plot and _plot.Parent then return _plot end
            local g=workspace:FindFirstChild("Gardens"); if not g then return nil end
            for _,p in ipairs(g:GetChildren()) do if p:GetAttribute("OwnerUserId")==lp.UserId then _plot=p; return p end end
        end
        local last_fire={}; local FIRE_CD=2.0

        local function sweep()
            local plot=myPlot(); if not plot then return 0 end
            local plants=plot:FindFirstChild("Plants"); if not plants then return 0 end
            local now=tick(); local fired,scanned=0,0
            for _,plant in ipairs(plants:GetChildren()) do
                if fired>=400 or not active() then break end
                scanned=scanned+1; if scanned % 50 == 0 then task.wait() end
                local seedName=tostring(plant:GetAttribute("SeedName") or ""):lower()
                local mutOnly=MUTONLY[seedName]==true
                local fruits=plant:FindFirstChild("Fruits") or plant:FindFirstChild("F")
                if fruits then
                    for _,fruit in ipairs(fruits:GetChildren()) do
                        local fruitId=fruit:GetAttribute("FruitId")
                        if fruitId~=nil and ((not mutOnly) or mutationOf(fruit)~=nil) then
                            local plantId=fruit:GetAttribute("PlantId")
                            local age,maxAge=fruit:GetAttribute("Age"),fruit:GetAttribute("MaxAge")
                            local ripeOk=(type(age)=="number" and type(maxAge)=="number" and age>=maxAge)   -- always ripe-only
                            now=tick(); local cdOk=(not last_fire[fruitId]) or (now-last_fire[fruitId]>=FIRE_CD)
                            if plantId and ripeOk and cdOk then
                                pcall(function() P_Collect:Fire(plantId, fruitId) end)
                                last_fire[fruitId]=now; fired=fired+1; task.wait(0.08)
                                if fired>=400 then break end
                            end
                        end
                    end
                else
                    if (not mutOnly) or mutationOf(plant)~=nil then
                        local plantId=plant:GetAttribute("PlantId")
                        local ready=plant:GetAttribute("PlantGrowthReady")==true
                        if not ready then local a,m=plant:GetAttribute("Age"),plant:GetAttribute("MaxAge"); ready=type(a)=="number" and type(m)=="number" and a>=m end
                        now=tick(); local cdOk=(not last_fire[plantId]) or (now-last_fire[plantId]>=FIRE_CD)
                        if plantId and ready and cdOk then
                            pcall(function() P_Collect:Fire(plantId, "") end)
                            last_fire[plantId]=now; fired=fired+1; task.wait(0.08)
                        end
                    end
                end
            end
            if next(last_fire) then for id,t in pairs(last_fire) do if now-t>FIRE_CD*4 then last_fire[id]=nil end end end
            return fired
        end

        print("[HARV] harvest started; mutation-only seeds: "..(#(C.MutationOnly or {})>0 and table.concat(C.MutationOnly,", ") or "(none)"))
        while active() do
            local ok,fired = pcall(sweep)
            if not ok then
                warn("[HARV] sweep error (recovered): "..tostring(fired))
            elseif fired and fired>0 then
                print(("[HARV] sweep harvested %d"):format(fired))
            end
            -- NONSTOP (always on): re-sweep immediately when fruit was harvested; a tiny
            -- breather only when nothing was ripe, so an empty garden isn't scanned every frame.
            if fired and fired>0 then task.wait() else task.wait(0.5) end
        end
        print("[HARV] stopped.")
    end

    local function runSell(C)
        local function active() return alive() and Cfg.Sell ~= false end
        local function dbg(...) if miscDebug() then print("[SELL]", ...) end end
        local P_Sell = Packet("SellAll")
        local function fruitCount() return tonumber(lp:GetAttribute("FruitCount")) or 0 end
        local function maxCap()     return tonumber(lp:GetAttribute("MaxFruitCapacity")) or 100 end
        local fullMode = (tostring(C.Mode or "full"):lower() ~= "always")
        local function threshold()
            if C.SellAtPercent and C.SellAtPercent > 0 then
                return math.max(1, math.floor(maxCap() * math.clamp(C.SellAtPercent, 0, 1) + 0.5))
            end
            return tonumber(C.SellAtFruitCount) or 90
        end
        print(("[SELL] started; mode=%s%s  (capacity %d)")
            :format(fullMode and "sell-when-full" or "sell-always",
                    fullMode and (" threshold="..threshold()) or "", maxCap()))
        -- EVENT-DRIVEN: sell the INSTANT FruitCount crosses the threshold (no polling wait, no
        -- post-sell delay). The 0.5s guard only dedups the burst while a sell is in flight
        -- (FruitCount takes a server round-trip to drop) - the first sell is immediate.
        local lastSell = 0
        local function trySell()
            if not active() then return end
            local fc = fruitCount()
            local hit = fullMode and (fc >= threshold()) or ((not fullMode) and fc > 0)
            if hit and (os.clock() - lastSell) >= 0.5 then
                lastSell = os.clock()
                pcall(function() P_Sell:Fire() end)
                dbg(("sold (fruit was %d/%d, threshold %d)"):format(fc, maxCap(), threshold()))
            end
        end
        local conn
        pcall(function() conn = lp:GetAttributeChangedSignal("FruitCount"):Connect(trySell) end)
        trySell()   -- in case the backpack is already full at start
        while active() do trySell(); task.wait(2) end   -- light safety net; the event does the selling
        if conn then pcall(function() conn:Disconnect() end) end
        print("[SELL] stopped.")
    end

    local function runSeedGrab(C)
        local function active() return alive() and Cfg.CollectEventSeeds ~= false end
        local function dbg(...) if miscDebug() then print("[SEEDGRAB]", ...) end end
        local function getRoot() local c=lp.Character; if not c then return nil end return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso"), c end
        local YOFF = 3.0   -- hardcoded teleport height offset
        local function teleportTo(pos) local r,c=getRoot(); if not c then return end pcall(function() c:PivotTo(CFrame.new(pos+Vector3.new(0, YOFF, 0))) end)
            if r then pcall(function() r.AssemblyLinearVelocity=Vector3.zero; r.AssemblyAngularVelocity=Vector3.zero end) end end  -- anti-fall
        local function spawnInfo(part)
            if part:GetAttribute("RainbowSeed")==true then return "Rainbow Seed","rainbow" end
            if part:GetAttribute("GoldSeed")==true then return "Gold Seed","gold" end
            local sp=part:GetAttribute("SeedPack")
            if type(sp)=="string" and sp~="" then
                local low=sp:lower()
                if low:find("rainbow") then return sp,"rainbow" end  
                if low:find("gold")    then return sp,"gold"    end  
                return sp,"pack"
            end
            return nil,nil
        end
        -- accept both new (Collect*) and old (Grab*) key names; rainbow/gold default ON
        -- (only OFF if explicitly false), packs default OFF. Prevents a rename/missing-key
        -- mismatch from silently filtering every seed out (= "won't teleport").
        local function wanted(k)
            if k=="rainbow" then local v=C.CollectRainbow; if v==nil then v=C.GrabRainbow end; return v ~= false
            elseif k=="gold" then local v=C.CollectGold;   if v==nil then v=C.GrabGold   end; return v ~= false
            elseif k=="pack" then local v=C.CollectAllSeedPacks; if v==nil then v=C.GrabAllSeedPacks end; return v == true end
            return false
        end
        local function spawnPos(part) if part:IsA("BasePart") then return part.Position end local ok,cf=pcall(function() return part:GetPivot() end); if ok then return cf.Position end end
        local claiming={}; local skip={}   
        local function claimSpawn(part)
            if claiming[part] or skip[part] or not (part and part.Parent) then return end
            claiming[part]=true
            local _,char=getRoot(); local startCF=char and char:GetPivot()
            local name,kind=spawnInfo(part)
            if name and not wanted(kind) then dbg("skip (filtered):", name); skip[part]=true; claiming[part]=nil return end
            local pos=spawnPos(part)
            if pos and pos.Magnitude>=1 then teleportTo(pos) end
            if not name then local dl=os.clock()+1.5 repeat task.wait(); name,kind=spawnInfo(part) until name or os.clock()>dl or not part.Parent end
            if not (part.Parent and name) then claiming[part]=nil return end
            if not wanted(kind) then
                dbg("skip (filtered):", name); skip[part]=true
                if startCF then local _,ch=getRoot(); if ch then pcall(function() ch:PivotTo(startCF) end) end end
                claiming[part]=nil return
            end
            if not pos or pos.Magnitude<1 then local dl=os.clock()+1.5 repeat task.wait(); pos=spawnPos(part) until (pos and pos.Magnitude>=1) or os.clock()>dl or not part.Parent end
            if not (part.Parent and pos) then claiming[part]=nil return end
            print(("[SEEDGRAB] *** %s SPAWNED *** at %s - claiming"):format(name, tostring(pos)))
            local t0=os.clock()
            while active() and part.Parent and (os.clock()-t0)<2 do
                grabUntil = os.clock() + 0.5   -- anchor-float during the grab (true anti-fall)
                teleportTo(spawnPos(part) or pos)
                for _,d in ipairs(part:GetDescendants()) do
                    if d:IsA("ProximityPrompt") and typeof(fireproximityprompt)=="function" then
                        pcall(function() d.HoldDuration=0; d.RequiresLineOfSight=false; d.MaxActivationDistance=math.max(d.MaxActivationDistance or 0, 60) end)
                        pcall(function() fireproximityprompt(d) end)
                    elseif d:IsA("ClickDetector") and typeof(fireclickdetector)=="function" then pcall(function() fireclickdetector(d) end) end
                end
                task.wait(0.06)
            end
            if not part.Parent then print(("[SEEDGRAB] claimed %s"):format(name)) else dbg("claim timeout:", name) end
            if startCF then local _,ch=getRoot(); if ch then pcall(function() ch:PivotTo(startCF) end) end end
            claiming[part]=nil
        end
        local map=workspace:WaitForChild("Map",30)
        local sl=map and map:FindFirstChild("SeedPackSpawnServerLocations")
        if not sl then warn("[SEEDGRAB] SeedPackSpawnServerLocations not found - seed-grab aborting") return end
        local function scanNow() for _,c in ipairs(sl:GetChildren()) do if active() then task.spawn(claimSpawn,c) end end end
        sl.ChildAdded:Connect(function(c) if active() then task.spawn(claimSpawn,c) end end)
        pcall(function()
            local Net=require(RS.SharedModules.Networking); local sp=Net and Net.SeedPackSpawn
            if sp then
                if sp.Announce then sp.Announce.OnClientEvent:Connect(function() if active() then scanNow() end end) end
                if sp.FX then sp.FX.OnClientEvent:Connect(function() if active() then scanNow() end end) end
            end
        end)
        task.spawn(function() while active() do scanNow(); task.wait(0.5) end end)   
        scanNow()
        print(("[SEEDGRAB] started (rainbow=%s gold=%s allPacks=%s)"):format(tostring(C.CollectRainbow), tostring(C.CollectGold), tostring(C.CollectAllSeedPacks)))
    end

    local function runMail(C)
        local function mail_active() return alive() and Cfg.Mail ~= false end
        local RECIPIENT_USERNAME=C.TargetUsername; local RECIPIENT_USERID=C.TargetUserId
        local MESSAGE=C.MessageMail; local LIST_ITEM=C.ListItem
        local MAX_PER_ITEM=(C.MaxPerItem and C.MaxPerItem>0) and C.MaxPerItem or math.huge
        local SEND_DEBOUNCE=5; local MAX_ITEMS_PER_GIFT=20
        local SEND_WHEN_COUNT=C.SendWhenCount; local SEND_AMOUNT=C.SendAmount; local WATCH_INTERVAL=10
        local INCLUDE_FRUITS=false
        local ReplicaClient=require(RS.ClientModules.ReplicaClient)
        print(string.rep("=",56)); print("GAG2 Auto Send Mail  [LIVE]"); print(string.rep("=",56))
        local PER_INSTANCE={ Pets=true, HarvestedFruits=true }
        local GIFTABLE={"Seeds","SeedPacks","Crates","Sprinklers","WateringCans","Mushrooms","Gnomes","Raccoons","Trowels","Props","Pets","HarvestedFruits"}
        local function normName(s) s=tostring(s):lower():gsub("^%s+",""):gsub("%s+$",""); s=s:gsub("%s*seed$",""); return s end
        local CAT_ALIAS={seed="Seeds",seeds="Seeds",fruit="HarvestedFruits",fruits="HarvestedFruits",harvestedfruit="HarvestedFruits",harvestedfruits="HarvestedFruits",pet="Pets",pets="Pets",crate="Crates",crates="Crates",pack="SeedPacks",packs="SeedPacks",seedpack="SeedPacks",seedpacks="SeedPacks",sprinkler="Sprinklers",sprinklers="Sprinklers",can="WateringCans",cans="WateringCans",wateringcan="WateringCans",wateringcans="WateringCans",mushroom="Mushrooms",mushrooms="Mushrooms",gnome="Gnomes",gnomes="Gnomes",raccoon="Raccoons",raccoons="Raccoons",trowel="Trowels",trowels="Trowels",prop="Props",props="Props"}
        local function parseNameList(str)
            local anyN,catN,n={},{},0
            for token in tostring(str):gmatch("[^,]+") do
                token=token:gsub("^%s+",""):gsub("%s+$","")
                local catRaw,nameRaw=token:match("^([%a]+)%s*:%s*(.+)$")
                if catRaw and nameRaw then local cat=CAT_ALIAS[catRaw:lower()]; local nm=normName(nameRaw); if cat and nm~="" then catN[cat]=catN[cat] or {}; catN[cat][nm]=true; n=n+1 end
                else local nm=normName(token); if nm~="" then anyN[nm]=true; n=n+1 end end
            end
            return anyN,catN,n
        end
        local NAME_SET,CAT_NAME_SET,NAME_COUNT=parseNameList(LIST_ITEM)
        local SEND_ALL=(LIST_ITEM:lower():gsub("%s","")=="*" or LIST_ITEM:lower():gsub("%s","")=="all")
        local BLACKLIST={}; for _,nm in ipairs(C.Blacklist or {}) do BLACKLIST[normName(nm)]=true end
        local function resolveRecipient()
            if type(RECIPIENT_USERID)=="number" and RECIPIENT_USERID>0 then return RECIPIENT_USERID end
            local _rl = (type(RECIPIENT_USERNAME)=="string" and RECIPIENT_USERNAME:lower():gsub("%s","")) or ""
            if _rl=="" or _rl=="username" or _rl=="puttargetusernamehere" or _rl=="targetusername" then
                return nil, "set a real TargetUsername (placeholder '"..tostring(RECIPIENT_USERNAME).."' rejected)" end
            for _,pl in ipairs(Players:GetPlayers()) do if pl.Name:lower()==RECIPIENT_USERNAME:lower() or pl.DisplayName:lower()==RECIPIENT_USERNAME:lower() then return pl.UserId end end
            local ok,info=pcall(function() return Packet("MailboxLookupPlayer"):Fire(RECIPIENT_USERNAME) end)
            if ok and type(info)=="table" and (info.UserId or info.userId) then return info.UserId or info.userId end
            if ok and type(info)=="number" and info>0 then return info end
            local ok2,uid=pcall(function() return Players:GetUserIdFromNameAsync(RECIPIENT_USERNAME) end)
            if ok2 and type(uid)=="number" then return uid end
            return nil, "could not resolve '"..RECIPIENT_USERNAME.."'"
        end
        local _psRep   -- cache the PlayerState replica (avoid re-scanning all replicas each pass)
        local function getInventory()
            if _psRep and _psRep.Data and _psRep.Data.Inventory then return _psRep.Data.Inventory end
            local ok,reg=pcall(ReplicaClient.Test); if not ok then return nil end
            for _,rep in pairs(reg.Replicas or {}) do if rep.Token=="PlayerState" and rep.Data and rep.Data.Inventory then _psRep=rep; return rep.Data.Inventory end end
        end
        local function nameAllowed(category, displayName)
            local nn=normName(displayName)
            if BLACKLIST[nn] then return false end
            local cset=CAT_NAME_SET[category]; if cset and cset[nn] then return true end
            if category=="HarvestedFruits" and not INCLUDE_FRUITS then return false end
            if SEND_ALL then return true end
            return NAME_SET[nn]==true
        end
        local function buildItems(inv)
            local items={}
            for _,cat in ipairs(GIFTABLE) do
                local t=inv[cat]
                if type(t)=="table" then
                    if PER_INSTANCE[cat] then
                        local byName={}
                        for key,val in pairs(t) do local nm=(type(val)=="table" and (val.Name or val.FruitName)) or tostring(key); if nameAllowed(cat,nm) then byName[nm]=byName[nm] or {}; table.insert(byName[nm],key) end end
                        for nm,uids in pairs(byName) do local have=#uids; if have>=SEND_WHEN_COUNT then local toSend=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; toSend=math.min(toSend,MAX_PER_ITEM); for i=1,toSend do table.insert(items,{Category=cat,ItemKey=uids[i],Count=1,_display=nm,_have=have}) end end end
                    else
                        for key,val in pairs(t) do local have=tonumber(val) or 0; if nameAllowed(cat,key) and have>=SEND_WHEN_COUNT then local sc=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; sc=math.min(sc,MAX_PER_ITEM); if sc>0 then table.insert(items,{Category=cat,ItemKey=key,Count=sc,_display=key,_have=have}) end end end
                    end
                end
            end
            return items
        end
        local function chunk(list,size) local out,cur={},{} for _,v in ipairs(list) do table.insert(cur,v); if #cur>=size then table.insert(out,cur); cur={} end end if #cur>0 then table.insert(out,cur) end return out end
        if SEND_ALL then print("[MAIL] filter: SEND ALL giftable items")
        elseif NAME_COUNT>0 then print(("[MAIL] filter: by name (%d), fruits=%s"):format(NAME_COUNT, INCLUDE_FRUITS and "included" or "excluded"))
        else warn("[MAIL] ListItem empty - nothing to do") return end
        local userId,err1=resolveRecipient()
        if not userId then warn("[MAIL] recipient error: "..tostring(err1)) return end
        print(("[MAIL] recipient = %s (UserId %s); threshold=%d"):format(tostring(RECIPIENT_USERNAME), tostring(userId), SEND_WHEN_COUNT))

        local cumMails, cumSeeds = 0, 0   
        local function postWebhook(sentByName, total)
            if (Cfg.WebhookConfig or {}).Mail == false then return end   
            cumMails = cumMails + 1
            cumSeeds = cumSeeds + (tonumber(total) or 0)
            local lines = {}
            for nm, ct in pairs(sentByName) do lines[#lines+1] = ("%s x%d"):format(tostring(nm), ct) end
            local itemsText = (#lines > 0) and table.concat(lines, "\n") or "(none)"
            if #itemsText > 1000 then itemsText = itemsText:sub(1, 1000) .. "\n..." end
            local wc = Cfg.WebhookConfig or {}
            local ok = webhookPost(wc.MailUrl, {
                embeds = {{
                    title = "Auto-Mail",
                    color = 5763719,
                    fields = {
                        { name = "Sender",    value = tostring(lp.Name), inline = true },
                        { name = "Recipient", value = ("%s (UserId %s)"):format(tostring(RECIPIENT_USERNAME), tostring(userId)), inline = true },
                        { name = "Last send", value = itemsText, inline = false },
                        { name = "Total Mails Sent",   value = tostring(cumMails), inline = true },
                        { name = "Total Seeds Mailed", value = tostring(cumSeeds), inline = true },
                    },
                    footer = { text = "GAG2 Auto-Mail " .. os.date("%Y-%m-%d %H:%M:%S") },
                }},
            }, wc.MailMessageID, "Mail")
            if ok and miscDebug() then print("[MAIL] webhook posted") end
        end

        local function doSendPass()
            local inv=getInventory(); if not inv then return 0 end
            local items=buildItems(inv); if #items==0 then return 0 end
            local batches=chunk(items,MAX_ITEMS_PER_GIFT); local sent=0; local sentByName={}
            for bi,batch in ipairs(batches) do
                local clean={}; for _,it in ipairs(batch) do table.insert(clean,{Category=it.Category,ItemKey=it.ItemKey,Count=it.Count}) end
                local ok=pcall(function() return Packet("MailboxSendBatch"):Fire(userId,clean,MESSAGE) end)
                if ok then
                    for _,it in ipairs(batch) do sent=sent+it.Count; sentByName[it._display]=(sentByName[it._display] or 0)+it.Count end
                    print(("[MAIL] batch %d/%d sent (%d entries)"):format(bi,#batches,#clean))
                end
                if bi<#batches then task.wait(SEND_DEBOUNCE) end
            end
            if sent>0 then postWebhook(sentByName, sent) end
            return sent
        end
        print("[MAIL] watch started - auto-send when count >= "..SEND_WHEN_COUNT)
        while mail_active() do
            local ok,sent=pcall(doSendPass)
            if ok and sent and sent>0 then task.wait(SEND_DEBOUNCE) end
            task.wait(WATCH_INTERVAL)
        end
        print("[MAIL] watch stopped.")
    end

    local function runWebhook(C)
        local function active() return alive() and Cfg.Webhook ~= false end
        local function dbg(...) if miscDebug() then print("[WEBHOOK]", ...) end end
        if C.Inventory == false then print("[WEBHOOK] ready (inventory snapshot off; mail webhook still active)"); return end
        local ReplicaClient = require(RS.ClientModules.ReplicaClient)
        local SEED_CATS = { "Seeds" }
        local GEAR_CATS = { "Sprinklers", "WateringCans", "Trowels", "Rakes", "Ladders", "Teleporters", "Flashbangs" }
        local PET_CATS  = { "Pets", "Birds", "Gnomes", "Raccoons" }
        local PER_INSTANCE = { Pets=true, Birds=true, Gnomes=true, Raccoons=true, HarvestedFruits=true, Eggs=true }
        local function getData()
            local ok,reg = pcall(ReplicaClient.Test); if not ok then return nil end
            for _,rep in pairs(reg.Replicas or {}) do if rep.Token=="PlayerState" and rep.Data then return rep.Data end end
        end
        local function summarize(inv, cats)
            local lines, total = {}, 0
            for _,cat in ipairs(cats or {}) do
                local t = inv[cat]
                if type(t)=="table" then
                    if PER_INSTANCE[cat] then
                        local byName = {}
                        for _,val in pairs(t) do
                            local nm = (type(val)=="table" and (val.Name or val.PetName or val.FruitName)) or cat
                            byName[nm] = (byName[nm] or 0) + 1; total = total + 1
                        end
                        for nm,ct in pairs(byName) do lines[#lines+1] = ("%s x%d"):format(tostring(nm), ct) end
                    else
                        for key,val in pairs(t) do local n=tonumber(val) or 0; if n>0 then lines[#lines+1]=("%s x%d"):format(tostring(key), n); total=total+n end end
                    end
                end
            end
            table.sort(lines)
            return lines, total
        end
        local function fieldFor(name, lines, total)
            local v = (#lines>0) and table.concat(lines, "\n") or "(none)"
            if #v > 1000 then v = v:sub(1, 1000) .. "\n..." end
            return { name = ("%s (%d)"):format(name, total), value = v, inline = false }
        end
        print(("[WEBHOOK] inventory snapshot started; interval=%ss"):format(tostring(C.InventoryInterval or 300)))
        while active() do
            local data = getData()
            if data then
                local sheckles = math.floor(tonumber(data.Sheckles) or 0)
                local inv = data.Inventory or {}
                local sL,sT = summarize(inv, SEED_CATS)
                local gL,gT = summarize(inv, GEAR_CATS)
                local pL,pT = summarize(inv, PET_CATS)
                local ok = webhookPost(C.InventoryUrl, {
                    embeds = {{
                        title = "Inventory Snapshot",
                        description = ("Player: **%s**\nSheckles: **%d**"):format(tostring(lp.Name), sheckles),
                        color = 3447003,
                        fields = { fieldFor("Seeds", sL, sT), fieldFor("Gear", gL, gT), fieldFor("Pets", pL, pT) },
                        footer = { text = "GAG2 Inventory " .. os.date("%Y-%m-%d %H:%M:%S") },
                    }},
                }, C.InventoryMessageID, "Inventory")
                if ok then dbg(("posted (sheckles=%d seeds=%d gear=%d pets=%d)"):format(sheckles, sT, gT, pT)) end
            end
            for _=1, math.max(10, C.InventoryInterval or 300) do if not active() then return end task.wait(1) end
        end
        print("[WEBHOOK] inventory snapshot stopped.")
    end

    local function runBuyGears(C)
        local function active() return alive() and Cfg.BuyGears ~= false end
        local function dbg(...) if miscDebug() then print("[BUYGEAR]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[BUYGEAR] PlayerState replica unavailable - aborting"); return end
        local function data() return replica.Data end
        local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end

        local GearShopData = require(RS.SharedModules.GearShopData)
        local GEAR = {}   
        local function scanGear(t, depth)
            if depth > 3 then return end
            for _,e in pairs(t) do
                if type(e)=="table" then
                    if e.ItemName then GEAR[e.ItemName] = { Cost = tonumber(e.Cost) or 0, Rarity = tostring(e.Rarity or "") }
                    else scanGear(e, depth+1) end
                end
            end
        end
        scanGear(GearShopData, 0)

        local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("GearShop", 20)
        if not SS then warn("[BUYGEAR] StockValues.GearShop not found - aborting"); return end
        local ITEMS = SS:WaitForChild("Items", 20)
        local function stockMax(n) local v=ITEMS:FindFirstChild(n); return (v and v:IsA("ValueBase") and v.Value) or 0 end
        local function purchased(n) local d=data(); local g=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Gears; return (g and g[n]) or 0 end
        local function remaining(n) return math.max(0, stockMax(n)-purchased(n)) end

        local rarWant = {}; for _,r in ipairs(C.Rarities or {}) do rarWant[tostring(r):lower()] = true end
        local hasRar = next(rarWant) ~= nil
        local function buildWanted()
            local want = {}
            for _,name in ipairs(C.ListGear or {}) do want[name] = true end
            if hasRar then for name,info in pairs(GEAR) do if rarWant[info.Rarity:lower()] and stockMax(name)>0 then want[name]=true end end end
            return want
        end
        local function buyOne(name)
            local info = GEAR[name]
            if not info then warn(("[BUYGEAR] unknown gear '%s' (check spelling)"):format(name)); return 0 end
            local cost, bought = info.Cost, 0
            while active() do
                if remaining(name)<=0 then break end
                if sheckles()<cost then break end
                local before = purchased(name)
                pcall(function() Net.GearShop.PurchaseGear:Fire(name) end)
                local t0=os.clock(); repeat task.wait(0.1) until purchased(name)>before or not active() or os.clock()-t0>1.5
                if purchased(name)>before then bought=bought+1 else break end
                task.wait(0.15)
            end
            return bought
        end
        print("[BUYGEAR] started")
        while active() do
            local want = buildWanted()
            for name in pairs(want) do
                if not active() then break end
                if remaining(name)>0 then local b=buyOne(name); if b>0 then print(("[BUYGEAR] bought %s x%d (Sheckles ~%d)"):format(name,b,math.floor(sheckles()))) end end
            end
            for _=1, math.max(2, 20 or 6) do if not active() then return end task.wait(1) end
        end
        print("[BUYGEAR] stopped.")
    end

    local function runBuyPets(C)
        local function active() return alive() and Cfg.BuyPets ~= false end
        local function dbg(...) if miscDebug() then print("[BUYPET]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[BUYPET] PlayerState replica unavailable - aborting"); return end
        local function sheckles() local d=replica.Data; return (d and d.Sheckles) or 0 end

        local map = workspace:WaitForChild("Map", 30)
        local refFolder = map and map:WaitForChild("WildPetRef", 30)
        if not refFolder then warn("[BUYPET] Map.WildPetRef not found - aborting"); return end

        local function root() local c=lp.Character; return c and c:FindFirstChild("HumanoidRootPart") end
        local function tpTo(pos) local h=root(); if not h then return false end pcall(function() h.CFrame=CFrame.new(pos+Vector3.new(0,4,0)); h.AssemblyLinearVelocity=Vector3.zero; h.AssemblyAngularVelocity=Vector3.zero end); return true end  -- anti-fall

        local spWant, raWant = {}, {}
        for _,s in ipairs(C.ListPets or {}) do spWant[tostring(s):lower()] = true end
        for _,r in ipairs(C.Rarities or {}) do raWant[tostring(r):lower()] = true end
        local hasSp, hasRa = next(spWant)~=nil, next(raWant)~=nil

        pcall(function() Net.Pets.WildPetTameResult.OnClientEvent:Connect(function(part,val) if active() then dbg(("buy result: %s -> %s"):format(part and part.Name or "?", tostring(val))) end end) end)

        local RANK = { common=1, uncommon=2, rare=3, super=4, legendary=5, mythic=6, divine=7, secret=8 }
        local function rarityRank(part) return RANK[tostring(part:GetAttribute("Rarity") or ""):lower()] or 0 end

        local handled  = {}   
        local cooldown = {}   

        local function wantPet(part)
            if part:GetAttribute("OwnerUserId") ~= 0 then return false end   
            local pn = tostring(part:GetAttribute("PetName") or "")
            local rr = tostring(part:GetAttribute("Rarity") or "")
            if hasSp and not spWant[pn:lower()] then return false end
            if hasRa and not raWant[rr:lower()] then return false end
            local price = tonumber(part:GetAttribute("Price")) or 0
            if sheckles() < price then return false end
            return true, pn, rr, price
        end
        local function claimWild(part)
            local ok, pn, rr, price = wantPet(part)
            if not ok then return false end
            local home; do local h=root(); if h then home=h.Position end end  
            pcall(function() Net.Pets.WildPetTame:Fire(part) end)
            task.wait(0.1)
            if part.Parent and (part:GetAttribute("OwnerUserId") or 0) == 0 then
                grabUntil = os.clock() + 0.5   -- anchor-float from the moment we teleport onto the pet
                local p = select(2, pcall(function() return part.Position end))
                if typeof(p)=="Vector3" then tpTo(p); task.wait(0.1) end
                pcall(function() Net.Pets.WildPetTame:Fire(part) end)
            end
            local t0 = os.clock()
            while active() and part.Parent and (part:GetAttribute("OwnerUserId") or 0) == 0 and os.clock()-t0 <= 3 do
                grabUntil = os.clock() + 0.5   -- anchor-float during the grab (true anti-fall)
                do local p = select(2, pcall(function() return part.Position end)); if typeof(p)=="Vector3" then tpTo(p) end end
                task.wait(0.1)
            end
            if home then tpTo(home) end
            local mine = (not part.Parent) or (part:GetAttribute("OwnerUserId") == lp.UserId)
            if mine then
                handled[part] = true
                print(("[BUYPET] claimed %s (%s) ~%d Sheckles"):format(pn,rr,price))
            else
                cooldown[part] = os.clock() + 3
                dbg(("claim not confirmed for %s (%s)"):format(pn,rr))
            end
            return mine
        end
        local dirty = false
        refFolder.ChildAdded:Connect(function() if active() then dirty = true end end)
        print("[BUYPET] started (event-driven + rarity priority)")
        while active() do
            local best, bestRank
            for _,part in ipairs(refFolder:GetChildren()) do
                if part:IsA("BasePart") and not handled[part] and not (cooldown[part] and os.clock() < cooldown[part]) then
                    if select(1, wantPet(part)) then
                        local rk = rarityRank(part)
                        if not best or rk > bestRank then best, bestRank = part, rk end
                    end
                end
            end
            for p in pairs(handled)  do if not p.Parent then handled[p]  = nil end end
            for p in pairs(cooldown) do if not p.Parent then cooldown[p] = nil end end
            if best then
                claimWild(best); task.wait(0.3)
            else
                local idleFor, waited = math.max(0.5, 20 or 1), 0
                while active() and not dirty and waited < idleFor do task.wait(0.1); waited = waited + 0.1 end
                dirty = false
            end
        end
        print("[BUYPET] stopped.")
    end

    local function runExpandPlot(C)
        local function active() return alive() and Cfg.ExpandPlot ~= false end
        local function dbg(...) if miscDebug() then print("[EXPAND]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[EXPAND] PlayerState replica unavailable - aborting"); return end
        local function sheckles() local d=replica.Data; return (d and d.Sheckles) or 0 end
        local function owned() return tonumber(replica.Data.OwnedExpansions) or 1 end

        local EP = require(RS.SharedData.ExpansionPrices)
        local GardenFlags; pcall(function() GardenFlags = require(RS.SharedModules.Flags.GardenFlags) end)
        local maxIdx = #EP
        local function nextInfo()
            local o = owned(); local nIdx = o + 1; local e = EP[nIdx]
            if not e then return nil, nil, o end
            local price = tonumber(e.Price) or 0
            if GardenFlags and GardenFlags.ExpansionPriceOverrides then
                local ok, ov = pcall(function() return GardenFlags.ExpansionPriceOverrides:Get() end)
                if ok and type(ov)=="table" and ov[tostring(nIdx)] then price = tonumber(ov[tostring(nIdx)]) or price end
            end
            return nIdx, price, o
        end
        print("[EXPAND] started")
        while active() do
            local target = math.min(tonumber(C.TargetExpansions) or maxIdx, maxIdx)
            local nIdx, price, o = nextInfo()
            while active() and nIdx and o < target and sheckles() >= price do
                local before = o
                pcall(function() Net.Actions.ExpandGarden:Fire() end)
                local t0=os.clock(); repeat task.wait(0.2) until owned()>before or not active() or os.clock()-t0>5
                if owned()>before then print(("[EXPAND] expanded -> %d/%d (cost ~%d)"):format(owned(), target, price))
                else dbg("expand not confirmed (afford/max?)"); break end
                nIdx, price, o = nextInfo()
            end
            for _=1, math.max(3, 20 or 10) do if not active() then return end task.wait(1) end
        end
        print("[EXPAND] stopped.")
    end

    local function runBuySlot(C)
        local function active() return alive() and Cfg.BuySlot ~= false end
        local function dbg(...) if miscDebug() then print("[SLOT]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[SLOT] PlayerState replica unavailable - aborting"); return end
        local function sheckles() local d=replica.Data; return (d and d.Sheckles) or 0 end

        local SP = require(RS.SharedData.PetSlotPrices)
        local baseMax = tonumber(SP.BaseMax) or 3
        local absMax  = tonumber(SP.AbsoluteMax) or 6
        local prices  = SP.Prices or {}
        local function maxPets() return tonumber(lp:GetAttribute("MaxEquippedPets")) or baseMax end
        local function nextPrice()
            local cur = maxPets(); if cur >= absMax then return nil end
            return tonumber(prices[(cur-baseMax)+1]) or 0
        end
        print("[SLOT] started")
        while active() do
            local target = math.min(tonumber(C.TargetSlots) or absMax, absMax)
            local price = nextPrice()
            while active() and price and maxPets()<target and sheckles()>=price do
                local before = maxPets()
                pcall(function() Net.Pets.RequestPurchasePetSlot:Fire() end)
                local t0=os.clock(); repeat task.wait(0.2) until maxPets()>before or not active() or os.clock()-t0>5
                if maxPets()>before then print(("[SLOT] bought pet slot -> %d/%d (cost ~%d)"):format(maxPets(),target,price))
                else dbg("slot buy not confirmed (afford/max?)"); break end
                price = nextPrice()
            end
            for _=1, math.max(3, 20 or 10) do if not active() then return end task.wait(1) end
        end
        print("[SLOT] stopped.")
    end

    local function runEquipPets(C)
        local function active() return alive() and Cfg.EquipPets ~= false end
        local function dbg(...) if miscDebug() then print("[EQUIP]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[EQUIP] PlayerState replica unavailable - aborting"); return end

        local want = {}; for _,n in ipairs(C.ListEquip or {}) do want[n] = (want[n] or 0) + 1 end
        local wantRar = {}; for _,r in ipairs(C.EquipRarities or {}) do wantRar[tostring(r):lower()] = true end
        local hasRar = next(wantRar) ~= nil
        if next(want)==nil and not hasRar then warn("[EQUIP] ListEquip + EquipRarities both empty - aborting"); return end

        local PetData = require(RS.SharedData.PetData)   
        local function petRarity(name) local e=PetData[name]; return (e and tostring(e.Rarity or "")) or "" end
        local function rarWanted(name) return hasRar and wantRar[petRarity(name):lower()] == true end

        local function pets() local d=replica.Data; return (d and d.Inventory and d.Inventory.Pets) or {} end
        local function equippedCount(n) local c=0 for _,p in pairs(pets()) do if p.Name==n and p.Equipped then c=c+1 end end return c end
        local function totalEquipped() local c=0 for _,p in pairs(pets()) do if p.Equipped then c=c+1 end end return c end
        local function haveUnequipped(n) for _,p in pairs(pets()) do if p.Name==n and not p.Equipped then return true end end return false end
        local function isWanted(n) return (want[n] or 0) > 0 or rarWanted(n) end
        local function equipOne(name)
            local before = equippedCount(name)
            pcall(function() Net.Pets.RequestEquipByName:Fire(name) end)
            local t0=os.clock(); repeat task.wait(0.2) until equippedCount(name)>before or not active() or os.clock()-t0>3
            if equippedCount(name)>before then print(("[EQUIP] equipped %s (%s)"):format(name, petRarity(name))); return true end
            dbg("equip not confirmed for "..name); return false
        end
        print("[EQUIP] started")
        while active() do
            local cap = tonumber(lp:GetAttribute("MaxEquippedPets")) or 3
            for _,p in pairs(pets()) do
                if not active() then break end
                if p.Equipped and not isWanted(p.Name) then
                    pcall(function() Net.Pets.RequestUnequipByName:Fire(p.Name) end); task.wait(0.3)
                end
            end
            for name,n in pairs(want) do
                if not active() then break end
                while active() and equippedCount(name)<n and totalEquipped()<cap and haveUnequipped(name) do
                    if not equipOne(name) then break end
                    task.wait(0.2)
                end
            end
            if hasRar then
                while active() and totalEquipped()<cap do
                    local target
                    for _,p in pairs(pets()) do
                        if (not p.Equipped) and rarWanted(p.Name) and not ((want[p.Name] or 0) > 0) then target=p.Name; break end
                    end
                    if not target then break end
                    if not equipOne(target) then break end
                    task.wait(0.2)
                end
            end
            for _=1, math.max(3, 20 or 8) do if not active() then return end task.wait(1) end
        end
        print("[EQUIP] stopped.")
    end

    local function runRedeemCodes(C)
        local function dbg(...) if miscDebug() then print("[CODE]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local codes = C.ListCodes or {}
        if #codes == 0 then dbg("no codes listed - skip"); return end
        print(("[CODE] redeeming %d code(s)"):format(#codes))
        for _, code in ipairs(codes) do
            if not alive() then return end
            code = tostring(code):gsub("^%s+",""):gsub("%s+$","")
            if code ~= "" then
                local ok, res = pcall(function() return Net.Settings.SubmitCode:InvokeServer(code) end)
                if ok then
                    print(("[CODE] '%s' -> %s"):format(code, tostring(res)))
                else
                    pcall(function() Net.Settings.SubmitCode:Fire(code) end)  
                    print(("[CODE] '%s' submitted (fire)"):format(code))
                end
                task.wait(1.5)   
            end
        end
        print("[CODE] done.")
    end

    local function runGuard()
        local function active() return alive() end
        local function isNight()
            local w = workspace:GetAttribute("ActiveWeather")
            return type(w)=="string" and w:lower():find("moon") ~= nil
        end
        local function gardenCenter()
            local plot = getPlot(); if not plot then return nil end
            local sum, n = Vector3.new(), 0
            for _,pp in ipairs(CS:GetTagged("PlantArea")) do
                if pp:IsA("BasePart") and pp:IsDescendantOf(plot) then sum = sum + pp.Position; n = n + 1 end
            end
            if n == 0 then local cf = plot:GetBoundingBox(); return cf.Position end
            return (sum / n) + Vector3.new(0, 6, 0)
        end
        local function pivotCenter(why)
            local c = gardenCenter(); local char = lp.Character
            if c and char and char:FindFirstChild("HumanoidRootPart") then
                pcall(function() char:PivotTo(CFrame.new(c)) end)
                if why then print("[GUARD] pivot to garden center ("..why..")") end
            end
        end

        task.spawn(function()
            local VIM; pcall(function() VIM = game:GetService("VirtualInputManager") end)
            if not VIM then return end
            local function pressAnyKey()
                pcall(function()
                    VIM:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
                    VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    VIM:SendMouseButtonEvent(100,100,0,true,  game, 0)
                    VIM:SendMouseButtonEvent(100,100,0,false, game, 0)
                end)
            end
            local t0, announced = os.clock(), false
            while active() and os.clock()-t0 < 90 do
                if lp:GetAttribute("LoadingScreenActive") == true then
                    if not announced then print("[GUARD] auto-pressing through loading screen"); announced = true end
                    pressAnyKey(); task.wait(0.25)
                elseif lp:GetAttribute("OfflineCutscenePlaying") == true then
                    pcall(function() VIM:SendMouseButtonEvent(100,100,0,true,game,0) end)
                    local h = os.clock()
                    while active() and lp:GetAttribute("OfflineCutscenePlaying")==true and os.clock()-h < 1.5 do task.wait(0.05) end
                    pcall(function() VIM:SendMouseButtonEvent(100,100,0,false,game,0) end)
                    print("[GUARD] held to skip offline-growth cutscene"); task.wait(0.5)
                else
                    task.wait(0.3)
                end
            end
        end)

        task.spawn(function()
            local function trulySpawned()
                if lp:GetAttribute("LoadingScreenActive") == true then return false end
                if lp:GetAttribute("OfflineCutscenePlaying") == true then return false end
                if lp:GetAttribute("CutsceneInputBlocked") == true then return false end
                local char = lp.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                if not (hrp and hum) then return false end
                if hum.Health <= 0 then return false end
                local st = hum:GetState()
                if st == Enum.HumanoidStateType.Dead or st == Enum.HumanoidStateType.None then return false end
                return true
            end
            local t0 = os.clock()
            while active() and not trulySpawned() and os.clock()-t0 < 120 do task.wait(0.3) end
            if not active() then return end
            task.wait(1.0)   
            pivotCenter("after spawn")
            local wasNight = nil
            while active() do
                local n = isNight()
                if n then pivotCenter(wasNight ~= true and "night start" or nil) end  
                wasNight = n
                for _=1, (n and 12 or 3) do if not active() then return end task.wait(1) end
            end
        end)
        print("[GUARD] started (safe hold-to-skip + garden-center pivot + night hold)")
    end

    local function runMisc(C)
        local function active() return alive() and Cfg.Misc ~= false end
        local Lighting = game:GetService("Lighting")
        local conns       = {}
        local removed     = {}   -- [plantsFolder] = plot (restore other gardens on stop)
        local hiddenChars = {}   -- [character] = parent (restore other players on stop)
        local myPlotName  = "Plot"..tostring(lp:GetAttribute("PlotId"))

        if C.FpsBoost ~= false then
            pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
            pcall(function() game:GetService("UserSettings"):GetService("UserGameSettings").SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end)
            pcall(function() Lighting.GlobalShadows = false end)
            pcall(function() Lighting.Technology = Enum.Technology.Compatibility end)
            for _,e in ipairs(Lighting:GetDescendants()) do
                if e:IsA("PostEffect") or e:IsA("Atmosphere") then pcall(function() e.Enabled = false end) end
            end
            local ter = workspace:FindFirstChildOfClass("Terrain")
            if ter then pcall(function() ter.WaterWaveSize=0; ter.WaterWaveSpeed=0; ter.WaterReflectance=0; ter.WaterTransparency=0.9; ter.Decoration=false end) end
            -- cheaper lighting: kill image-based lighting + clouds (Brightness left alone to avoid a dark screen)
            pcall(function() Lighting.EnvironmentDiffuseScale = 0; Lighting.EnvironmentSpecularScale = 0 end)
            if ter then local cl = ter:FindFirstChildOfClass("Clouds"); if cl then pcall(function() cl:Destroy() end) end end

            local function removePlot(plot)
                if plot.Name == myPlotName then return end
                local pf = plot:FindFirstChild("Plants")
                if pf and not removed[pf] then removed[pf] = plot; pcall(function() pf.Parent = nil end) end
            end
            local gardens = workspace:WaitForChild("Gardens", 30)
            if gardens then
                for _,plot in ipairs(gardens:GetChildren()) do if active() then removePlot(plot) end end
                conns[#conns+1] = gardens.ChildAdded:Connect(function(plot)
                    if active() and plot.Name ~= myPlotName then
                        local pf = plot:WaitForChild("Plants", 30)
                        if pf and active() then removePlot(plot) end
                    end
                end)
                conns[#conns+1] = gardens.DescendantAdded:Connect(function(d)
                    if active() and d.Name=="Plants" and d.Parent and d.Parent.Name~=myPlotName and d.Parent.Parent==gardens then
                        removed[d]=d.Parent; pcall(function() d.Parent=nil end)
                    end
                end)
            end

            local function killFx(d)
                if d:IsA("ParticleEmitter") or d:IsA("Beam") or d:IsA("Trail") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
                    pcall(function() d.Enabled = false end)
                elseif d:IsA("BasePart") then
                    pcall(function() d.LocalTransparencyModifier = 1; d.CastShadow = false end)
                end
            end
            for _,fn in ipairs({"RainDrops","RainSplashes","LightningEffects","StormRainDrops","StormSplashes"}) do
                local f = workspace:FindFirstChild(fn)
                if f then
                    for _,d in ipairs(f:GetDescendants()) do killFx(d) end
                    conns[#conns+1] = f.DescendantAdded:Connect(function(d) if active() then killFx(d) end end)
                end
            end
            for _,ln in ipairs({"RainEffect","LightningEffect","RainbowEffect","FlameEffect","StarEffect"}) do
                local e = Lighting:FindFirstChild(ln)
                if e and e:IsA("PostEffect") then
                    pcall(function() e.Enabled = false end)
                    conns[#conns+1] = e:GetPropertyChangedSignal("Enabled"):Connect(function() if active() and e.Enabled then pcall(function() e.Enabled=false end) end end)
                end
            end

            local function flatten(d)
                if d:IsA("BasePart") then
                    pcall(function() d.Material = Enum.Material.SmoothPlastic; d.Reflectance = 0; d.CastShadow = false end)
                    if d:IsA("MeshPart") then pcall(function() d.TextureID = "" end) end       -- mesh texture
                elseif d:IsA("SpecialMesh") then pcall(function() d.TextureId = "" end)          -- legacy mesh texture
                elseif d:IsA("Decal") or d:IsA("Texture") then pcall(function() d.Transparency = 1 end)
                elseif d:IsA("SurfaceAppearance") then pcall(function() d:Destroy() end)         -- PBR maps
                elseif d:IsA("Sound") or d:IsA("SoundGroup") then pcall(function() d.Volume = 0 end)   -- mute SFX/music
                elseif d:IsA("ParticleEmitter") or d:IsA("Trail") or d:IsA("Beam") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
                    pcall(function() d.Enabled = false end)                                       -- kill ALL particles/fx
                end
            end
            local function flattenSubtree(root)
                if not root then return end
                local n = 0
                for _,d in ipairs(root:GetDescendants()) do
                    if not active() then return end
                    flatten(d); n = n + 1; if n % 300 == 0 then task.wait() end
                end
            end
            -- mute sounds in SoundService (outside workspace) + new ones there
            for _,s in ipairs(game:GetService("SoundService"):GetDescendants()) do flatten(s) end
            conns[#conns+1] = game:GetService("SoundService").DescendantAdded:Connect(function(d) if active() then flatten(d) end end)
            -- keep new workspace instances low-poly/quiet (scoped to workspace, not game-wide = less overhead)
            conns[#conns+1] = workspace.DescendantAdded:Connect(function(d) if active() then flatten(d) end end)
            task.spawn(function()
                flattenSubtree(workspace)   -- whole map + your garden + decorations + every visible texture
                print("[MISC] low-poly + sound-mute applied (whole workspace)")
            end)

            -- (#2) nuke transient cosmetic VFX models (harvest/sell pops, blizzard beams); they
            -- respawn constantly with nonstop harvest, so removing them on spawn frees real FPS
            local JUNK = { PopVFXModel = true, BlizzardBeams = true, PopVFX = true }
            local function killJunk(c) if JUNK[c.Name] then pcall(function() c:Destroy() end) end end
            for _,c in ipairs(workspace:GetChildren()) do killJunk(c) end
            conns[#conns+1] = workspace.ChildAdded:Connect(function(c) if active() then killJunk(c) end end)

            -- (#4) hide OTHER players' characters: un-parent them (transparency wouldn't free FPS).
            -- Restored on stop. If it ever causes client errors, just turn Misc/FpsBoost off.
            local Plrs = game:GetService("Players")
            local function hideChar(ch) if ch and ch.Parent then hiddenChars[ch] = ch.Parent; pcall(function() ch.Parent = nil end) end end
            local function onPlr(p)
                if p == lp then return end
                if p.Character then hideChar(p.Character) end
                conns[#conns+1] = p.CharacterAdded:Connect(function(ch) if active() then task.wait(0.3); hideChar(ch) end end)
            end
            for _,p in ipairs(Plrs:GetPlayers()) do onPlr(p) end
            conns[#conns+1] = Plrs.PlayerAdded:Connect(function(p) if active() then onPlr(p) end end)

            do local n=0 for _ in pairs(removed) do n=n+1 end
               print(("[MISC] fps boost applied (quality lowest, shadows/effects off, %d other gardens removed, particles+weather off, sfx muted)"):format(n)) end
        end

        -- CHARACTER GUARD (always on): one Heartbeat that
        --   * ANCHORS your HRP while it's NIGHT/moon (freeze: exploit flings can't throw you out of
        --     the garden, and other players can't shove you) OR while a grab is running (true
        --     anti-gravity = zero fall, not just velocity-zero),
        --   * otherwise CLAMPS abnormal velocity (anti-fling) so you can't be launched.
        -- Anchoring still lets the auto-grabbers set CFrame (teleport works on anchored parts).
        do
            local RunService = game:GetService("RunService")
            local MAXV = 100
            conns[#conns+1] = RunService.Heartbeat:Connect(function()
                if not active() then return end
                local ch = lp.Character
                local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local w = workspace:GetAttribute("ActiveWeather")
                local night = type(w) == "string" and w:lower():find("moon") ~= nil
                local hold = night or (os.clock() < grabUntil)
                if hrp.Anchored ~= hold then pcall(function() hrp.Anchored = hold end) end
                if not hold then
                    if hrp.AssemblyLinearVelocity.Magnitude  > MAXV then pcall(function() hrp.AssemblyLinearVelocity  = Vector3.zero end) end
                    if hrp.AssemblyAngularVelocity.Magnitude > MAXV then pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end) end
                end
            end)
            print("[MISC] character guard armed (freeze on night + anti-gravity on grab + anti-fling)")
        end

        if C.AntiAfk then
            local okVIM, VIM = pcall(function() return game:GetService("VirtualInputManager") end)
            local function jump()
                if okVIM and VIM then
                    pcall(function() VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game); task.wait(0.06); VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game) end)
                else
                    local c = lp.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
                    if h then pcall(function() h:ChangeState(Enum.HumanoidStateType.Jumping) end) end
                end
            end
            conns[#conns+1] = lp.Idled:Connect(function() if active() then jump() end end)
            task.spawn(function() while active() do for _=1, math.max(5, 600) do if not active() then return end task.wait(1) end jump() end end)
            print(("[MISC] anti-afk armed (jump every %ds; VIM=%s)"):format(600, tostring(okVIM and VIM~=nil)))
        end

        if C.AutoReconnect then
            local TP = game:GetService("TeleportService")
            local GuiService = game:GetService("GuiService")
            local rejoining = false
            local function rejoin()
                if rejoining then return end; rejoining = true
                task.wait(0.5)
                pcall(function() TP:Teleport(game.PlaceId, lp) end)
            end
            conns[#conns+1] = GuiService.ErrorMessageChanged:Connect(function(msg)
                if msg and tostring(msg) ~= "" then task.spawn(rejoin) end
            end)
            print("[MISC] auto-reconnect armed (note: a hard network drop can kill the VM before it fires)")
        end

        if C.RedeemCodes then task.spawn(runRedeemCodes, C) end

        while active() do task.wait(2) end
        for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
        for pf,plot in pairs(removed) do pcall(function() pf.Parent = plot end) end          -- restore other gardens
        for ch,par in pairs(hiddenChars) do pcall(function() ch.Parent = par end) end        -- restore other players
        pcall(function() local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if h then h.Anchored = false end end)  -- never leave frozen
        print("[MISC] stopped (other gardens + players restored, character unfrozen)")
    end

    print("========================================================")
    print(("GAG2 ALL-IN-ONE  Plant=%s Harvest=%s Sell=%s CollectEventSeeds=%s Mail=%s Webhook=%s Misc=%s")
        :format(tostring(Cfg.Plant), tostring(Cfg.Harvest), tostring(Cfg.Sell), tostring(Cfg.CollectEventSeeds), tostring(Cfg.Mail), tostring(Cfg.Webhook), tostring(Cfg.Misc)))
