    local function runBuyGears(C)
        local function active() return alive() and Cfg.BuyGears ~= false end
        local function dbg(...) if miscDebug() then print("[BUYGEAR]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[BUYGEAR] PlayerState replica unavailable - aborting"); return end
        local function data() return replica.Data end
        local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end

        local GearShopData = require(RS.SharedModules.GearShopData)
        local GEAR = {}   
        local function scanGear(t, depth)
            if depth > 3 then return end
            for _,e in pairs(t) do
                if type(e)=="table" then
                    if e.ItemName then GEAR[e.ItemName] = { Cost = tonumber(e.Cost) or 0, Rarity = tostring(e.Rarity or "") }
                    else scanGear(e, depth+1) end
                end
            end
        end
        scanGear(GearShopData, 0)

        local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("GearShop", 20)
        if not SS then warn("[BUYGEAR] StockValues.GearShop not found - aborting"); return end
        local ITEMS = SS:WaitForChild("Items", 20)
        local function stockMax(n) local v=ITEMS:FindFirstChild(n); return (v and v:IsA("ValueBase") and v.Value) or 0 end
        local function purchased(n) local d=data(); local g=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Gears; return (g and g[n]) or 0 end
        local function remaining(n) return math.max(0, stockMax(n)-purchased(n)) end

        local rarWant = {}; for _,r in ipairs(C.Rarities or {}) do rarWant[tostring(r):lower()] = true end
        local hasRar = next(rarWant) ~= nil
        local function buildWanted()
            local want = {}
            for _,name in ipairs(C.ListGear or {}) do want[name] = true end
            if hasRar then for name,info in pairs(GEAR) do if rarWant[info.Rarity:lower()] and stockMax(name)>0 then want[name]=true end end end
            return want
        end
        -- MEASURED: PurchaseGear is NOT rate-limited (11 fired in one frame -> all 11 landed), same as
        -- PurchaseSeed. So fire the whole affordable/in-stock batch at ONCE, verify, re-fire shortfall.
        -- (Old path bought one at a time, up to 1.5s confirm + 0.15s pad EACH.) The gear shop restocks
        -- fast, so remaining() is re-read every pass.
        local function buyOne(name)
            local info = GEAR[name]
            if not info then warn(("[BUYGEAR] unknown gear '%s' (check spelling)"):format(name)); return 0 end
            local cost = info.Cost
            local start = purchased(name)
            local function canBuy()
                local n = remaining(name)
                if cost>0 then n = math.min(n, math.floor(sheckles()/cost)) end
                return math.max(0, n)
            end
            for _=1,5 do
                if not active() then break end
                local n = canBuy(); if n<=0 then break end
                local before = purchased(name)
                for _=1,n do pcall(function() Net.GearShop.PurchaseGear:Fire(name) end) end   -- whole batch in one burst
                local t0=os.clock()
                repeat task.wait(0.1) until purchased(name)>=before+n or not active() or os.clock()-t0>2
                if purchased(name)<=before then break end                                       -- nothing landed -> stop
            end
            return purchased(name)-start
        end
        print("[BUYGEAR] started")
        while active() do
            local want = buildWanted()
            for name in pairs(want) do
                if not active() then break end
                if remaining(name)>0 then local b=buyOne(name); if b>0 then print(("[BUYGEAR] bought %s x%d (Sheckles ~%d)"):format(name,b,math.floor(sheckles()))) end end
            end
            for _=1, math.max(2, 20 or 6) do if not active() then return end task.wait(1) end
        end
        print("[BUYGEAR] stopped.")
    end

    local function runBuyPets(C)
        local function active() return alive() and Cfg.BuyPets ~= false end
        local function dbg(...) if miscDebug() then print("[BUYPET]", ...) end end
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
        if not replica then warn("[BUYPET] PlayerState replica unavailable - aborting"); return end
        local function sheckles() local d=replica.Data; return (d and d.Sheckles) or 0 end

        local map = workspace:WaitForChild("Map", 30)
        local refFolder = map and map:WaitForChild("WildPetRef", 30)
        if not refFolder then warn("[BUYPET] Map.WildPetRef not found - aborting"); return end

        local function root() local c=lp.Character; return c and c:FindFirstChild("HumanoidRootPart") end
        local function tpTo(pos) local h=root(); if not h then return false end pcall(function() h.CFrame=CFrame.new(pos+Vector3.new(0,4,0)); h.AssemblyLinearVelocity=Vector3.zero; h.AssemblyAngularVelocity=Vector3.zero end); return true end  -- anti-fall

        local spWant, raWant = {}, {}
        for _,s in ipairs(C.ListPets or {}) do spWant[tostring(s):lower()] = true end
        for _,r in ipairs(C.Rarities or {}) do raWant[tostring(r):lower()] = true end
        local hasSp, hasRa = next(spWant)~=nil, next(raWant)~=nil

        pcall(function() Net.Pets.WildPetTameResult.OnClientEvent:Connect(function(part,val) if active() then dbg(("buy result: %s -> %s"):format(part and part.Name or "?", tostring(val))) end end) end)

        local RANK = { common=1, uncommon=2, rare=3, super=4, legendary=5, mythic=6, divine=7, secret=8 }
        local function rarityRank(part) return RANK[tostring(part:GetAttribute("Rarity") or ""):lower()] or 0 end

        local handled  = {}   
        local cooldown = {}   

        -- match by species/rarity + still wild (NO sheckles check here; the loop scans this every
        -- tick, so the affordability gate lives in claimWild right before the teleport).
        local function matchPet(part)
            if part:GetAttribute("OwnerUserId") ~= 0 then return false end
            local pn = tostring(part:GetAttribute("PetName") or ""):lower()
            local rr = tostring(part:GetAttribute("Rarity") or ""):lower()
            if hasSp and not spWant[pn] then return false end
            if hasRa and not raWant[rr] then return false end
            return true
        end
        -- Price attribute can read 0/nil for a frame right after a pet spawns; wait briefly so the
        -- affordability check isn't fooled into teleporting to a pet we can't actually afford.
        local function resolvePrice(part)
            local p = tonumber(part:GetAttribute("Price")) or 0
            if p > 0 then return p end
            local dl = os.clock() + 1.0
            while part.Parent and p <= 0 and os.clock() < dl do task.wait(0.05); p = tonumber(part:GetAttribute("Price")) or 0 end
            return p
        end
        local function claimWild(part)
            if not matchPet(part) then return false end
            local pn = tostring(part:GetAttribute("PetName") or "")
            local rr = tostring(part:GetAttribute("Rarity") or "")
            -- AFFORDABILITY GATE (before ANY teleport): resolve the real price + check Sheckles.
            -- If we can't afford this pet, do NOT teleport to it.
            local price = resolvePrice(part)
            if price <= 0 then cooldown[part] = os.clock() + 5; dbg(("price unknown for %s - skip"):format(pn)); return false end
            if sheckles() < price then
                cooldown[part] = os.clock() + 5
                dbg(("not enough Sheckles for %s (%s): need %d have %d - NOT teleporting"):format(pn, rr, price, sheckles()))
                return false
            end
            local home; do local h=root(); if h then home=h.Position end end
            pcall(function() Net.Pets.WildPetTame:Fire(part) end)
            task.wait(0.1)
            if part.Parent and (part:GetAttribute("OwnerUserId") or 0) == 0 then
                grabUntil = os.clock() + 0.5   -- anchor-float from the moment we teleport onto the pet
                local p = select(2, pcall(function() return part.Position end))
                if typeof(p)=="Vector3" then tpTo(p); task.wait(0.1) end
                pcall(function() Net.Pets.WildPetTame:Fire(part) end)
            end
            local t0 = os.clock()
            while active() and part.Parent and (part:GetAttribute("OwnerUserId") or 0) == 0 and os.clock()-t0 <= 3 do
                grabUntil = os.clock() + 0.5   -- anchor-float during the grab (true anti-fall)
                do local p = select(2, pcall(function() return part.Position end)); if typeof(p)=="Vector3" then tpTo(p) end end
                task.wait(0.1)
            end
            if home then tpTo(home) end
            local mine = (not part.Parent) or (part:GetAttribute("OwnerUserId") == lp.UserId)
            if mine then
                handled[part] = true
                print(("[BUYPET] claimed %s (%s) ~%d Sheckles"):format(pn,rr,price))
            else
                cooldown[part] = os.clock() + 3
                dbg(("claim not confirmed for %s (%s)"):format(pn,rr))
            end
            return mine
        end
        local dirty = false
        refFolder.ChildAdded:Connect(function() if active() then dirty = true end end)
        print("[BUYPET] started (event-driven + rarity priority)")
        while active() do
            local best, bestRank
            for _,part in ipairs(refFolder:GetChildren()) do
                if part:IsA("BasePart") and not handled[part] and not (cooldown[part] and os.clock() < cooldown[part]) then
                    if matchPet(part) then
                        local rk = rarityRank(part)
                        if not best or rk > bestRank then best, bestRank = part, rk end
                    end
                end
            end
            for p in pairs(handled)  do if not p.Parent then handled[p]  = nil end end
            for p in pairs(cooldown) do if not p.Parent then cooldown[p] = nil end end
            if best then
                claimWild(best); task.wait(0.3)
            else
                local idleFor, waited = math.max(0.5, 20 or 1), 0
                while active() and not dirty and waited < idleFor do task.wait(0.1); waited = waited + 0.1 end
                dirty = false
            end
        end
        print("[BUYPET] stopped.")
    end

    local function runExpandPlot(C)
