local HttpService = game:GetService("HttpService")
local function webhookPost(url, bodyTable, messageId, label)
  if Cfg.Webhook == false then return false end
  if type(url) ~= "string" or url == "" or url:find("PUT_YOUR") then return false end
  local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
  if not req then warn("[WEBHOOK] executor has no HTTP request function"); return false end
  local wc = Cfg.WebhookConfig or {}
  if type(bodyTable) == "table" and not bodyTable.username then
    bodyTable.username = (type(wc.Username)=="string" and wc.Username~="") and wc.Username or "GAG2"
  end
  local function fire(method, fullUrl)
    return pcall(function()
      return req({ Url = fullUrl, Method = method,
         Headers = { ["Content-Type"] = "application/json" },
         Body = HttpService:JSONEncode(bodyTable) })
    end)
  end
  local editing = type(messageId)=="string" and messageId~=""
  local method  = editing and "PATCH" or "POST"
  local fullUrl = editing and (url.."/messages/"..messageId) or (url.."?wait=true")
  local ok, res = fire(method, fullUrl)
  if not ok then return false end
  local status = res and (res.StatusCode or res.Status or res.status_code)
  if editing and status and status >= 400 then
    method, fullUrl = "POST", url.."?wait=true"
    ok, res = fire(method, fullUrl); if not ok then return false end
  end
  if method == "POST" and res and res.Body then
    local okj, data = pcall(function() return HttpService:JSONDecode(tostring(res.Body)) end)
    if okj and type(data)=="table" and data.id then
      print(("[WEBHOOK] %s message id = %s  (paste into WebhookConfig.%sMessageID to edit this message in place)")
        :format(tostring(label or "?"), tostring(data.id), tostring(label or "")))
    end
  end
  return true
end

local function runPlantBuy(C)
  local function active()  return alive() and (Cfg.Plant ~= false or Cfg.BuySeed ~= false) end  -- loop runs while EITHER is on
  local function plantOn() return Cfg.Plant   ~= false end
  local function buyOn()   return Cfg.BuySeed ~= false end
  local function dbg(...) if miscDebug() then print("[PB]", ...) end end

  local P_Buy = Packet("PurchaseSeed")
  local SeedData = require(RS.SharedModules.SeedData)
  local PRICE = {}
  for _, e in pairs(SeedData) do if type(e)=="table" and e.SeedName then PRICE[e.SeedName] = tonumber(e.PurchasePrice) or 0 end end

  local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("SeedShop", 20)
  if not SS then warn("[PB] StockValues.SeedShop not found - plant+buy aborting"); return end
  local ITEMS = SS:WaitForChild("Items", 20)

  local replica = PSC:WaitForLocalReplica(PSC, 30)
  if not replica then warn("[PB] PlayerState replica unavailable - plant+buy aborting"); return end
  local function data() return replica.Data end
  local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end
  local function invCount(n) local d=data(); local s=d and d.Inventory and d.Inventory.Seeds; return (s and s[n]) or 0 end
  local function purchasedCount(n) local d=data(); local p=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Seeds; return (p and p[n]) or 0 end
  local function stockRemaining(n) local v=ITEMS:FindFirstChild(n); local mx=(v and v:IsA("ValueBase") and v.Value) or 0; return math.max(0, mx - purchasedCount(n)) end

  -- spatial hash: O(1) spacing checks (vs scanning EVERY plant per candidate cell)
  local function makeHash(cell) return { cell = cell, b = {} } end
  local function hAdd(h, x, z)
    local k = math.floor(x/h.cell)..","..math.floor(z/h.cell)
    local t = h.b[k]; if not t then t = {}; h.b[k] = t end
    t[#t+1] = Vector2.new(x, z)
  end
  local function hFar(h, x, z, minSp)
    local cx, cz = math.floor(x/h.cell), math.floor(z/h.cell)
    local v = Vector2.new(x, z)
    for dx = -1, 1 do for dz = -1, 1 do
      local t = h.b[(cx+dx)..","..(cz+dz)]
      if t then for _, o in ipairs(t) do if (o - v).Magnitude < minSp then return false end end end
    end end
    return true
  end

  -- Cache the planted-count map (ONE pass over all plants) and reuse it for the whole cycle.
  -- Before, plantedCount rescanned EVERY plant ~4x per target x ~23 targets each cycle = a big
  -- synchronous CPU spike. Invalidated at cycle start + right after we actually plant.
  local plantedCache = nil
  local function refreshPlanted()
    plantedCache = countPlantedBySeed(getPlot())
  end
  local function plantedCount(name) if not plantedCache then refreshPlanted() end return plantedCache[name] or 0 end
  local function findSeedTool(name)
    local bp=lp:FindFirstChildOfClass("Backpack")
    if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
    if lp.Character then for _,t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
  end

  -- BUY config is now SEPARATE (Cfg.BuySeedConfig) but still LINKED to plant: buy quantities come
  -- from BuySeedConfig.Targets, falling back to PlantConfig.Targets when that's empty (option A).
  local BC = Cfg.BuySeedConfig or {}
  local KEEPBUY = {}
  for _, s in ipairs(BC.KeepBuyingAfterTarget or {}) do KEEPBUY[tostring(s)] = true end
  local buyTargets = (next(BC.Targets or {}) ~= nil) and BC.Targets or C.Targets   -- empty => mirror plant targets
  local function wantPlant(n, t) return plantedCount(n) < t end
  local function wantBuy(n, t)
    if KEEPBUY[n] then return true end
    return (plantedCount(n) + invCount(n)) < (t or 0)
  end

  -- MEASURED: PurchaseSeed is NOT rate-limited (10 fired in one frame -> all 10 landed). So fire
  -- the whole affordable/in-stock batch at ONCE, then verify and re-fire any shortfall. Far
  -- faster than the old one-at-a-time confirm (which waited up to 1.5s PER seed).
  local function buySeed(name, cap)
    local price = PRICE[name] or 0
    local start = purchasedCount(name)
    local function canBuy()
      local n = stockRemaining(name)
      if cap and cap>0 then n = math.min(n, cap-(purchasedCount(name)-start)) end
      if price>0 then n = math.min(n, math.floor(sheckles()/price)) end
      return math.max(0, n)
    end
    for _=1,5 do
      if not active() then break end
      local n = canBuy(); if n<=0 then break end
      local before = purchasedCount(name)
      for _=1,n do pcall(function() P_Buy:Fire(name) end) end          -- whole batch in one burst
      local t0=os.clock()
      repeat task.wait(0.1) until purchasedCount(name)>=before+n or not active() or os.clock()-t0>2
      if purchasedCount(name)<=before then break end                    -- nothing landed -> stop
    end
    return purchasedCount(name)-start
  end

  -- PlantMode spacing: "compact" packs at ~0.6 stud (near the ~0.5 server min = far more
  -- plants/plot), "spread" keeps the wide ~1.2 random scatter. Constant per run -> hoisted.
  local SP = (tostring(C.PlantMode or "spread"):lower() == "compact") and 0.6 or 1.2
  -- P1: build the PlantArea list + spatial hash ONCE per cycle and SHARE across every seed.
  -- (Before, each plantTopUp rebuilt the hash from scratch = one GetPivot full-walk over ALL
  -- plants PER seed = the planting-burst CPU spike on big gardens.) Each plantTopUp's ChildAdded
  -- appends newly-landed plants so the shared hash stays current within the cycle. The GetPivot
  -- walk yields every 100 so even a 1000+ plant garden never spikes a frame.
  local plantCtx = nil
  local function buildPlantCtx()
    local plot=getPlot(); local plants=plot and plot:FindFirstChild("Plants"); if not plants then return nil end
    local areas={}
    for _,p in ipairs(CS:GetTagged("PlantArea")) do if p:IsDescendantOf(plot) and p:IsA("BasePart") then areas[#areas+1]=p end end
    if #areas==0 then return nil end
    for i=#areas,2,-1 do local j=math.random(i); areas[i],areas[j]=areas[j],areas[i] end   -- de-bias area order (no first/corner bias)
    local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Include; rp.FilterDescendantsInstances=areas
    local hash=makeHash(SP); local cnt=0
    for _,pl in ipairs(plants:GetChildren()) do
      cnt=cnt+1; if cnt%100==0 then task.wait() end   -- yield: never spike the frame on huge gardens
      local ok,cf=pcall(function() return pl:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end
    end
    local totalW=0; for _,part in ipairs(areas) do totalW=totalW+math.max(1, part.Size.X*part.Size.Z) end
    plantCtx={plants=plants, areas=areas, rp=rp, hash=hash, totalW=totalW}
    dbg(("plant ctx built (%d plants, %d areas)"):format(cnt, #areas))
    return plantCtx
  end

  local function plantTopUp(name, target)
    local plot=getPlot(); if not plot then return 0 end
    local need = target - plantedCount(name)
    if need<=0 then return 0 end
    need = math.min(need, invCount(name))
    if need<=0 then return 0 end
    local tool=findSeedTool(name); if not tool then dbg("no seed tool for", name); return 0 end
    local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid"); if hum then pcall(function() hum:EquipTool(tool) end) end
    -- P2: local equip is ~instant (measured ~0.5ms); the old flat 0.2s was almost all server-settle
    -- margin. Confirm the tool is actually held, then a short server-settle (~0.1s). If the server
    -- still missed a fire, the 3-pass refill loop below tops it up, so a tight wait self-corrects
    -- rather than silently under-planting. (Net ~0.1s vs 0.2s per seed.)
    local te=os.clock(); repeat task.wait() until (not lp.Character) or (tool.Parent==lp.Character) or (os.clock()-te>0.15)
    task.wait(0.1)
    local ctx = plantCtx or buildPlantCtx(); if not ctx then dbg("no plant ctx (no plot/areas) for", name); return 0 end   -- P1: shared per-cycle context
    local plants, areas, rp, hash, totalW = ctx.plants, ctx.areas, ctx.rp, ctx.hash, ctx.totalW
    local function farEnough(x,z) return hFar(hash, x, z, SP) end
    local added=0
    local conn=plants.ChildAdded:Connect(function(m)
      task.defer(function()
        for _=1,20 do if m:GetAttribute("SeedName") then break end task.wait(0.05) end
        if m:GetAttribute("SeedName")==name then added=added+1
          local ok,cf=pcall(function() return m:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end
        end
      end)
    end)
    -- RANDOM sampling across all plant areas (weighted by surface size) instead of a regular
    -- grid. A grid lays candidates in straight rows so a small batch ends up on one line/edge
    -- of the plot ("garis"). Uniform random points (each kept >=1.2 apart via the hash)
    -- scatter the batch across the whole garden. (totalW comes from the shared per-cycle ctx.)
    local function pickArea()
      local r = math.random() * totalW
      for _,part in ipairs(areas) do r = r - math.max(1, part.Size.X * part.Size.Z); if r <= 0 then return part end end
      return areas[#areas]
    end
    local want = math.min(need * 2 + 8, 1200)   -- spaced buffer (smaller = fewer raycasts = less CPU)
    local spots = {}
    local attempts, maxAttempts = 0, want * 20
    while #spots < want and attempts < maxAttempts do
      attempts = attempts + 1
      if attempts % 80 == 0 then task.wait() end   -- yield often so the raycast sampling never spikes a frame
      local part = pickArea()
      local hx = math.max(0.1, part.Size.X/2 - 0.6)
      local hz = math.max(0.1, part.Size.Z/2 - 0.6)
      local lx = (math.random()*2 - 1) * hx
      local lz = (math.random()*2 - 1) * hz
      local wp = (part.CFrame * CFrame.new(lx, part.Size.Y/2 + 0.2, lz)).Position
      if farEnough(wp.X, wp.Z) then
        local hit = workspace:Raycast(wp + Vector3.new(0,5,0), Vector3.new(0,-20,0), rp)
        if hit then spots[#spots+1] = hit.Position; hAdd(hash, hit.Position.X, hit.Position.Z) end
      end
    end
    if #spots == 0 then dbg(("no free spot for %s (garden full at spacing %.2f, mode=%s)"):format(name, SP, tostring(C.PlantMode or "spread"))) end
    -- MEASURED: PlantSeed IS rate-limited ~1/tick (8 fired in one frame -> 1 landed; ~0.05s
    -- pace -> ~full). So pace at 0.05s like harvest instead of confirm-per-plant + a 0.25s pad
    -- (old path was ~3/s; this is ~20/s). `added` (ChildAdded) counts the real plants; the
    -- multi-pass loop refills the few drops from the spare spots so we still reach `need`
    -- without waiting for the next whole cycle. Fires are capped at the shortfall = no overplant.
    local PLANT_DELAY = 0.05
    local si = 1
    for _=1,3 do
      if not active() then break end
      local short = need - added; if short<=0 then break end
      local fired = 0
      while si<=#spots and fired<short and active() do
        pcall(function() Packet("PlantSeed"):Fire(spots[si], name, tool) end)
        si=si+1; fired=fired+1; task.wait(PLANT_DELAY)
      end
      if fired==0 then break end                                  -- out of spots
      local t0=os.clock(); repeat task.wait(0.05) until added>=need or os.clock()-t0>1   -- let ChildAdded catch up
    end
    conn:Disconnect()
    return added
  end

  -- AUTO-SHOVEL over-target: if planted COUNT exceeds the target (e.g. Strawberry 30/10), dig up the
  -- excess until it's back to target (-> 10/10). DESTRUCTIVE + permanent; gated by ShovelOverTarget.
  -- Contract (verified from ShovelController): Net.Shovel.UseShovel:Fire(plantModelName, "", shovelAttr, shovelTool)
  -- with a Shovel tool equipped. Only trims seeds that ARE in Targets (never touches untargeted plants).
  local SHOVEL_OVER = C.ShovelOverTarget == true
  local function findShovel()
    local bp=lp:FindFirstChildOfClass("Backpack")
    if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("Shovel")~=nil then return t end end end
    if lp.Character then for _,t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("Shovel")~=nil then return t end end end
  end
  local function shovelExcess(name, target)
    local plot=getPlot(); local plants=plot and plot:FindFirstChild("Plants"); if not plants then return 0 end
    local mine={}
    for _,pl in ipairs(plants:GetChildren()) do if pl:GetAttribute("SeedName")==name then mine[#mine+1]=pl end end
    local excess = #mine - target; if excess<=0 then return 0 end
    local tool=findShovel(); if not tool then dbg("no Shovel tool - cannot trim over-target", name); return 0 end
    local shovelAttr = tool:GetAttribute("Shovel")
    local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid"); if hum then pcall(function() hum:EquipTool(tool) end) end
    task.wait(0.15)
    local removed=0
    for i=1, excess do
      if not active() then break end
      local pl=mine[i]
      if pl and pl.Parent then
        pcall(function() Net.Shovel.UseShovel:Fire(pl.Name, "", shovelAttr, tool) end)
        removed=removed+1; task.wait(0.1)   -- server rate-limits shovel ~0.1s (matches in-game auto-shovel)
      end
    end
    plantedCache=nil
    return removed
  end

  do local n={} for k,v in pairs(C.Targets) do n[#n+1]=k.."="..tostring(v) end
  print(("[PB] started  plant=%s buy=%s; plantTargets: %s  keepBuying: %s  %s"):format(
    tostring(plantOn()), tostring(buyOn()),
    (table.concat(n,", ")=="" and "(none)" or table.concat(n,", ")),
    ((BC.KeepBuyingAfterTarget and #BC.KeepBuyingAfterTarget>0) and table.concat(BC.KeepBuyingAfterTarget,", ") or "(none)"),
    (buyTargets~=C.Targets and "(buy uses BuySeedConfig.Targets)" or "(buy mirrors plant targets)"))) end

  local pbPaused=false
  while active() do
    if eventPauseActive() then
      if not pbPaused then print("[PB] paused (seed event - claiming)"); pbPaused=true end
      task.wait(0.5)
    else
    if pbPaused then print("[PB] resumed (event over)"); pbPaused=false end
    plantedCache = nil   -- rebuild the planted-count map ONCE per cycle, not per check
    plantCtx = nil       -- P1: rebuild the shared spatial-hash/areas ONCE per cycle (lazy: only if a seed actually plants)
    -- every seed we might buy and/or plant this cycle (plant targets + buy targets + keep-buying)
    local names = {}
    for n in pairs(C.Targets) do names[n]=true end
    for n in pairs(buyTargets) do names[n]=true end
    for n in pairs(KEEPBUY)   do names[n]=true end
    for name in pairs(names) do
      if not active() then break end
      local pt = C.Targets[name]            -- plant target (nil = not a plant seed)
      local bt = buyTargets[name] or pt     -- buy target (mirror plant when unset)
      if buyOn() and wantBuy(name, bt) then local b=buySeed(name, 0); if b>0 then dbg(("bought %s x%d (inv %d)"):format(name,b,invCount(name))) end end
      if plantOn() and pt then
        if wantPlant(name, pt) then local p=plantTopUp(name, pt); if p>0 then plantedCache=nil; print(("[PB] planted %s x%d (now %d/%d)"):format(name,p,plantedCount(name),pt)) end
        elseif SHOVEL_OVER and plantedCount(name) > pt then
          local rem=shovelExcess(name, pt); if rem>0 then plantedCache=nil; print(("[PB] shoveled %s x%d over-target (now %d/%d)"):format(name, rem, plantedCount(name), pt)) end
        else dbg(("%s target met (%d/%d) - plant stopped%s"):format(name, plantedCount(name), pt, KEEPBUY[name] and ", still buying" or ", buy stopped")) end
      end
      task.wait()   -- yield between targets so the cycle's work is SPREAD across frames, not one CPU spike
    end
    for _=1, math.max(3, 5) do if not active() then return end task.wait(1) end   -- cycle every 5s
    end   -- eventPauseActive else
  end
  print("[PB] stopped.")
end

local function runHarvest(C)
  local active = activeFor("Harvest")
  local function dbg(...) if miscDebug() then print("[HARV]", ...) end end

  local P_Collect = Packet("CollectFruit")
  local MUTONLY={} for _,s in ipairs(C.MutationOnly or {}) do MUTONLY[tostring(s):lower()]=true end
  local MUT_SET={} for _,m in ipairs(C.Mutations or {}) do MUT_SET[tostring(m):lower()]=true end
  local function mutationOf(inst)
    local m=inst:GetAttribute("Mutation")
    if m==nil or m=="" or m=="None" then return nil end
    if next(MUT_SET)~=nil and not MUT_SET[tostring(m):lower()] then return nil end
    return tostring(m)
  end

  local last_fire={}; local FIRE_CD=2.0
  -- H2: per-plant skip window. A plant with nothing harvestable RIGHT NOW is skipped for SKIP_FAR
  -- (near-ripe: SKIP_NEAR) so the steady-state sweep stops re-walking every unripe plant's fruit
  -- each pass. Growth is minutes-scale (measured 0.007-0.25 age/sec) so this adds negligible
  -- harvest latency. nextCheck is force-cleared every 30s as insurance vs growth-rate changes and
  -- to bound the table (removed plants' keys get dropped on the clear). Keyed by tick().
  local nextCheck={}; local SKIP_FAR=2.0; local SKIP_NEAR=0.5; local lastFullScan=0
  -- MEASURED on the live server: CollectFruit is rate-limited to ~18-20 accepted/sec. Firing
  -- faster just gets the extras DROPPED (80 in one frame -> 1 landed; ~24/s -> only ~76% landed)
  -- which is exactly why bursting / no-wait was SLOWER. 0.05s (=20/s) sits right at that ceiling:
  -- ~full landing and ~1.6x faster than the old 0.08 (12.5/s). This is a SERVER wall - higher FPS
  -- does not help past it. (FireDelay overridable; set 0 for one-per-frame.)
  local FIRE_DELAY = (C.FireDelay ~= nil) and tonumber(C.FireDelay) or 0.05
  local function pace() if FIRE_DELAY>0 then task.wait(FIRE_DELAY) else task.wait() end end

  -- VALUE PRIORITY: harvest the highest-value fruit FIRST. value ~= seed base value (if known)
  -- x fruit SizeMulti x mutation multiplier. Mutations (Rainbow/Gold) dwarf everything else, so
  -- even without exact per-seed sell-values this still surfaces the genuinely valuable fruit.
  -- SellValueData = the real per-seed base sell value (verified live: seedName -> number, e.g.
  -- Pomegranate 900, Bamboo 800, Cherry 350, Tomato 9). Exact cross-seed ordering.
  local SEED_VALUE = {}
  pcall(function()
    local SVD = require(RS.SharedModules.SellValueData)
    if type(SVD)=="table" then for name,val in pairs(SVD) do local n=tonumber(val); if n then SEED_VALUE[tostring(name)] = n end end end
  end)
  local function mutMult(inst)
    local m=tostring(inst:GetAttribute("Mutation") or ""):lower()
    if m=="" or m=="none" then return 1 end
    if m:find("rainbow") then return 50 elseif m:find("gold") then return 20 else return 5 end
  end
  local function valueOf(inst, seedRaw)
    local base=SEED_VALUE[seedRaw]; if not base or base<=0 then base=1 end
    return base * (tonumber(inst:GetAttribute("SizeMulti")) or 1) * mutMult(inst)
  end

  local function sweep()
    local plot=getPlot(); if not plot then return 0 end
    local plants=plot:FindFirstChild("Plants"); if not plants then return 0 end
    local now=tick()
    if now-lastFullScan>30 then nextCheck={}; lastFullScan=now end   -- H2: periodic force full-rescan (insurance + bound table)
    -- PASS 1: gather every collectable fruit/plant with its value (yield while scanning so the
    -- gather never spikes a frame), then sort by value so the richest get collected first.
    local ripe, scanned = {}, 0
    for _,plant in ipairs(plants:GetChildren()) do
      if not active() then break end
      if nextCheck[plant] and now < nextCheck[plant] then
        -- H2: still in skip window (nothing harvestable when last seen) -> O(1), no fruit walk
      else
      scanned=scanned+1; if scanned % 50 == 0 then task.wait() end
      local seedRaw=tostring(plant:GetAttribute("SeedName") or "")
      local mutOnly=MUTONLY[seedRaw:lower()]==true
      local fruits=plant:FindFirstChild("Fruits") or plant:FindFirstChild("F")
      local got=false; local nearRipe=false   -- H2: got=harvestable now; nearRipe=within 3% of MaxAge
      if fruits then
        for _,fruit in ipairs(fruits:GetChildren()) do
          local fruitId=fruit:GetAttribute("FruitId")
          if fruitId~=nil and ((not mutOnly) or mutationOf(fruit)~=nil) then
            local plantId=fruit:GetAttribute("PlantId")
            local age,maxAge=fruit:GetAttribute("Age"),fruit:GetAttribute("MaxAge")
            local ripeOk=(type(age)=="number" and type(maxAge)=="number" and age>=maxAge)   -- always ripe-only
            local cdOk=(not last_fire[fruitId]) or (now-last_fire[fruitId]>=FIRE_CD)
            if plantId and ripeOk and cdOk then ripe[#ripe+1]={pid=plantId, fid=fruitId, key=fruitId, v=valueOf(fruit, seedRaw)}; got=true
            elseif type(age)=="number" and type(maxAge)=="number" and maxAge>0 and (maxAge-age)/maxAge<0.03 then nearRipe=true end
          end
        end
      else
        if (not mutOnly) or mutationOf(plant)~=nil then
          local plantId=plant:GetAttribute("PlantId")
          local a,m=plant:GetAttribute("Age"),plant:GetAttribute("MaxAge")
          local ready=plant:GetAttribute("PlantGrowthReady")==true
          if not ready then ready=type(a)=="number" and type(m)=="number" and a>=m end
          local cdOk=(not last_fire[plantId]) or (now-last_fire[plantId]>=FIRE_CD)
          if plantId and ready and cdOk then ripe[#ripe+1]={pid=plantId, fid="", key=plantId, v=valueOf(plant, seedRaw)}; got=true
          elseif type(a)=="number" and type(m)=="number" and m>0 and (m-a)/m<0.03 then nearRipe=true end
        end
      end
      if not got then nextCheck[plant]=now+(nearRipe and SKIP_NEAR or SKIP_FAR) else nextCheck[plant]=nil end   -- H2
      end
    end
    table.sort(ripe, function(a,b) return a.v > b.v end)   -- HIGHEST value first
    -- PASS 2: collect, richest first, at the server-safe pace
    local fired=0
    for _,e in ipairs(ripe) do
      if fired>=400 or not active() then break end
      pcall(function() P_Collect:Fire(e.pid, e.fid) end)
      last_fire[e.key]=tick(); fired=fired+1; pace()
    end
    now=tick()
    if next(last_fire) then for id,t in pairs(last_fire) do if now-t>FIRE_CD*4 then last_fire[id]=nil end end end
    return fired
  end

  print("[HARV] harvest started; mutation-only seeds: "..(#(C.MutationOnly or {})>0 and table.concat(C.MutationOnly,", ") or "(none)"))
  local pausedLog=false
  while active() do
    if eventPauseActive() then
      if not pausedLog then print("[HARV] paused (seed event - claiming)"); pausedLog=true end
      task.wait(0.4)
    else
    if pausedLog then print("[HARV] resumed (event over)"); pausedLog=false end
    local ok,fired = pcall(sweep)
    if not ok then
      warn("[HARV] sweep error (recovered): "..tostring(fired))
    elseif fired and fired>0 then
      print(("[HARV] sweep harvested %d"):format(fired))
    end
    -- NONSTOP-ish: re-sweep fast when fruit was harvested, but with a small floor so the
    -- garden isn't fully scanned EVERY frame (that was a real CPU spike); longer breather
    -- when nothing was ripe. H3: idle 0.5->0.2s is now cheap because H2 makes an idle sweep
    -- ~0.12ms (95% of plants skipped), so ripe fruit is picked up sooner without a CPU cost.
    if fired and fired>0 then task.wait(0.1) else task.wait(0.2) end
    end   -- eventPauseActive else
  end
  print("[HARV] stopped.")
end

local function runSell(C)
  local active = activeFor("Sell")
  local function dbg(...) if miscDebug() then print("[SELL]", ...) end end
  local P_Sell = Packet("SellAll")
  local function fruitCount() return tonumber(lp:GetAttribute("FruitCount")) or 0 end
  local function maxCap()     return tonumber(lp:GetAttribute("MaxFruitCapacity")) or 100 end
  local mode = tostring(C.Mode or "full"):lower()
  local fullMode = (mode ~= "always")
  local function threshold()
    if C.SellAtPercent and C.SellAtPercent > 0 then
      return math.max(1, math.floor(maxCap() * math.clamp(C.SellAtPercent, 0, 1) + 0.5))
    end
    return tonumber(C.SellAtFruitCount) or 90
  end
  print(("[SELL] started; mode=%s%s + sell-all every 60s  (capacity %d)")
    :format(fullMode and "sell-when-full" or "sell-always",
        fullMode and (" threshold="..threshold()) or "", maxCap()))
  -- EVENT-DRIVEN: sell the INSTANT FruitCount crosses the threshold (no polling wait, no
  -- post-sell delay). The 0.5s guard only dedups the burst while a sell is in flight
  -- (FruitCount takes a server round-trip to drop) - the first sell is immediate.
  local lastSell = 0
  local function trySell()
    if not active() then return end
    if eventPauseActive() then return end   -- pause selling during a seed event
    local fc = fruitCount()
    local hit = fullMode and (fc >= threshold()) or ((not fullMode) and fc > 0)
    if hit and (os.clock() - lastSell) >= 0.5 then
      lastSell = os.clock()
      pcall(function() P_Sell:Fire() end)
      dbg(("sold (fruit was %d/%d, threshold %d)"):format(fc, maxCap(), threshold()))
    end
  end
  local conn
  pcall(function() conn = lp:GetAttributeChangedSignal("FruitCount"):Connect(trySell) end)
  trySell()   -- in case the backpack is already full at start
  -- 1-MINUTE CAP: force a sell-all every 60s regardless of threshold, so fruit never sits >1 min.
  -- The event-driven trySell above still sells EARLY the instant the threshold is hit (anti-overflow).
  local SELL_INTERVAL = 60
  while active() do
    for _=1, SELL_INTERVAL do if not active() then break end task.wait(1) end
    if active() and not eventPauseActive() then   -- skip forced sell during a seed event
      local fc = fruitCount()
      if fc > 0 then
        lastSell = os.clock()
        pcall(function() P_Sell:Fire() end)
        dbg(("forced sell-all (1-min cap, fruit was %d/%d)"):format(fc, maxCap()))
      end
    end
  end
  if conn then pcall(function() conn:Disconnect() end) end
  print("[SELL] stopped.")
end

local function runSeedGrab(C)
  local active = activeFor("CollectEventSeeds")
  local function enabled() return Cfg.CollectEventSeeds ~= false end   -- outer loop stays alive across respawns (idles while dead)
  local function dbg(...) if miscDebug() then print("[SEEDGRAB]", ...) end end
  -- WEBHOOK: ping Discord when OUR Gold/Rainbow seed count rises (= WE actually claimed one; this
  -- avoids the "us OR another player" ambiguity of the seed despawning). Watches the inventory replica
  -- across any seed-category, coalesces an event burst into ONE message every ~12s (rate-limit safe).
  task.spawn(function()
    if (Cfg.WebhookConfig or {}).Seed == false then return end
    local rep = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
    if not rep then return end
    local function gr()   -- current totals of gold / rainbow seeds across seed categories
      local g, r = 0, 0
      local inv = rep.Data and rep.Data.Inventory
