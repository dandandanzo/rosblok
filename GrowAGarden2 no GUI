-- TUTORIAL AUTO-SKIP: runs immediately (doesn't need the garden). New accounts are server-gated during
-- the tutorial ("You can't gift items during the tutorial!"). The tutorial is client-driven; firing
-- Net.Tutorial.Complete ends it server-side (verified live: gift unblocked + a real MailboxSendBatch
-- went through). Sets tutorialDone -> unblocks runMail. No-op for returning players (SecondTimePlayer).
local function runTutorialSkip()   -- HARDCODED ALWAYS-ON (no config toggle)
  local function inTut() return workspace:GetAttribute("InTutorial") == true end
  local function isNew() return lp:GetAttribute("SecondTimePlayer") ~= true end
  local t0 = os.clock()
  while alive() and lp:GetAttribute("LoadingScreenDone") ~= true and os.clock()-t0 < 60 do task.wait(0.5) end
  -- returning player + no tutorial showing -> nothing to do, let mail go immediately
  if not isNew() and not inTut() then tutorialDone = true; print("[TUT] returning player - no skip needed"); return end
  print("[TUT] new account / tutorial -> auto-skipping (watch up to 60s)")
  -- WATCH: fire Ready->Complete whenever InTutorial shows (re-fire if it reappears), clearing the
  -- client flag too. Exit once InTutorial has stayed clear for ~4s after we fired (tutorial really
  -- gone), or after a 60s safety window. Robust to the tutorial starting late.
  local clearAt = nil
  local hard = os.clock() + 60
  while alive() and os.clock() < hard do
    if inTut() then
      clearAt = nil
      pcall(function() Net.Tutorial.Ready:Fire() end); task.wait(0.3)
      pcall(function() Net.Tutorial.Complete:Fire() end)
      pcall(function() workspace:SetAttribute("InTutorial", nil) end)
      task.wait(0.8)
    else
      if not clearAt then   -- first time we see it clear: fire Complete once (covers variants that never set InTutorial), start the 4s timer
        clearAt = os.clock()
        pcall(function() Net.Tutorial.Ready:Fire() end); task.wait(0.3)
        pcall(function() Net.Tutorial.Complete:Fire() end)
      end
      if os.clock() - clearAt >= 4 then break end
      task.wait(0.5)
    end
  end
  tutorialDone = true
  print("[TUT] tutorial skip done - gifting/mail unlocked")
end
task.spawn(function() local ok,err=pcall(runTutorialSkip); if not ok then warn("[ALL] tutorial-skip crashed: "..tostring(err)); tutorialDone = true end end)

-- ===== AUTO-WATER-REVIVE ================================================================
-- Plant yang ditinggal offline lama bisa "decaying" (muncul icon watering can di atasnya) dan akhirnya
-- mati. Logika decay disalin PERSIS dari game (WaterRevivePromptController.IsPlantDecaying):
-- PrimeStartedAt>0, TANPA mutation, seed punya PrimeTime (bukan AlwaysPrime), dan
-- PlantLifecycleHandler:GetDecayAlpha > 0.5. Scan periodik -> equip watering can -> fire UseWateringCan
-- di tiap plant decaying buat reset decay. Idle murah: 0 decaying = cuma scan lalu tidur (gak equip).
local function runWaterRevive(C)
  local function active() return alive() and C.WaterRevive ~= false end
  local interval = 60   -- hardcoded scan interval (detik)
  local wantCan  = C.WaterCan
  local okPLH, PLH = pcall(require, lp.PlayerScripts.Controllers.PlantLifecycleHandler)
  if not okPLH or type(PLH) ~= "table" then warn("[WATER] PlantLifecycleHandler unavailable - water-revive off"); return end
  local SeedData = require(RS.SharedModules.SeedData)
  local seedByName = {}
  for _,s in pairs(SeedData) do if type(s) == "table" and s.SeedName then seedByName[s.SeedName] = s end end
  local uidStr = tostring(lp.UserId)

  -- find a watering can Tool in character/backpack (prefer the configured name; else any can)
  local function findCan()
    local fallback
    for _,where in ipairs({ lp.Character, lp:FindFirstChild("Backpack") }) do
      if where then for _,t in ipairs(where:GetChildren()) do
        if t:IsA("Tool") then
          local cn = t:GetAttribute("WateringCan")
          if cn then
            if (not wantCan) or wantCan == "" or cn == wantCan or t.Name == wantCan then return t, cn end
            if not fallback then fallback = { t, cn } end
          end
        end
      end end
    end
    if fallback then return fallback[1], fallback[2] end
    return nil
  end

  local function equip(tool)
    local char = lp.Character; local hum = char and char:FindFirstChildOfClass("Humanoid")
    if char and hum and tool.Parent ~= char then pcall(function() hum:EquipTool(tool) end) end
  end

  -- mirror of game IsPlantDecaying (decay alpha > 0.5; mutated/no-PrimeTime plants never decay)
  local function isDecaying(entry, key)
    if not (entry.PrimeStartedAt and entry.PrimeStartedAt > 0) then return false end
    if entry.Mutation then return false end
    local sd = seedByName[entry.SeedName]
    if not (sd and sd.PrimeTime) then return false end
    if sd.AlwaysPrime then return false end
    local uid, pid = tostring(key):match("^(%d+)_(.+)$")
    if not (uid and pid) then return false end
    local ok, alpha = pcall(function() return PLH:GetDecayAlpha(tonumber(uid), pid) end)
    return ok and type(alpha) == "number" and alpha > 0.5
  end

  local function scanDecaying()
    local out = {}
    pcall(function()
      for key, entry in pairs(PLH:GetActiveEntries()) do
        if type(entry) == "table" and tostring(key):match("^(%d+)_") == uidStr
           and entry.Model and entry.Model.Parent and isDecaying(entry, key) then
          local pp = entry.Model.PrimaryPart
          if pp then out[#out+1] = pp.Position end
        end
      end
    end)
    return out
  end

  print(("[WATER] auto-water-revive armed (every %ds, can=%s)"):format(interval, tostring((wantCan and wantCan ~= "") and wantCan or "any")))
  while active() do
    local decaying = scanDecaying()
    if #decaying > 0 then
      local tool, canName = findCan()
      if tool and canName then
        equip(tool); task.wait(0.15)
        for _,pos in ipairs(decaying) do
          if not active() then break end
          pcall(function() Net.WateringCan.UseWateringCan:Fire(pos - Vector3.new(0, 0.3, 0), canName, tool) end)
          task.wait(0.1)
        end
        print(("[WATER] watered %d decaying plant(s) with '%s'"):format(#decaying, tostring(canName)))
      else
        warn(("[WATER] %d plant(s) decaying but NO watering can in backpack/character"):format(#decaying))
      end
    end
    local waited = 0
    while active() and waited < interval do task.wait(1); waited = waited + 1 end
  end
  print("[WATER] stopped.")
end

