-- Movement helper shared by BuyPets + CollectEventSeeds.
--   mode "teleport" (default) = instant CFrame set (original behaviour).
--   mode "tween"              = smooth glide to the target; character collision is auto-disabled
--                               for the glide (phases through obstacles) and restored after.
-- Refreshes grabUntil so the night anti-steal re-pin / anti-fall doesn't fight the move.
local function moveTo(targetPos, yoff, mode, speed, maxTime)
  local char = lp.Character
  local hrp  = char and char:FindFirstChild("HumanoidRootPart")
  if not (hrp and typeof(targetPos) == "Vector3") then return false end
  local goal = targetPos + Vector3.new(0, yoff or 0, 0)
  if tostring(mode):lower() ~= "tween" then
    pcall(function() hrp.CFrame = CFrame.new(goal); hrp.AssemblyLinearVelocity = Vector3.zero; hrp.AssemblyAngularVelocity = Vector3.zero end)
    return true
  end
  -- tween: disable character collision while gliding (record originals, restore after)
  local saved = {}
  for _,p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") and p.CanCollide then saved[#saved+1]=p; pcall(function() p.CanCollide=false end) end end
  local sp, last, t0 = math.max(16, tonumber(speed) or 120), os.clock(), os.clock()
  local cap = tonumber(maxTime) or 8   -- cap glide time (BuyPets: don't chase a wandering pet forever; fire ~1/s)
  local arrived = false
  while os.clock()-t0 < cap do
    local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not h then break end
    local cur = h.Position; local d = goal - cur; local dist = d.Magnitude
    if dist <= 1.5 then arrived = true; break end
    local now = os.clock(); local dt = now - last; last = now
    grabUntil = os.clock() + 0.4   -- stop the night re-pin yanking us mid-glide (also anti-fall)
    pcall(function() h.CFrame = CFrame.new(cur + d.Unit * math.min(dist, sp * math.clamp(dt, 1/240, 0.1))); h.AssemblyLinearVelocity = Vector3.zero end)
    task.wait()
  end
  if arrived then   -- only snap exactly onto target if we actually reached it (capped glide keeps approaching next call)
    local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if h then pcall(function() h.CFrame = CFrame.new(goal); h.AssemblyLinearVelocity = Vector3.zero end) end
  end
  for _,p in ipairs(saved) do if p.Parent then pcall(function() p.CanCollide=true end) end end
  return arrived
end

