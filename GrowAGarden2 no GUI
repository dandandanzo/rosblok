  end)
  local YOFF = 3.0   -- hardcoded teleport height offset
  local MOVE_MODE = tostring(C.Mode or "teleport"):lower()   -- "teleport" or "tween" (no-collision)
  local CLAIM_SECS = tonumber(C.ClaimSeconds) or 5           -- keep firing the claim this long per seed (server claim can be a multi-second dwell)
  local STANDOFF   = tonumber(C.Standoff) or 6               -- stand this many studs FROM the seed (don't clip inside its body); 0 = on it
  local function teleportTo(pos) return moveTo(pos, YOFF, MOVE_MODE, C.TweenSpeed) end
  local function spawnInfo(part)
    if part:GetAttribute("RainbowSeed")==true then return "Rainbow Seed","rainbow" end
    if part:GetAttribute("GoldSeed")==true then return "Gold Seed","gold" end
    local sp=part:GetAttribute("SeedPack")
    if type(sp)=="string" and sp~="" then
      local low=sp:lower()
      if low:find("rainbow") then return sp,"rainbow" end  
      if low:find("gold")    then return sp,"gold"    end  
      return sp,"pack"
    end
    return nil,nil
  end
  -- accept both new (Collect*) and old (Grab*) key names; rainbow/gold default ON
  -- (only OFF if explicitly false), packs default OFF. Prevents a rename/missing-key
  -- mismatch from silently filtering every seed out (= "won't teleport").
  local function wanted(k)
    if k=="rainbow" then local v=C.CollectRainbow; if v==nil then v=C.GrabRainbow end; return v ~= false
    elseif k=="gold" then local v=C.CollectGold;   if v==nil then v=C.GrabGold   end; return v ~= false
    elseif k=="pack" then local v=C.CollectAllSeedPacks; if v==nil then v=C.GrabAllSeedPacks end; return v == true end
    return false
  end
  local function spawnPos(part) if part:IsA("BasePart") then return part.Position end local ok,cf=pcall(function() return part:GetPivot() end); if ok then return cf.Position end end
  -- The PHYSICAL gold/rainbow seed (what you actually see + walk into) is a separate object in
  -- Map.SeedPackSpawnClient, created AT the server-location's spot a beat after the data ref
  -- appears. Aim at THAT once it materializes (firing at the data-ref the instant it appears is
  -- why it "only teleported"). Returns the nearest client-seed position to the ref, or nil.
  local function physSeedPos(refPos)
    if not refPos then return nil end
    local mapf=workspace:FindFirstChild("Map"); local cf=mapf and mapf:FindFirstChild("SeedPackSpawnClient")
    if not cf then return nil end
    local best,bestD=nil,20
    for _,c in ipairs(cf:GetChildren()) do local ok,piv=pcall(function() return c:GetPivot() end); if ok then local d=(piv.Position-refPos).Magnitude; if d<bestD then bestD=d; best=piv.Position end end end
    return best
  end
  -- physical seed INSTANCES near the ref, so we can fire prompts/clicks on the SEED OBJECT itself,
  -- not just the data ref (in case a hold-E prompt lives on the visual seed, not the ServerLocation).
  local function physSeedInsts(refPos)
    local out={}
    if not refPos then return out end
    local mapf=workspace:FindFirstChild("Map"); local cf=mapf and mapf:FindFirstChild("SeedPackSpawnClient")
    if not cf then return out end
    for _,c in ipairs(cf:GetChildren()) do local ok,piv=pcall(function() return c:GetPivot() end); if ok and (piv.Position-refPos).Magnitude<20 then out[#out+1]=c end end
    return out
  end
  -- GROUND SNAP: the server claims event seeds by PROXIMITY to the ground spawn point, NOT the
  -- floating/bobbing visual (SpawnSeedPackController hovers the model above the anchor). Raycast
  -- straight down at the spawn X/Z to find the real floor, excluding our own character + the
  -- cosmetic SeedPackSpawnClient visuals (so we never snap onto a hovering seed model). Returns a
  -- ground-level Vector3 at the spawn X/Z; falls back to refPos if no floor is hit.
  local function groundSnap(refPos)
    if typeof(refPos) ~= "Vector3" then return refPos end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    local excl = {}
    if lp.Character then excl[#excl+1] = lp.Character end
    local mapf = workspace:FindFirstChild("Map")
    local cfv = mapf and mapf:FindFirstChild("SeedPackSpawnClient"); if cfv then excl[#excl+1] = cfv end
    params.FilterDescendantsInstances = excl
    local res = workspace:Raycast(refPos + Vector3.new(0,60,0), Vector3.new(0,-400,0), params)
    if res then return Vector3.new(refPos.X, res.Position.Y, refPos.Z) end
    return refPos
  end
  -- feet-on-floor Y offset for the CURRENT avatar (HipHeight + half root height); ~3 for default.
  -- Combined with a ground-snapped target this stands the character on the floor (injak tanah),
  -- instead of the old flat +3 on top of the already-floating visual.
  local function footY()
    -- Seed-teleport height offset above the ground-snapped floor. Set to +1 per request (was +3) so the
    -- char stands LOWER / closer to the seed's ground spawn point. NOTE: +3 was the prior "normal
    -- standing" value (HipHeight reads 0, so a low offset can look sunk into the floor) -- +1 intentional.
    return 1
  end
  -- fire every interactable under a container: ProximityPrompt (instant via fireproximityprompt,
  -- hold zeroed so "hold E for several seconds" collapses to one trigger), ClickDetector, per-part
  -- touch. Returns prompt/click/touch counts.
  local function fireUnder(container, r)
    local nP,nC,nT=0,0,0
    for _,d in ipairs(container:GetDescendants()) do
      if d:IsA("ProximityPrompt") then
        nP=nP+1
        if typeof(fireproximityprompt)=="function" then
          pcall(function() d.Enabled=true; d.HoldDuration=0; d.RequiresLineOfSight=false; d.MaxActivationDistance=math.max(d.MaxActivationDistance or 0, 60) end)
          pcall(function() fireproximityprompt(d) end)
        end
      elseif d:IsA("ClickDetector") then
        nC=nC+1
        if typeof(fireclickdetector)=="function" then pcall(function() fireclickdetector(d) end) end
      elseif d:IsA("BasePart") and r and typeof(firetouchinterest)=="function" then
        nT=nT+1
        pcall(function() firetouchinterest(r, d, 0); firetouchinterest(r, d, 1) end)   -- touch-pickup seeds
      end
    end
    return nP,nC,nT
  end
  -- ===== sequential, no-cap claimer =====
  -- One target at a time: go to the NEAREST physical seed (any distance, NO selection cap), commit
  -- to it until its ref is destroyed = claimed by us OR anyone (server destroys the ref on claim,
  -- which despawns the physical), then pick the next nearest. We do NOT re-target mid-claim even if
  -- a closer seed spawns. ClaimSeconds is the per-seed SAFETY timeout: if nobody claims it in time,
  -- skip to the next (+ briefly cooldown it so we don't instantly re-lock onto it).
  -- NOTE: physSeedPos/physSeedInsts' 20-stud bound is only ref<->physical PAIRING (distance ~0 per
  -- SpawnSeedPackController), NOT the selection distance; selection below is uncapped.
  local map=workspace:WaitForChild("Map",30)
  local sl=map and map:FindFirstChild("SeedPackSpawnServerLocations")
  if not sl then warn("[SEEDGRAB] SeedPackSpawnServerLocations not found - seed-grab aborting") return end
  local cooldown={}   -- [ref] = os.clock() until; a recently timed-out seed we skip for a bit
  -- wanted refs -> {ref,name,kind,rp(refPos),pos(physPos or refPos)}
  local function candidates()
    local out={}
    for _,ref in ipairs(sl:GetChildren()) do
      if ref.Parent and not (cooldown[ref] and os.clock()<cooldown[ref]) then
        local name,kind=spawnInfo(ref)
        if name and wanted(kind) then
          local rp=spawnPos(ref)
          -- do NOT wait for the physical seed: target the ref the moment it spawns (win the
          -- race to the spot). Use the physical position if it's already there, else the ref.
          if rp and rp.Magnitude>=1 then out[#out+1]={ref=ref,name=name,kind=kind,rp=rp,pos=rp} end   -- sort by ref pos; claim uses groundSnap(rp). skip physSeedPos scan for speed
        end
      end
    end
    return out
  end
  -- commit to ONE seed until its ref is destroyed (claimed by anyone) or ClaimSeconds elapses
  local function claimOne(c, allCands)
    print(("[SEEDGRAB] *** %s *** claiming at %s"):format(c.name, tostring(c.rp)))
    -- SPEED: ground target computed ONCE (spawn point is static). On PROMPT-based servers the seed has
    -- a "CLAIM" ProximityPrompt (key E, hold=0) -> re-fire it every ~0.1s (= AUTO-HOLD E) until the ref
    -- despawns. A SINGLE fire often misses (our teleport not yet replicated server-side, or the seed is
    -- claimed by another player first) which is why claims weren't landing (gold inv stayed flat). On
    -- proximity-only servers there's no prompt (claimPrompt=nil) so the loop just holds position. The
    -- heavy click/touch + physical-seed scan stays one-shot (keeps the seed-speed gains).
    local seedPos = groundSnap(c.rp)                                 -- floor under the data-ref (feet on the floor via footY)
    local claimPrompt; for _,d in ipairs(c.ref:GetDescendants()) do if d:IsA("ProximityPrompt") then claimPrompt=d; break end end
    -- WHOLE-MAP: cache the CLAIM prompt of EVERY other wanted seed too. fireproximityprompt is
    -- distance-free, so we fire them in parallel (throttled) while teleport-claiming the nearest ->
    -- the WHOLE map gets claimed, not just the closest. (Proximity-only seeds have no prompt -> empty.)
    local allPrompts = {}
    if allCands then for _,cc in ipairs(allCands) do if cc.ref ~= c.ref then for _,d in ipairs(cc.ref:GetDescendants()) do if d:IsA("ProximityPrompt") then allPrompts[#allPrompts+1]=d; break end end end end end
    local t0=os.clock(); local fired=false; local lastPromptFire=0; local lastAllFire=0
    while active() and c.ref.Parent and (os.clock()-t0)<CLAIM_SECS do
      -- BAIL if the seed is no longer a valid wanted seed: when the event ENDS mid-claim the ref can
      -- linger a beat (or its Gold/Rainbow attribute gets cleared) without Parent going nil -> without
      -- this, the loop keeps teleporting to the dead seed's spot and FIGHTS the return-home failsafe.
      do local sn, sk = spawnInfo(c.ref); if not (sn and wanted(sk)) then break end end
      grabUntil = os.clock()+0.5; noAnchorUntil = os.clock()+0.5   -- no night re-pin + stay UNANCHORED
      local r=getRoot()
      local target = seedPos                                       -- stand BESIDE the seed (horizontal standoff), feet on the floor
      if STANDOFF>0 and r then local d=r.Position-seedPos; d=Vector3.new(d.X,0,d.Z); target = seedPos + (d.Magnitude>0.1 and d.Unit or Vector3.new(1,0,0))*STANDOFF end
      moveTo(target, footY(), MOVE_MODE, C.TweenSpeed)
      if claimPrompt and claimPrompt.Parent and (os.clock()-lastPromptFire)>=0.1 and typeof(fireproximityprompt)=="function" then
        lastPromptFire=os.clock()                               -- AUTO-HOLD E: keep pressing the CLAIM prompt until the seed is ours
        pcall(function() claimPrompt.Enabled=true; claimPrompt.HoldDuration=0; claimPrompt.RequiresLineOfSight=false; claimPrompt.MaxActivationDistance=math.max(claimPrompt.MaxActivationDistance or 0, 60) end)
        pcall(function() fireproximityprompt(claimPrompt) end)
      end
      if #allPrompts>0 and (os.clock()-lastAllFire)>=0.15 and typeof(fireproximityprompt)=="function" then
        lastAllFire=os.clock()                                   -- WHOLE-MAP: fire every OTHER seed's claim prompt in parallel (distance-free)
        for _,p in ipairs(allPrompts) do if p.Parent then
          pcall(function() p.Enabled=true; p.HoldDuration=0; p.RequiresLineOfSight=false; p.MaxActivationDistance=math.max(p.MaxActivationDistance or 0, 60) end)
          pcall(function() fireproximityprompt(p) end)
        end end
      end
      if not fired then                                           -- one-shot: click/touch + physical-seed scan (the expensive GetDescendants part)
        fired=true
        local nP,nC,nT = fireUnder(c.ref, r)
        for _,inst in ipairs(physSeedInsts(c.rp)) do local a,b,cc=fireUnder(inst,r); nP=nP+a; nC=nC+b; nT=nT+cc end
        if c.ref:IsA("BasePart") and r and typeof(firetouchinterest)=="function" then
          pcall(function() firetouchinterest(r, c.ref, 0); firetouchinterest(r, c.ref, 1) end)
        end
        dbg(("claim %s: hasPrompt=%s prompts=%d clicks=%d parts=%d"):format(c.name, tostring(claimPrompt~=nil), nP,nC,nT))
      end
      task.wait(0.04)
    end
    if not c.ref.Parent then print(("[SEEDGRAB] claimed %s (us or another player)"):format(c.name))
    else cooldown[c.ref]=os.clock()+10; dbg("claim timeout -> next:", c.name) end
  end
  print(("[SEEDGRAB] started (sequential nearest-first, no cap | rainbow=%s gold=%s allPacks=%s)"):format(tostring(C.CollectRainbow), tostring(C.CollectGold), tostring(C.CollectAllSeedPacks)))
  -- SPEED: event-driven detection. Wake the instant a seed ref is parented under the spawn folder
  -- instead of waiting out the idle poll. The 0.25s backstop covers refs that mutate in place.
  local woke=false
  local addConn=sl.ChildAdded:Connect(function() woke=true end)
  while enabled() do
    if not alive() then seedEventActive=false; task.wait(0.5)
    else
      for r,t in pairs(cooldown) do if (not r.Parent) or os.clock()>t then cooldown[r]=nil end end  -- prune dead/expired ref keys (leak fix)
      local cands=candidates()
      if #cands==0 then
        seedEventActive=false                                 -- no wanted seed -> freeze guard back to normal
        woke=false
        local tw=os.clock()
        while enabled() and not woke and (os.clock()-tw)<0.25 do
          if #candidates()>0 then break end   -- seed's type-attribute just replicated -> catch it instantly, don't wait out the poll
          task.wait(0.03)
        end
      else
        seedEventActive=true                                  -- event live -> runMisc freeze guard stands down (no anchor/re-pin)
        seedEventLingerUntil=os.clock()+10                    -- keep farming paused through the ~4-6s gaps between seed spawns
        local r=getRoot(); local hp=r and r.Position
        if hp then table.sort(cands, function(a,b) return (a.pos-hp).Magnitude < (b.pos-hp).Magnitude end) end
        claimOne(cands[1], cands)   -- nearest = teleport-claim; ALL others fired in parallel (whole map)
        task.wait(0.05)
      end
    end
  end
  if addConn then addConn:Disconnect() end
  seedEventActive=false   -- feature stopped -> never leave the guard disabled
  print("[SEEDGRAB] stopped.")
end

local function runMail(C)
  local function mail_active() return alive() and Cfg.Mail ~= false end
