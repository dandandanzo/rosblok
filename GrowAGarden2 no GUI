-- self-refreshing deadline: grab loops push this forward each tick so the character-guard
-- anchors the HRP during a grab (true anti-gravity). Auto-expires -> never stuck anchored.
local grabUntil = 0
-- CollectEventSeeds sets this so the night-freeze / anti-gravity guard keeps the HRP UNANCHORED
-- during a seed claim. An anchored character does NOT register the server-side event-seed claim
-- (that's the regression the night-freeze introduced - it worked before, when never anchored).
-- The seed loop holds position via fast re-teleport + zeroed velocity, so there's no fall.
local noAnchorUntil = 0
-- Set > os.clock() by runBuyPets for the whole wild-pet trip (teleport + tame + return-home) so the
-- return-home failsafe does NOT yank the char home mid-tame. Auto-expires (timestamp, like grabUntil),
-- so an error mid-trip can never leave the failsafe permanently disabled.
local buyPetsUntil = 0
-- Set TRUE by runSeedGrab whenever a wanted rainbow/gold/pack seed is present (event active).
-- The night/moon freeze guard reads this and FULLY STANDS DOWN while it's true (no anchor, no
-- garden-center re-pin) so a claim is never fought. noAnchorUntil only covered 0.5s windows that
-- leaked between claims; this covers the whole event. Trade-off: no anti-fling during the event.
local seedEventActive = false
-- pushed forward by runSeedGrab whenever a wanted seed is present; eventPauseActive lingers on it so the
-- pause doesn't flicker in the ~4-6s gaps between seed spawns. Resets ~10s after the LAST seed.
local seedEventLingerUntil = 0

-- TRUE while a gold/rainbow SEED event is actually producing seeds AND the user wants farming paused.
-- Read by runHarvest / runPlantBuy / runSell to STAND DOWN so the char focuses on claiming (and
-- harvest/plant don't fail/fight while the char is teleported away). Auto-resumes ~10s after the last
-- seed. Signal = ACTUAL seed activity (seedEventActive + linger), NOT the weather name -- so non-seed
-- moon events (e.g. Bloodmoon, which spawns NO seeds) do NOT pause farming. Gated by CollectEventSeeds
-- on + PauseFarmDuringEvent ~= false.
local function eventPauseActive()
  if Cfg.CollectEventSeeds == false then return false end
  local ec = Cfg.CollectEventSeedsConfig
  if not (ec and ec.PauseFarmDuringEvent ~= false) then return false end
  return seedEventActive or os.clock() < seedEventLingerUntil
end

