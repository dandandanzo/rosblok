    local HttpService = game:GetService("HttpService")
    local function webhookPost(url, bodyTable, messageId, label)
        if Cfg.Webhook == false then return false end
        if type(url) ~= "string" or url == "" or url:find("PUT_YOUR") then return false end
        local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
        if not req then warn("[WEBHOOK] executor has no HTTP request function"); return false end
        local wc = Cfg.WebhookConfig or {}
        if type(bodyTable) == "table" and not bodyTable.username then
            bodyTable.username = (type(wc.Username)=="string" and wc.Username~="") and wc.Username or "GAG2"
        end
        local function fire(method, fullUrl)
            return pcall(function()
                return req({ Url = fullUrl, Method = method,
                      Headers = { ["Content-Type"] = "application/json" },
                      Body = HttpService:JSONEncode(bodyTable) })
            end)
        end
        local editing = type(messageId)=="string" and messageId~=""
        local method  = editing and "PATCH" or "POST"
        local fullUrl = editing and (url.."/messages/"..messageId) or (url.."?wait=true")
        local ok, res = fire(method, fullUrl)
        if not ok then return false end
        local status = res and (res.StatusCode or res.Status or res.status_code)
        if editing and status and status >= 400 then
            method, fullUrl = "POST", url.."?wait=true"
            ok, res = fire(method, fullUrl); if not ok then return false end
        end
        if method == "POST" and res and res.Body then
            local okj, data = pcall(function() return HttpService:JSONDecode(tostring(res.Body)) end)
            if okj and type(data)=="table" and data.id then
                print(("[WEBHOOK] %s message id = %s  (paste into WebhookConfig.%sMessageID to edit this message in place)")
                    :format(tostring(label or "?"), tostring(data.id), tostring(label or "")))
            end
        end
        return true
    end

    local function runPlantBuy(C)
        local function active() return alive() and Cfg.Plant ~= false end
        local function dbg(...) if miscDebug() then print("[PB]", ...) end end

        local P_Buy = Packet("PurchaseSeed")
        local PlayerStateClient = require(RS.ClientModules.PlayerStateClient)
        local SeedData = require(RS.SharedModules.SeedData)
        local PRICE = {}
        for _, e in pairs(SeedData) do if type(e)=="table" and e.SeedName then PRICE[e.SeedName] = tonumber(e.PurchasePrice) or 0 end end

        local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("SeedShop", 20)
        if not SS then warn("[PB] StockValues.SeedShop not found - plant+buy aborting"); return end
        local ITEMS = SS:WaitForChild("Items", 20)

        local replica = PlayerStateClient:WaitForLocalReplica(PlayerStateClient, 30)
        if not replica then warn("[PB] PlayerState replica unavailable - plant+buy aborting"); return end
        local function data() return replica.Data end
        local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end
        local function invCount(n) local d=data(); local s=d and d.Inventory and d.Inventory.Seeds; return (s and s[n]) or 0 end
        local function purchasedCount(n) local d=data(); local p=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Seeds; return (p and p[n]) or 0 end
        local function stockRemaining(n) local v=ITEMS:FindFirstChild(n); local mx=(v and v:IsA("ValueBase") and v.Value) or 0; return math.max(0, mx - purchasedCount(n)) end

        -- spatial hash: O(1) spacing checks (vs scanning EVERY plant per candidate cell)
        local function makeHash(cell) return { cell = cell, b = {} } end
        local function hAdd(h, x, z)
            local k = math.floor(x/h.cell)..","..math.floor(z/h.cell)
            local t = h.b[k]; if not t then t = {}; h.b[k] = t end
            t[#t+1] = Vector2.new(x, z)
        end
        local function hFar(h, x, z, minSp)
            local cx, cz = math.floor(x/h.cell), math.floor(z/h.cell)
            local v = Vector2.new(x, z)
            for dx = -1, 1 do for dz = -1, 1 do
                local t = h.b[(cx+dx)..","..(cz+dz)]
                if t then for _, o in ipairs(t) do if (o - v).Magnitude < minSp then return false end end end
            end end
            return true
        end

        local function plantedCount(name)
            local plot=getPlot(); local plants=plot and plot:FindFirstChild("Plants")
            if not plants then return 0 end
            local c=0 for _,pl in ipairs(plants:GetChildren()) do if pl:GetAttribute("SeedName")==name then c=c+1 end end
            return c
        end
        local function findSeedTool(name)
            local bp=lp:FindFirstChildOfClass("Backpack")
            if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
            if lp.Character then for _,t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") and t:GetAttribute("SeedTool")==name then return t end end end
        end

        local KEEPBUY = {}
        for _, s in ipairs(C.KeepBuyingAfterTarget or {}) do KEEPBUY[tostring(s)] = true end
        local function wantPlant(n, t) return plantedCount(n) < t end
        local function wantBuy(n, t)
            if KEEPBUY[n] then return true end
            return (plantedCount(n) + invCount(n)) < t
        end

        -- MEASURED: PurchaseSeed is NOT rate-limited (10 fired in one frame -> all 10 landed). So fire
        -- the whole affordable/in-stock batch at ONCE, then verify and re-fire any shortfall. Far
        -- faster than the old one-at-a-time confirm (which waited up to 1.5s PER seed).
        local function buySeed(name, cap)
            local price = PRICE[name] or 0
            local start = purchasedCount(name)
            local function canBuy()
                local n = stockRemaining(name)
                if cap and cap>0 then n = math.min(n, cap-(purchasedCount(name)-start)) end
                if price>0 then n = math.min(n, math.floor(sheckles()/price)) end
                return math.max(0, n)
            end
            for _=1,5 do
                if not active() then break end
                local n = canBuy(); if n<=0 then break end
                local before = purchasedCount(name)
                for _=1,n do pcall(function() P_Buy:Fire(name) end) end          -- whole batch in one burst
                local t0=os.clock()
                repeat task.wait(0.1) until purchasedCount(name)>=before+n or not active() or os.clock()-t0>2
                if purchasedCount(name)<=before then break end                    -- nothing landed -> stop
            end
            return purchasedCount(name)-start
        end

        local function plantTopUp(name, target)
            local plot=getPlot(); if not plot then return 0 end
            local plants=plot:FindFirstChild("Plants"); if not plants then return 0 end
            local need = target - plantedCount(name)
            if need<=0 then return 0 end
            need = math.min(need, invCount(name))
            if need<=0 then return 0 end
            local tool=findSeedTool(name); if not tool then dbg("no seed tool for", name); return 0 end
            local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid"); if hum then pcall(function() hum:EquipTool(tool) end) end
            task.wait(0.2)
            local areas={}
            for _,p in ipairs(CS:GetTagged("PlantArea")) do if p:IsDescendantOf(plot) and p:IsA("BasePart") then areas[#areas+1]=p end end
            if #areas==0 then return 0 end
            local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Include; rp.FilterDescendantsInstances=areas
            local hash = makeHash(1.2)
            for _,pl in ipairs(plants:GetChildren()) do local ok,cf=pcall(function() return pl:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end end
            local function farEnough(x,z) return hFar(hash, x, z, 1.2) end
            -- shuffle PlantArea order so a need-capped scan isn't biased to the first/corner plot
            for i=#areas,2,-1 do local j=math.random(i); areas[i],areas[j]=areas[j],areas[i] end
            local added=0
            local conn=plants.ChildAdded:Connect(function(m)
                task.defer(function()
                    for _=1,20 do if m:GetAttribute("SeedName") then break end task.wait(0.05) end
                    if m:GetAttribute("SeedName")==name then added=added+1
                        local ok,cf=pcall(function() return m:GetPivot() end); if ok then hAdd(hash, cf.Position.X, cf.Position.Z) end
                    end
                end)
            end)
            -- RANDOM sampling across all plant areas (weighted by surface size) instead of a regular
            -- grid. A grid lays candidates in straight rows so a small batch ends up on one line/edge
            -- of the plot ("garis"). Uniform random points (each kept >=1.2 apart via the hash)
            -- scatter the batch across the whole garden.
            local totalW = 0
            for _,part in ipairs(areas) do totalW = totalW + math.max(1, part.Size.X * part.Size.Z) end
            local function pickArea()
                local r = math.random() * totalW
                for _,part in ipairs(areas) do r = r - math.max(1, part.Size.X * part.Size.Z); if r <= 0 then return part end end
                return areas[#areas]
            end
            local want = math.min(need * 3 + 12, 2000)   -- collect a spaced buffer, then plant `need`
            local spots = {}
            local attempts, maxAttempts = 0, want * 30
            while #spots < want and attempts < maxAttempts do
                attempts = attempts + 1
                if attempts % 200 == 0 then task.wait() end
                local part = pickArea()
                local hx = math.max(0.1, part.Size.X/2 - 0.6)
                local hz = math.max(0.1, part.Size.Z/2 - 0.6)
                local lx = (math.random()*2 - 1) * hx
                local lz = (math.random()*2 - 1) * hz
                local wp = (part.CFrame * CFrame.new(lx, part.Size.Y/2 + 0.2, lz)).Position
                if farEnough(wp.X, wp.Z) then
                    local hit = workspace:Raycast(wp + Vector3.new(0,5,0), Vector3.new(0,-20,0), rp)
                    if hit then spots[#spots+1] = hit.Position; hAdd(hash, hit.Position.X, hit.Position.Z) end
                end
            end
            if #spots == 0 then dbg(("no free spot for %s (garden full at spacing %.2f)"):format(name, 1.2)) end
            -- MEASURED: PlantSeed IS rate-limited ~1/tick (8 fired in one frame -> 1 landed; ~0.05s
            -- pace -> ~full). So pace at 0.05s like harvest instead of confirm-per-plant + a 0.25s pad
            -- (old path was ~3/s; this is ~20/s). `added` (ChildAdded) counts the real plants; the
            -- multi-pass loop refills the few drops from the spare spots so we still reach `need`
            -- without waiting for the next whole cycle. Fires are capped at the shortfall = no overplant.
            local PLANT_DELAY = 0.05
            local si = 1
            for _=1,3 do
                if not active() then break end
                local short = need - added; if short<=0 then break end
                local fired = 0
                while si<=#spots and fired<short and active() do
                    pcall(function() Packet("PlantSeed"):Fire(spots[si], name, tool) end)
                    si=si+1; fired=fired+1; task.wait(PLANT_DELAY)
                end
                if fired==0 then break end                                  -- out of spots
                local t0=os.clock(); repeat task.wait(0.05) until added>=need or os.clock()-t0>1   -- let ChildAdded catch up
            end
            conn:Disconnect()
            return added
        end

        do local n={} for k,v in pairs(C.Targets) do n[#n+1]=k.."="..tostring(v) end
        print("[PB] plant+buy started; targets: "..(table.concat(n,", ")=="" and "(none)" or table.concat(n,", "))
                .."  keepBuying: "..((C.KeepBuyingAfterTarget and #C.KeepBuyingAfterTarget>0) and table.concat(C.KeepBuyingAfterTarget,", ") or "(none)")) end

        while active() do
            for name, target in pairs(C.Targets) do
                if not active() then break end
                if wantBuy(name, target) then local b=buySeed(name, 0); if b>0 then dbg(("bought %s x%d (inv %d)"):format(name,b,invCount(name))) end end
                if wantPlant(name, target) then local p=plantTopUp(name, target); if p>0 then print(("[PB] planted %s x%d (now %d/%d)"):format(name,p,plantedCount(name),target)) end
                else dbg(("%s target met (%d/%d) - plant stopped%s"):format(name, plantedCount(name), target, KEEPBUY[name] and ", still buying" or ", buy stopped")) end
            end
            for _=1, math.max(3, 5) do if not active() then return end task.wait(1) end   -- Plant cycle every 5s
        end
        print("[PB] stopped.")
    end

    local function runHarvest(C)
        local function active() return alive() and Cfg.Harvest ~= false end
        local function dbg(...) if miscDebug() then print("[HARV]", ...) end end

        local P_Collect = Packet("CollectFruit")
        local MUTONLY={} for _,s in ipairs(C.MutationOnly or {}) do MUTONLY[tostring(s):lower()]=true end
        local MUT_SET={} for _,m in ipairs(C.Mutations or {}) do MUT_SET[tostring(m):lower()]=true end
        local function mutationOf(inst)
            local m=inst:GetAttribute("Mutation")
            if m==nil or m=="" or m=="None" then return nil end
            if next(MUT_SET)~=nil and not MUT_SET[tostring(m):lower()] then return nil end
            return tostring(m)
        end

        local _plot
        local function myPlot()
            if _plot and _plot.Parent then return _plot end
            local g=workspace:FindFirstChild("Gardens"); if not g then return nil end
            for _,p in ipairs(g:GetChildren()) do if p:GetAttribute("OwnerUserId")==lp.UserId then _plot=p; return p end end
        end
        local last_fire={}; local FIRE_CD=2.0
        -- MEASURED on the live server: CollectFruit is rate-limited to ~18-20 accepted/sec. Firing
        -- faster just gets the extras DROPPED (80 in one frame -> 1 landed; ~24/s -> only ~76% landed)
        -- which is exactly why bursting / no-wait was SLOWER. 0.05s (=20/s) sits right at that ceiling:
        -- ~full landing and ~1.6x faster than the old 0.08 (12.5/s). This is a SERVER wall - higher FPS
        -- does not help past it. (FireDelay overridable; set 0 for one-per-frame.)
        local FIRE_DELAY = (C.FireDelay ~= nil) and tonumber(C.FireDelay) or 0.05
        local function pace() if FIRE_DELAY>0 then task.wait(FIRE_DELAY) else task.wait() end end

        local function sweep()
            local plot=myPlot(); if not plot then return 0 end
            local plants=plot:FindFirstChild("Plants"); if not plants then return 0 end
            local now=tick(); local fired,scanned=0,0
            for _,plant in ipairs(plants:GetChildren()) do
                if fired>=400 or not active() then break end
                scanned=scanned+1; if scanned % 50 == 0 then task.wait() end
                local seedName=tostring(plant:GetAttribute("SeedName") or ""):lower()
                local mutOnly=MUTONLY[seedName]==true
                local fruits=plant:FindFirstChild("Fruits") or plant:FindFirstChild("F")
                if fruits then
                    for _,fruit in ipairs(fruits:GetChildren()) do
                        local fruitId=fruit:GetAttribute("FruitId")
                        if fruitId~=nil and ((not mutOnly) or mutationOf(fruit)~=nil) then
                            local plantId=fruit:GetAttribute("PlantId")
                            local age,maxAge=fruit:GetAttribute("Age"),fruit:GetAttribute("MaxAge")
                            local ripeOk=(type(age)=="number" and type(maxAge)=="number" and age>=maxAge)   -- always ripe-only
                            now=tick(); local cdOk=(not last_fire[fruitId]) or (now-last_fire[fruitId]>=FIRE_CD)
                            if plantId and ripeOk and cdOk then
                                pcall(function() P_Collect:Fire(plantId, fruitId) end)
                                last_fire[fruitId]=now; fired=fired+1; pace()
                                if fired>=400 then break end
                            end
                        end
                    end
                else
                    if (not mutOnly) or mutationOf(plant)~=nil then
                        local plantId=plant:GetAttribute("PlantId")
                        local ready=plant:GetAttribute("PlantGrowthReady")==true
                        if not ready then local a,m=plant:GetAttribute("Age"),plant:GetAttribute("MaxAge"); ready=type(a)=="number" and type(m)=="number" and a>=m end
                        now=tick(); local cdOk=(not last_fire[plantId]) or (now-last_fire[plantId]>=FIRE_CD)
                        if plantId and ready and cdOk then
                            pcall(function() P_Collect:Fire(plantId, "") end)
                            last_fire[plantId]=now; fired=fired+1; pace()
                        end
                    end
                end
            end
            if next(last_fire) then for id,t in pairs(last_fire) do if now-t>FIRE_CD*4 then last_fire[id]=nil end end end
            return fired
        end

        print("[HARV] harvest started; mutation-only seeds: "..(#(C.MutationOnly or {})>0 and table.concat(C.MutationOnly,", ") or "(none)"))
        while active() do
            local ok,fired = pcall(sweep)
            if not ok then
                warn("[HARV] sweep error (recovered): "..tostring(fired))
            elseif fired and fired>0 then
                print(("[HARV] sweep harvested %d"):format(fired))
            end
            -- NONSTOP-ish: re-sweep fast when fruit was harvested, but with a small floor so the
            -- garden isn't fully scanned EVERY frame (that was a real CPU spike); longer breather
            -- when nothing was ripe.
            if fired and fired>0 then task.wait(0.1) else task.wait(0.5) end
        end
        print("[HARV] stopped.")
    end

    local function runSell(C)
        local function active() return alive() and Cfg.Sell ~= false end
        local function dbg(...) if miscDebug() then print("[SELL]", ...) end end
        local P_Sell = Packet("SellAll")
        local function fruitCount() return tonumber(lp:GetAttribute("FruitCount")) or 0 end
        local function maxCap()     return tonumber(lp:GetAttribute("MaxFruitCapacity")) or 100 end
        local mode = tostring(C.Mode or "full"):lower()
        local fullMode = (mode ~= "always")
        local function threshold()
            if C.SellAtPercent and C.SellAtPercent > 0 then
                return math.max(1, math.floor(maxCap() * math.clamp(C.SellAtPercent, 0, 1) + 0.5))
            end
            return tonumber(C.SellAtFruitCount) or 90
        end
        -- DELAY mode: sell on a fixed timer (regardless of fruit count)
        if mode == "delay" then
            local d = math.max(1, tonumber(C.SellDelay) or 30)
            print(("[SELL] started; mode=delay (every %ds, capacity %d)"):format(d, maxCap()))
            while active() do
                local fc = fruitCount()
                if fc > 0 then pcall(function() P_Sell:Fire() end); dbg(("sold on delay (fruit was %d/%d)"):format(fc, maxCap())) end
                for _=1, d do if not active() then return end task.wait(1) end
            end
            print("[SELL] stopped.")
            return
        end
        print(("[SELL] started; mode=%s%s  (capacity %d)")
            :format(fullMode and "sell-when-full" or "sell-always",
                    fullMode and (" threshold="..threshold()) or "", maxCap()))
        -- EVENT-DRIVEN: sell the INSTANT FruitCount crosses the threshold (no polling wait, no
        -- post-sell delay). The 0.5s guard only dedups the burst while a sell is in flight
        -- (FruitCount takes a server round-trip to drop) - the first sell is immediate.
        local lastSell = 0
        local function trySell()
            if not active() then return end
            local fc = fruitCount()
            local hit = fullMode and (fc >= threshold()) or ((not fullMode) and fc > 0)
            if hit and (os.clock() - lastSell) >= 0.5 then
                lastSell = os.clock()
                pcall(function() P_Sell:Fire() end)
                dbg(("sold (fruit was %d/%d, threshold %d)"):format(fc, maxCap(), threshold()))
            end
        end
        local conn
        pcall(function() conn = lp:GetAttributeChangedSignal("FruitCount"):Connect(trySell) end)
        trySell()   -- in case the backpack is already full at start
        while active() do trySell(); task.wait(2) end   -- light safety net; the event does the selling
        if conn then pcall(function() conn:Disconnect() end) end
        print("[SELL] stopped.")
    end

    local function runSeedGrab(C)
        local function active() return alive() and Cfg.CollectEventSeeds ~= false end
        local function dbg(...) if miscDebug() then print("[SEEDGRAB]", ...) end end
        local function getRoot() local c=lp.Character; if not c then return nil end return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso"), c end
        local YOFF = 3.0   -- hardcoded teleport height offset
        local function teleportTo(pos) local r,c=getRoot(); if not c then return end pcall(function() c:PivotTo(CFrame.new(pos+Vector3.new(0, YOFF, 0))) end)
            if r then pcall(function() r.AssemblyLinearVelocity=Vector3.zero; r.AssemblyAngularVelocity=Vector3.zero end) end end  -- anti-fall
        local function spawnInfo(part)
            if part:GetAttribute("RainbowSeed")==true then return "Rainbow Seed","rainbow" end
            if part:GetAttribute("GoldSeed")==true then return "Gold Seed","gold" end
            local sp=part:GetAttribute("SeedPack")
            if type(sp)=="string" and sp~="" then
                local low=sp:lower()
                if low:find("rainbow") then return sp,"rainbow" end  
                if low:find("gold")    then return sp,"gold"    end  
                return sp,"pack"
            end
            return nil,nil
        end
        -- accept both new (Collect*) and old (Grab*) key names; rainbow/gold default ON
        -- (only OFF if explicitly false), packs default OFF. Prevents a rename/missing-key
        -- mismatch from silently filtering every seed out (= "won't teleport").
        local function wanted(k)
            if k=="rainbow" then local v=C.CollectRainbow; if v==nil then v=C.GrabRainbow end; return v ~= false
            elseif k=="gold" then local v=C.CollectGold;   if v==nil then v=C.GrabGold   end; return v ~= false
            elseif k=="pack" then local v=C.CollectAllSeedPacks; if v==nil then v=C.GrabAllSeedPacks end; return v == true end
            return false
        end
        local function spawnPos(part) if part:IsA("BasePart") then return part.Position end local ok,cf=pcall(function() return part:GetPivot() end); if ok then return cf.Position end end
        local claiming={}; local skip={}   
        local function claimSpawn(part)
            if claiming[part] or skip[part] or not (part and part.Parent) then return end
            claiming[part]=true
            local _,char=getRoot(); local startCF=char and char:GetPivot()
            local name,kind=spawnInfo(part)
            if name and not wanted(kind) then dbg("skip (filtered):", name); skip[part]=true; claiming[part]=nil return end
            local pos=spawnPos(part)
            if pos and pos.Magnitude>=1 then teleportTo(pos) end
            if not name then local dl=os.clock()+1.5 repeat task.wait(); name,kind=spawnInfo(part) until name or os.clock()>dl or not part.Parent end
            if not (part.Parent and name) then claiming[part]=nil return end
            if not wanted(kind) then
                dbg("skip (filtered):", name); skip[part]=true
                if startCF then local _,ch=getRoot(); if ch then pcall(function() ch:PivotTo(startCF) end) end end
                claiming[part]=nil return
            end
            if not pos or pos.Magnitude<1 then local dl=os.clock()+1.5 repeat task.wait(); pos=spawnPos(part) until (pos and pos.Magnitude>=1) or os.clock()>dl or not part.Parent end
            if not (part.Parent and pos) then claiming[part]=nil return end
            print(("[SEEDGRAB] *** %s SPAWNED *** at %s - claiming"):format(name, tostring(pos)))
            local t0=os.clock()
            local loggedKinds=false
            while active() and part.Parent and (os.clock()-t0)<3 do
                grabUntil = os.clock() + 0.5   -- anchor-float during the grab (true anti-fall)
                teleportTo(spawnPos(part) or pos)
                local r=getRoot()
                local nP,nC,nT=0,0,0
                for _,d in ipairs(part:GetDescendants()) do
                    if d:IsA("ProximityPrompt") then
                        nP=nP+1
                        if typeof(fireproximityprompt)=="function" then
                            pcall(function() d.Enabled=true; d.HoldDuration=0; d.RequiresLineOfSight=false; d.MaxActivationDistance=math.max(d.MaxActivationDistance or 0, 60) end)
                            pcall(function() fireproximityprompt(d) end)
                        end
                    elseif d:IsA("ClickDetector") then
                        nC=nC+1
                        if typeof(fireclickdetector)=="function" then pcall(function() fireclickdetector(d) end) end
                    elseif d:IsA("BasePart") and r and typeof(firetouchinterest)=="function" then
                        nT=nT+1
                        pcall(function() firetouchinterest(r, d, 0); firetouchinterest(r, d, 1) end)   -- touch-pickup seeds
                    end
                end
                -- some seeds are claimed by touching the spawn part itself, not a child prompt
                if part:IsA("BasePart") and r and typeof(firetouchinterest)=="function" then
                    pcall(function() firetouchinterest(r, part, 0); firetouchinterest(r, part, 1) end)
                end
                if not loggedKinds then dbg(("claim interactables for %s: prompts=%d clickdetectors=%d parts=%d"):format(tostring(name), nP, nC, nT)); loggedKinds=true end
                task.wait(0.06)
            end
            if not part.Parent then print(("[SEEDGRAB] claimed %s"):format(name)) else dbg("claim timeout:", name) end
            if startCF then local _,ch=getRoot(); if ch then pcall(function() ch:PivotTo(startCF) end) end end
            claiming[part]=nil
        end
        local map=workspace:WaitForChild("Map",30)
        local sl=map and map:FindFirstChild("SeedPackSpawnServerLocations")
        if not sl then warn("[SEEDGRAB] SeedPackSpawnServerLocations not found - seed-grab aborting") return end
        local function scanNow() for _,c in ipairs(sl:GetChildren()) do if active() then task.spawn(claimSpawn,c) end end end
        sl.ChildAdded:Connect(function(c) if active() then task.spawn(claimSpawn,c) end end)
        pcall(function()
            local Net=require(RS.SharedModules.Networking); local sp=Net and Net.SeedPackSpawn
            if sp then
                if sp.Announce then sp.Announce.OnClientEvent:Connect(function() if active() then scanNow() end end) end
                if sp.FX then sp.FX.OnClientEvent:Connect(function() if active() then scanNow() end end) end
            end
        end)
        task.spawn(function() while active() do scanNow(); task.wait(0.5) end end)   
        scanNow()
        print(("[SEEDGRAB] started (rainbow=%s gold=%s allPacks=%s)"):format(tostring(C.CollectRainbow), tostring(C.CollectGold), tostring(C.CollectAllSeedPacks)))
    end

    local function runMail(C)
        local function mail_active() return alive() and Cfg.Mail ~= false end
        local RECIPIENT_USERNAME=C.TargetUsername; local RECIPIENT_USERID=C.TargetUserId
        local MESSAGE=C.MessageMail; local LIST_ITEM=C.ListItem
        local MAX_PER_ITEM=(C.MaxPerItem and C.MaxPerItem>0) and C.MaxPerItem or math.huge
        local SEND_DEBOUNCE=5; local MAX_ITEMS_PER_GIFT=20
        local SEND_WHEN_COUNT=C.SendWhenCount; local SEND_AMOUNT=C.SendAmount; local WATCH_INTERVAL=10
        local INCLUDE_FRUITS=false
        local ReplicaClient=require(RS.ClientModules.ReplicaClient)
        print(string.rep("=",56)); print("GAG2 Auto Send Mail  [LIVE]"); print(string.rep("=",56))
        local PER_INSTANCE={ Pets=true, HarvestedFruits=true }
        local GIFTABLE={"Seeds","SeedPacks","Crates","Sprinklers","WateringCans","Mushrooms","Gnomes","Raccoons","Trowels","Props","Pets","HarvestedFruits"}
        local function normName(s) s=tostring(s):lower():gsub("^%s+",""):gsub("%s+$",""); s=s:gsub("%s*seed$",""); return s end
        local CAT_ALIAS={seed="Seeds",seeds="Seeds",fruit="HarvestedFruits",fruits="HarvestedFruits",harvestedfruit="HarvestedFruits",harvestedfruits="HarvestedFruits",pet="Pets",pets="Pets",crate="Crates",crates="Crates",pack="SeedPacks",packs="SeedPacks",seedpack="SeedPacks",seedpacks="SeedPacks",sprinkler="Sprinklers",sprinklers="Sprinklers",can="WateringCans",cans="WateringCans",wateringcan="WateringCans",wateringcans="WateringCans",mushroom="Mushrooms",mushrooms="Mushrooms",gnome="Gnomes",gnomes="Gnomes",raccoon="Raccoons",raccoons="Raccoons",trowel="Trowels",trowels="Trowels",prop="Props",props="Props"}
        local function parseNameList(str)
            local anyN,catN,n={},{},0
            for token in tostring(str):gmatch("[^,]+") do
                token=token:gsub("^%s+",""):gsub("%s+$","")
                local catRaw,nameRaw=token:match("^([%a]+)%s*:%s*(.+)$")
                if catRaw and nameRaw then local cat=CAT_ALIAS[catRaw:lower()]; local nm=normName(nameRaw); if cat and nm~="" then catN[cat]=catN[cat] or {}; catN[cat][nm]=true; n=n+1 end
                else local nm=normName(token); if nm~="" then anyN[nm]=true; n=n+1 end end
            end
            return anyN,catN,n
        end
        local NAME_SET,CAT_NAME_SET,NAME_COUNT=parseNameList(LIST_ITEM)
        local SEND_ALL=(LIST_ITEM:lower():gsub("%s","")=="*" or LIST_ITEM:lower():gsub("%s","")=="all")
        local BLACKLIST={}; for _,nm in ipairs(C.Blacklist or {}) do BLACKLIST[normName(nm)]=true end
        local function resolveRecipient()
            if type(RECIPIENT_USERID)=="number" and RECIPIENT_USERID>0 then return RECIPIENT_USERID end
            local _rl = (type(RECIPIENT_USERNAME)=="string" and RECIPIENT_USERNAME:lower():gsub("%s","")) or ""
            if _rl=="" or _rl=="username" or _rl=="puttargetusernamehere" or _rl=="targetusername" then
                return nil, "set a real TargetUsername (placeholder '"..tostring(RECIPIENT_USERNAME).."' rejected)" end
            for _,pl in ipairs(Players:GetPlayers()) do if pl.Name:lower()==RECIPIENT_USERNAME:lower() or pl.DisplayName:lower()==RECIPIENT_USERNAME:lower() then return pl.UserId end end
            local ok,info=pcall(function() return Packet("MailboxLookupPlayer"):Fire(RECIPIENT_USERNAME) end)
            if ok and type(info)=="table" and (info.UserId or info.userId) then return info.UserId or info.userId end
            if ok and type(info)=="number" and info>0 then return info end
            local ok2,uid=pcall(function() return Players:GetUserIdFromNameAsync(RECIPIENT_USERNAME) end)
            if ok2 and type(uid)=="number" then return uid end
            return nil, "could not resolve '"..RECIPIENT_USERNAME.."'"
        end
        local _psRep   -- cache the PlayerState replica (avoid re-scanning all replicas each pass)
        local function getInventory()
            if _psRep and _psRep.Data and _psRep.Data.Inventory then return _psRep.Data.Inventory end
            local ok,reg=pcall(ReplicaClient.Test); if not ok then return nil end
            for _,rep in pairs(reg.Replicas or {}) do if rep.Token=="PlayerState" and rep.Data and rep.Data.Inventory then _psRep=rep; return rep.Data.Inventory end end
        end
        local function nameAllowed(category, displayName)
            local nn=normName(displayName)
            if BLACKLIST[nn] then return false end
            local cset=CAT_NAME_SET[category]; if cset and cset[nn] then return true end
            if category=="HarvestedFruits" and not INCLUDE_FRUITS then return false end
            if SEND_ALL then return true end
            return NAME_SET[nn]==true
        end
        local function buildItems(inv)
            local items={}
            for _,cat in ipairs(GIFTABLE) do
                local t=inv[cat]
                if type(t)=="table" then
                    if PER_INSTANCE[cat] then
                        local byName={}
                        for key,val in pairs(t) do local nm=(type(val)=="table" and (val.Name or val.FruitName)) or tostring(key); if nameAllowed(cat,nm) then byName[nm]=byName[nm] or {}; table.insert(byName[nm],key) end end
                        for nm,uids in pairs(byName) do local have=#uids; if have>=SEND_WHEN_COUNT then local toSend=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; toSend=math.min(toSend,MAX_PER_ITEM); for i=1,toSend do table.insert(items,{Category=cat,ItemKey=uids[i],Count=1,_display=nm,_have=have}) end end end
                    else
                        for key,val in pairs(t) do local have=tonumber(val) or 0; if nameAllowed(cat,key) and have>=SEND_WHEN_COUNT then local sc=(SEND_AMOUNT>0) and math.min(have,SEND_AMOUNT) or have; sc=math.min(sc,MAX_PER_ITEM); if sc>0 then table.insert(items,{Category=cat,ItemKey=key,Count=sc,_display=key,_have=have}) end end end
                    end
                end
            end
            return items
        end
        local function chunk(list,size) local out,cur={},{} for _,v in ipairs(list) do table.insert(cur,v); if #cur>=size then table.insert(out,cur); cur={} end end if #cur>0 then table.insert(out,cur) end return out end
        if SEND_ALL then print("[MAIL] filter: SEND ALL giftable items")
        elseif NAME_COUNT>0 then print(("[MAIL] filter: by name (%d), fruits=%s"):format(NAME_COUNT, INCLUDE_FRUITS and "included" or "excluded"))
        else warn("[MAIL] ListItem empty - nothing to do") return end
        local userId,err1=resolveRecipient()
        if not userId then warn("[MAIL] recipient error: "..tostring(err1)) return end
        print(("[MAIL] recipient = %s (UserId %s); threshold=%d"):format(tostring(RECIPIENT_USERNAME), tostring(userId), SEND_WHEN_COUNT))

        local cumMails, cumSeeds = 0, 0   
        local function postWebhook(sentByName, total)
            if (Cfg.WebhookConfig or {}).Mail == false then return end   
            cumMails = cumMails + 1
            cumSeeds = cumSeeds + (tonumber(total) or 0)
            local lines = {}
            for nm, ct in pairs(sentByName) do lines[#lines+1] = ("%s x%d"):format(tostring(nm), ct) end
            local itemsText = (#lines > 0) and table.concat(lines, "\n") or "(none)"
            if #itemsText > 1000 then itemsText = itemsText:sub(1, 1000) .. "\n..." end
            local wc = Cfg.WebhookConfig or {}
            local ok = webhookPost(wc.MailUrl, {
                embeds = {{
                    title = "Auto-Mail",
                    color = 5763719,
                    fields = {
                        { name = "Sender",    value = tostring(lp.Name), inline = true },
                        { name = "Recipient", value = ("%s (UserId %s)"):format(tostring(RECIPIENT_USERNAME), tostring(userId)), inline = true },
                        { name = "Last send", value = itemsText, inline = false },
                        { name = "Total Mails Sent",   value = tostring(cumMails), inline = true },
                        { name = "Total Seeds Mailed", value = tostring(cumSeeds), inline = true },
                    },
                    footer = { text = "GAG2 Auto-Mail " .. os.date("%Y-%m-%d %H:%M:%S") },
                }},
            }, wc.MailMessageID, "Mail")
            if ok and miscDebug() then print("[MAIL] webhook posted") end
        end

        local function doSendPass()
            local inv=getInventory(); if not inv then return 0 end
            local items=buildItems(inv); if #items==0 then return 0 end
            local batches=chunk(items,MAX_ITEMS_PER_GIFT); local sent=0; local sentByName={}
            for bi,batch in ipairs(batches) do
                local clean={}; for _,it in ipairs(batch) do table.insert(clean,{Category=it.Category,ItemKey=it.ItemKey,Count=it.Count}) end
                local ok=pcall(function() return Packet("MailboxSendBatch"):Fire(userId,clean,MESSAGE) end)
                if ok then
                    for _,it in ipairs(batch) do sent=sent+it.Count; sentByName[it._display]=(sentByName[it._display] or 0)+it.Count end
                    print(("[MAIL] batch %d/%d sent (%d entries)"):format(bi,#batches,#clean))
                end
                if bi<#batches then task.wait(SEND_DEBOUNCE) end
            end
            if sent>0 then postWebhook(sentByName, sent) end
            return sent
        end
        print("[MAIL] watch started - auto-send when count >= "..SEND_WHEN_COUNT)
        while mail_active() do
            local ok,sent=pcall(doSendPass)
            if ok and sent and sent>0 then task.wait(SEND_DEBOUNCE) end
            task.wait(WATCH_INTERVAL)
        end
        print("[MAIL] watch stopped.")
    end

