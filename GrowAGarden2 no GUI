    local inv=getInventory(); if not inv then return 0 end
    local totalSent=0
    for _,spec in ipairs(SPECS) do
      if not mail_active() then break end
      if not (spec.count and spec.sent >= spec.count) then
        local items=collectForSpec(inv, spec)
        if #items>0 then
          local uid=specRecipient(spec)
          if uid then
            local msg=(spec.message~=nil) and spec.message or ""
            local label=("%s (uid %s)"):format(tostring(spec.username), tostring(uid))
            local sentByName={}; local passSent=0
            for _,batch in ipairs(chunk(items, MAX_ITEMS_PER_GIFT)) do
              if not mail_active() then break end
              local clean={}; for _,it in ipairs(batch) do table.insert(clean,{Category=it.Category,ItemKey=it.ItemKey,Count=it.Count}) end
              local ok=pcall(function() return Packet("MailboxSendBatch"):Fire(uid,clean,msg) end)
              if ok then
                for _,it in ipairs(batch) do spec.sent=spec.sent+it.Count; totalSent=totalSent+it.Count; passSent=passSent+it.Count; sentByName[it._display]=(sentByName[it._display] or 0)+it.Count end
                print(("[MAIL] sent %s (%d entries) -> %s"):format(spec.raw, #clean, label))
              end
              task.wait(SEND_DEBOUNCE)
            end
            if passSent>0 then postWebhook(sentByName, passSent, label) end
          elseif spec.uidErr then warn("[MAIL] skip '"..spec.raw.."': "..tostring(spec.uidErr)) end
        end
      end
    end
    return totalSent
  end
  print("[MAIL] watch started")
  while mail_active() do
    local ok,err=pcall(doSendPass)
    if not ok and miscDebug() then warn("[MAIL] send pass error: "..tostring(err)) end
    task.wait(WATCH_INTERVAL)
  end
  print("[MAIL] watch stopped.")
end

local function runWebhook(C)
  local active = activeFor("Webhook")
  local function dbg(...) if miscDebug() then print("[WEBHOOK]", ...) end end
  if C.Stats == false then print("[WEBHOOK] ready (stats snapshot off; mail webhook still active)"); return end
  local ReplicaClient = require(RS.ClientModules.ReplicaClient)
  local SEED_CATS = { "Seeds" }
  local GEAR_CATS = { "Sprinklers", "WateringCans", "Trowels", "Rakes", "Ladders", "Teleporters", "Flashbangs" }
  local PET_CATS  = { "Pets", "Birds", "Gnomes", "Raccoons" }
  local PER_INSTANCE = { Pets=true, Birds=true, Gnomes=true, Raccoons=true, HarvestedFruits=true, Eggs=true }
  local function getData()
    local ok,reg = pcall(ReplicaClient.Test); if not ok then return nil end
    for _,rep in pairs(reg.Replicas or {}) do if rep.Token=="PlayerState" and rep.Data then return rep.Data end end
  end
  local function summarize(inv, cats)
    local lines, total = {}, 0
    for _,cat in ipairs(cats or {}) do
      local t = inv[cat]
      if type(t)=="table" then
        if PER_INSTANCE[cat] then
          local byName = {}
          for _,val in pairs(t) do
            local nm = (type(val)=="table" and (val.Name or val.PetName or val.FruitName)) or cat
            byName[nm] = (byName[nm] or 0) + 1; total = total + 1
          end
          for nm,ct in pairs(byName) do lines[#lines+1] = ("%s x%d"):format(tostring(nm), ct) end
        else
          for key,val in pairs(t) do local n=tonumber(val) or 0; if n>0 then lines[#lines+1]=("%s x%d"):format(tostring(key), n); total=total+n end end
        end
      end
    end
    table.sort(lines)
    return lines, total
  end
  local function equippedList(data)
    local pets = data and data.Inventory and data.Inventory.Pets
    local byName, total = {}, 0
    if type(pets)=="table" then for _,p in pairs(pets) do if type(p)=="table" and p.Equipped then byName[p.Name or "?"]=(byName[p.Name or "?"] or 0)+1; total=total+1 end end end
    local lines={} for nm,ct in pairs(byName) do lines[#lines+1]=("%s x%d"):format(tostring(nm),ct) end
    table.sort(lines)
    return lines, total
  end
  local function plantedCounts() return countPlantedBySeed(getPlot()) end
  local function fmt(n)
    n=tonumber(n) or 0; local a=math.abs(n)
    if a>=1e9 then return ("%.2fB"):format(n/1e9) elseif a>=1e6 then return ("%.2fM"):format(n/1e6)
    elseif a>=1e3 then return ("%.2fK"):format(n/1e3) else return tostring(math.floor(n+0.5)) end
  end
  local function fieldFor(name, lines, total)
    local v = (#lines>0) and table.concat(lines, "\n") or "(none)"
    if #v > 1000 then v = v:sub(1, 1000) .. "\n..." end
    return { name = ("%s (%d)"):format(name, total), value = v, inline = false }
  end
  local interval = math.max(10, tonumber(C.StatsInterval) or 300)
  local firstShek, firstClock = nil, os.clock()
  print(("[WEBHOOK] stats snapshot started; interval=%ss"):format(tostring(interval)))
  while active() do
    local data = getData()
    if data then
      local shek = math.floor(tonumber(data.Sheckles) or 0)
      if firstShek == nil then firstShek = shek; firstClock = os.clock() end
      local perMin = 0; do local mins=(os.clock()-firstClock)/60; if mins>0.08 then perMin=(shek-firstShek)/mins end end
      local w = workspace:GetAttribute("ActiveWeather"); w = (type(w)=="string" and w~="") and w or "Clear"
      local inv = data.Inventory or {}
      local sL,sT = summarize(inv, SEED_CATS)
      local gL,gT = summarize(inv, GEAR_CATS)
      local pL,pT = summarize(inv, PET_CATS)
      local eL,eT = equippedList(data)
      local targets = (Cfg.PlantConfig and Cfg.PlantConfig.Targets) or {}
      local pc = plantedCounts(); local pnames = {}
      for n,t in pairs(targets) do if (tonumber(t) or 0) > 0 then pnames[#pnames+1]=n end end
      table.sort(pnames)
      local plines, ptot = {}, 0
      for _,n in ipairs(pnames) do local have=pc[n] or 0; ptot=ptot+have; plines[#plines+1]=("%s: %d/%d"):format(n, have, tonumber(targets[n]) or 0) end
      local name = (lp.DisplayName ~= lp.Name) and ("%s (@%s)"):format(lp.DisplayName, lp.Name) or lp.Name
      local ok = webhookPost(C.StatsUrl, {
        embeds = {{
          title = "GAG2 Stats",
          description = ("**%s**\nSheckles: **%s**  (%s%s/min)\nWeather / Event: **%s**")
            :format(name, fmt(shek), perMin>=0 and "+" or "", fmt(perMin), w),
          color = 2303786,
          fields = {
            fieldFor("Garden", plines, ptot),
            fieldFor("Equipped Pets", eL, eT),
            fieldFor("Inventory - Seeds", sL, sT),
            fieldFor("Inventory - Pets", pL, pT),
            fieldFor("Inventory - Gears", gL, gT),
          },
          footer = { text = "GAG2 Stats " .. os.date("%Y-%m-%d %H:%M:%S") },
        }},
      }, C.StatsMessageID, "Stats")
      if ok then dbg(("posted (sheckles=%d seeds=%d pets=%d gears=%d equip=%d)"):format(shek, sT, pT, gT, eT)) end
    end
    for _=1, interval do if not active() then return end task.wait(1) end
  end
  print("[WEBHOOK] stats snapshot stopped.")
end

local function runBuyGears(C)
  local active = activeFor("BuyGears")
  local function dbg(...) if miscDebug() then print("[BUYGEAR]", ...) end end
  local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
  if not replica then warn("[BUYGEAR] PlayerState replica unavailable - aborting"); return end
  local function data() return replica.Data end
  local function sheckles() local d=data(); return (d and d.Sheckles) or 0 end

  local GearShopData = require(RS.SharedModules.GearShopData)
  local GEAR = {}   
  local function scanGear(t, depth)
    if depth > 3 then return end
    for _,e in pairs(t) do
      if type(e)=="table" then
        if e.ItemName then GEAR[e.ItemName] = { Cost = tonumber(e.Cost) or 0, Rarity = tostring(e.Rarity or "") }
        else scanGear(e, depth+1) end
      end
    end
  end
  scanGear(GearShopData, 0)

  local SS = RS:WaitForChild("StockValues", 20) and RS.StockValues:WaitForChild("GearShop", 20)
  if not SS then warn("[BUYGEAR] StockValues.GearShop not found - aborting"); return end
  local ITEMS = SS:WaitForChild("Items", 20)
  local function stockMax(n) local v=ITEMS:FindFirstChild(n); return (v and v:IsA("ValueBase") and v.Value) or 0 end
  local function purchased(n) local d=data(); local g=d and d.PurchasedThisRestock and d.PurchasedThisRestock.Gears; return (g and g[n]) or 0 end
  local function remaining(n) return math.max(0, stockMax(n)-purchased(n)) end

  local rarWant = {}; for _,r in ipairs(C.Rarities or {}) do rarWant[tostring(r):lower()] = true end
  local hasRar = next(rarWant) ~= nil
  local function buildWanted()
    local want = {}
    for _,name in ipairs(C.ListGear or {}) do want[name] = true end
    if hasRar then for name,info in pairs(GEAR) do if rarWant[info.Rarity:lower()] and stockMax(name)>0 then want[name]=true end end end
    return want
  end
  -- MEASURED: PurchaseGear is NOT rate-limited (11 fired in one frame -> all 11 landed), same as
  -- PurchaseSeed. So fire the whole affordable/in-stock batch at ONCE, verify, re-fire shortfall.
  -- (Old path bought one at a time, up to 1.5s confirm + 0.15s pad EACH.) The gear shop restocks
  -- fast, so remaining() is re-read every pass.
  local function buyOne(name)
    local info = GEAR[name]
    if not info then warn(("[BUYGEAR] unknown gear '%s' (check spelling)"):format(name)); return 0 end
    local cost = info.Cost
    local start = purchased(name)
    local function canBuy()
      local n = remaining(name)
      if cost>0 then n = math.min(n, math.floor(sheckles()/cost)) end
      return math.max(0, n)
    end
    for _=1,5 do
      if not active() then break end
      local n = canBuy(); if n<=0 then break end
      local before = purchased(name)
      for _=1,n do pcall(function() Net.GearShop.PurchaseGear:Fire(name) end) end   -- whole batch in one burst
      local t0=os.clock()
      repeat task.wait(0.1) until purchased(name)>=before+n or not active() or os.clock()-t0>2
      if purchased(name)<=before then break end                                       -- nothing landed -> stop
    end
    return purchased(name)-start
  end
  print("[BUYGEAR] started")
  while active() do
    local want = buildWanted()
    for name in pairs(want) do
      if not active() then break end
      if remaining(name)>0 then local b=buyOne(name); if b>0 then print(("[BUYGEAR] bought %s x%d (Sheckles ~%d)"):format(name,b,math.floor(sheckles()))) end end
      task.wait()   -- yield between gears so a big rarity list doesn't burst-fire in one frame
    end
    for _=1, math.max(2, 20 or 6) do if not active() then return end task.wait(1) end
  end
  print("[BUYGEAR] stopped.")
end

local function runBuyPets(C)
  local active = activeFor("BuyPets")
  local function dbg(...) if miscDebug() then print("[BUYPET]", ...) end end
  local replica = PSC:GetLocalReplica() or PSC:WaitForLocalReplica(PSC, 30)
  if not replica then warn("[BUYPET] PlayerState replica unavailable - aborting"); return end
  local function sheckles() local d=replica.Data; return (d and d.Sheckles) or 0 end

  local map = workspace:WaitForChild("Map", 30)
  local refFolder = map and map:WaitForChild("WildPetRef", 30)
  if not refFolder then warn("[BUYPET] Map.WildPetRef not found - aborting"); return end

  local MOVE_MODE = tostring(C.Mode or "teleport"):lower()   -- "teleport" or "tween" (no-collision)
  -- cap each tween glide at ~1.3s so we keep firing ~1/sec at a WANDERING pet (no endless chase)
  local function tpTo(pos) return moveTo(pos, 4, MOVE_MODE, C.TweenSpeed, (MOVE_MODE=="tween") and 1.3 or nil) end

  -- MEASURED: the WildPetRef part is a STATIC reference; the real pet (with the "Buy" prompt) is
  -- a physical, WANDERING model in Map.WildPetSpawns named "WildPet_<species>_<refPartName>".
  -- The server checks tame proximity against THAT model, so we must teleport to it. Teleporting
  -- to the ref part is exactly why the old code only moved but never tamed.
  local spawns = map and map:FindFirstChild("WildPetSpawns")
  -- the wandering physical pet MODEL for a ref (name-substring match), or nil.
  local function physModel(refPart)
    local sf = spawns or (map and map:FindFirstChild("WildPetSpawns")); spawns = sf
    if sf then for _,c in ipairs(sf:GetChildren()) do
      if c.Name:find(refPart.Name, 1, true) then return c end
    end end
  end
  local function physPos(refPart)
    local m = physModel(refPart)
    if m then local ok,piv=pcall(function() return m:GetPivot() end); if ok then return piv.Position end end
    local ok,p=pcall(function() return refPart.Position end); if ok and typeof(p)=="Vector3" then return p end
  end
  -- MEASURED 2026-06-21: taming is now PROMPT-GATED — the model's RootPart carries a "BuyPrompt"
  -- ProximityPrompt (Buy, hold 1, range 12). `Net.Pets.WildPetTame:Fire` no longer tames; firing
  -- THIS prompt does (Frog tamed in 1 fire). So claimWild fires the BuyPrompt, remote = fallback.
  local function buyPrompt(model)
    if not model then return nil end
    for _,d in ipairs(model:GetDescendants()) do
      if d:IsA("ProximityPrompt") and (d.Name=="BuyPrompt" or d.ActionText=="Buy") then return d end
    end
  end

  local spWant, raWant = {}, {}
  for _,s in ipairs(C.ListPets or {}) do spWant[tostring(s):lower()] = true end
  for _,r in ipairs(C.Rarities or {}) do raWant[tostring(r):lower()] = true end
  local hasSp, hasRa = next(spWant)~=nil, next(raWant)~=nil

  pcall(function() Net.Pets.WildPetTameResult.OnClientEvent:Connect(function(part,val) if active() then dbg(("buy result: %s -> %s"):format(part and part.Name or "?", tostring(val))) end end) end)

  local RANK = { common=1, uncommon=2, rare=3, super=4, legendary=5, mythic=6, divine=7, secret=8 }
  local function rarityRank(part) return RANK[tostring(part:GetAttribute("Rarity") or ""):lower()] or 0 end

  local handled  = {}   
  local cooldown = {}   

  -- match by species/rarity + still wild (NO sheckles check here; the loop scans this every
  -- tick, so the affordability gate lives in claimWild right before the teleport).
  local function matchPet(part)
    if part:GetAttribute("OwnerUserId") ~= 0 then return false end
    local pn = tostring(part:GetAttribute("PetName") or ""):lower()
    local rr = tostring(part:GetAttribute("Rarity") or ""):lower()
    if hasSp and not spWant[pn] then return false end
    if hasRa and not raWant[rr] then return false end
    return true
  end
  -- Price attribute can read 0/nil for a frame right after a pet spawns; wait briefly so the
  -- affordability check isn't fooled into teleporting to a pet we can't actually afford.
  local function resolvePrice(part)
    local p = tonumber(part:GetAttribute("Price")) or 0
    if p > 0 then return p end
    local dl = os.clock() + 1.0
    while part.Parent and p <= 0 and os.clock() < dl do task.wait(0.05); p = tonumber(part:GetAttribute("Price")) or 0 end
    return p
  end
  local function claimWild(part)
    if not matchPet(part) then return false end
    local pn = tostring(part:GetAttribute("PetName") or "")
    local rr = tostring(part:GetAttribute("Rarity") or "")
    -- AFFORDABILITY GATE (before ANY teleport): resolve the real price + check Sheckles.
    -- If we can't afford this pet, do NOT teleport to it.
    local price = resolvePrice(part)
    if price <= 0 then cooldown[part] = os.clock() + 5; dbg(("price unknown for %s - skip"):format(pn)); return false end
    if sheckles() < price then
      cooldown[part] = os.clock() + 5
      dbg(("not enough Sheckles for %s (%s): need %d have %d - NOT teleporting"):format(pn, rr, price, sheckles()))
      return false
    end
    -- MEASURED: WildPetTame is accepted ~1/sec (matches the in-game "Buy" prompt's 1s hold) -
    -- firing faster gets the extras DROPPED (25 spam fires tamed nothing; 1/sec tamed a Rare
    -- in 2). Taming is also probabilistic per accepted fire (higher rarity = more fires), so
    -- fire ~1/sec, re-teleporting to the WANDERING physical pet each time, until owned / it
    -- despawns / a generous timeout.
    buyPetsUntil = os.clock() + 25   -- stand the return-home failsafe down for the WHOLE buypet trip
    local t0 = os.clock()
    while active() and part.Parent and (part:GetAttribute("OwnerUserId") or 0) == 0 and os.clock()-t0 <= 20 do
      grabUntil = os.clock() + 1.8; noAnchorUntil = os.clock() + 1.8   -- no re-pin + UNANCHORED (like seeds; guard zeroes velocity each frame so no fall)
      local m = physModel(part)
      local p = (m and select(2, pcall(function() return m:GetPivot().Position end))) or physPos(part)
      if typeof(p) == "Vector3" then tpTo(p) end   -- glide/teleport to the wandering pet
      -- PROMPT-GATED tame: fire the model's BuyPrompt (WildPetTame remote is dead now).
      local bp = buyPrompt(m)
      if bp and typeof(fireproximityprompt) == "function" then
        pcall(function() bp.Enabled=true; bp.HoldDuration=0; bp.RequiresLineOfSight=false; bp.MaxActivationDistance=math.max(bp.MaxActivationDistance or 0, 30) end)
        pcall(function() fireproximityprompt(bp) end)
      else
        pcall(function() Net.Pets.WildPetTame:Fire(part) end)   -- fallback (old path / prompt missing)
      end
      grabUntil = os.clock() + 1.8; noAnchorUntil = os.clock() + 1.8   -- keep both alive through the 1s wait
      task.wait(1.0)
    end
    pivotGardenCenter("after buypet")   -- return to garden center after a tame
    buyPetsUntil = 0                     -- trip done -> re-enable the return-home failsafe
    local mine = (not part.Parent) or (part:GetAttribute("OwnerUserId") == lp.UserId)
    if mine then
      handled[part] = true
      print(("[BUYPET] claimed %s (%s) ~%d Sheckles"):format(pn,rr,price))
    else
      cooldown[part] = os.clock() + 3
      dbg(("claim not confirmed for %s (%s)"):format(pn,rr))
    end
    return mine
  end
  local dirty = false
  local addConn = refFolder.ChildAdded:Connect(function() if active() then dirty = true end end)
  print("[BUYPET] started (event-driven + rarity priority)")
  while active() do
    local best, bestRank
    for _,part in ipairs(refFolder:GetChildren()) do
      if part:IsA("BasePart") and not handled[part] and not (cooldown[part] and os.clock() < cooldown[part]) then
        if matchPet(part) then
          local rk = rarityRank(part)
          if not best or rk > bestRank then best, bestRank = part, rk end
        end
      end
    end
    for p in pairs(handled)  do if not p.Parent then handled[p]  = nil end end
    for p in pairs(cooldown) do if not p.Parent then cooldown[p] = nil end end
    if best then
      claimWild(best); task.wait(0.3)
    else
      local idleFor, waited = math.max(0.5, 20 or 1), 0
      while active() and not dirty and waited < idleFor do task.wait(0.1); waited = waited + 0.1 end
      dirty = false
    end
  end
  if addConn then addConn:Disconnect() end
  print("[BUYPET] stopped.")
end

local function runExpandPlot(C)
