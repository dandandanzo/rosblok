        if Cfg.BuyGears  then task.spawn(function() local ok,err=pcall(runBuyGears,  Cfg.BuyGearsConfig  or {}); if not ok then warn("[ALL] buy-gears crashed: "..tostring(err)) end end) end
        if Cfg.BuyPets   then task.spawn(function() local ok,err=pcall(runBuyPets,   Cfg.BuyPetsConfig   or {}); if not ok then warn("[ALL] buy-pets crashed: "..tostring(err)) end end) end
        if Cfg.ExpandPlot then task.spawn(function() local ok,err=pcall(runExpandPlot, Cfg.ExpandPlotConfig or {}); if not ok then warn("[ALL] expand crashed: "..tostring(err)) end end) end
        if Cfg.BuySlot   then task.spawn(function() local ok,err=pcall(runBuySlot,   Cfg.BuySlotConfig   or {}); if not ok then warn("[ALL] buy-slot crashed: "..tostring(err)) end end) end
        if Cfg.EquipPets then task.spawn(function() local ok,err=pcall(runEquipPets, Cfg.EquipPetsConfig or {}); if not ok then warn("[ALL] equip crashed: "..tostring(err)) end end) end
        if Cfg.Misc then task.spawn(function() local ok,err=pcall(runMisc, Cfg.MiscConfig or {}); if not ok then warn("[ALL] misc crashed: "..tostring(err)) end end) end
    end)
