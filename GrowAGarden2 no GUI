        end
        print("[EXPAND] started")
        while active() do
            local target = math.min(tonumber(C.TargetExpansions) or maxIdx, maxIdx)
            local nIdx, price, o = nextInfo()
            while active() and nIdx and o < target and sheckles() >= price do
                local before = o
                pcall(function() Net.Actions.ExpandGarden:Fire() end)
                local t0=os.clock(); repeat task.wait(0.2) until owned()>before or not active() or os.clock()-t0>5
                if owned()>before then print(("[EXPAND] expanded -> %d/%d (cost ~%d)"):format(owned(), target, price))
                else dbg("expand not confirmed (afford/max?)"); break end
                nIdx, price, o = nextInfo()
            end
            for _=1, math.max(3, 20 or 10) do if not active() then return end task.wait(1) end
        end
        print("[EXPAND] stopped.")
    end

    local function runBuySlot(C)
