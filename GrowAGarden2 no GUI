        end

        local function row(name) return ("<font color='%s'>%s</font>"):format(GHEX, name) end
        local function val(v)    return ("<font color='%s'>%s</font>"):format(AHEX, tostring(v)) end

        local titleLbl = mkLabel{ size=20, h=26 }; titleLbl.Text = "GAG2 Stats"
        sep()
        local lblUser    = mkLabel{ size=14 }
        local lblShek    = mkLabel{ size=14 }
        local lblRate    = mkLabel{ size=14 }
        local lblWeather = mkLabel{ size=14 }
        local lblUptime  = mkLabel{ size=14 }
        sep()
        local hPlant = mkLabel{ size=14, color=ACCENT }
        local lPlant = mkLabel{ size=12, auto=true, color=LIGHT }
        sep()
        local hEquip = mkLabel{ size=14, color=ACCENT }
        local lEquip = mkLabel{ size=12, auto=true, color=LIGHT }
        sep()
        local hSeeds = mkLabel{ size=14, color=ACCENT }
        local lSeeds = mkLabel{ size=12, auto=true, color=LIGHT }
        sep()
        local hPets = mkLabel{ size=14, color=ACCENT }
        local lPets = mkLabel{ size=12, auto=true, color=LIGHT }
        sep()
        local hGears = mkLabel{ size=14, color=ACCENT }
        local lGears = mkLabel{ size=12, auto=true, color=LIGHT }

        -- bottom-center HIDE/SHOW toggle. Parented to the ScreenGui (NOT root) so it stays on screen
        -- after root is hidden -> hiding the panel leaves ONLY this button visible.
        local closed = false
        local shown  = true
        local toggle = Instance.new("TextButton")
        toggle.Name="Toggle"; toggle.AnchorPoint=Vector2.new(0.5,1)
        toggle.Position=UDim2.new(0.5,0,1,-12); toggle.Size=UDim2.new(0,150,0,26)
        toggle.BackgroundColor3=Color3.fromRGB(0,0,0); toggle.BackgroundTransparency=0.1; toggle.AutoButtonColor=true
        toggle.Font=Enum.Font.GothamBold; toggle.TextSize=13; toggle.TextColor3=Color3.fromRGB(255,255,255)
        toggle.Text="Hide Stats"; toggle.BorderSizePixel=0; toggle.ZIndex=50; toggle.Parent=sg
        do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,8); c.Parent=toggle
           local s=Instance.new("UIStroke"); s.Color=Color3.fromRGB(255,255,255); s.Thickness=1; s.Transparency=0.15; s.Parent=toggle end   -- thin white outline
        toggle.MouseButton1Click:Connect(function()
            shown = not shown
            root.Visible = shown
            toggle.Text = shown and "Hide Stats" or "Show Stats"
        end)
        -- defensive: nothing in this script flips visibility except the button above, so any "auto
        -- show/hide by itself" is an EXTERNAL flip (the game hiding GUIs during a cutscene, the
        -- executor rebuilding its gethui container, or a re-exec). Snap visibility back to the
        -- user's chosen state the instant anything changes it.
        root:GetPropertyChangedSignal("Visible"):Connect(function() if root.Visible ~= shown then root.Visible = shown end end)
        sg:GetPropertyChangedSignal("Enabled"):Connect(function() if sg.Enabled ~= true then sg.Enabled = true end end)

        local firstShek, firstClock = nil, os.clock()
        local function update()
            local data = getData()
            local name = lp.DisplayName ~= lp.Name and ("%s (@%s)"):format(lp.DisplayName, lp.Name) or lp.Name
            lblUser.Text = row("Username")..val("   "..name)

            local shek = data and tonumber(data.Sheckles) or 0
            if data and firstShek == nil then firstShek = shek; firstClock = os.clock() end
            lblShek.Text = row("Sheckles")..val("   "..fmt(shek))
            local perMin = 0
            if firstShek then local mins=(os.clock()-firstClock)/60; if mins>0.08 then perMin=(shek-firstShek)/mins end end
            lblRate.Text = row("Sheckles/min")..val("   "..(perMin>=0 and "+" or "")..fmt(perMin))

            local w = workspace:GetAttribute("ActiveWeather")
            lblWeather.Text = row("Weather / Event")..val("   "..((type(w)=="string" and w~="" ) and w or "Clear"))
            lblUptime.Text = row("Uptime")..val("   "..fmtTime(os.clock()-startClock))

            -- planted vs target (Plant subsystem)
            local targets = (Cfg.PlantConfig and Cfg.PlantConfig.Targets) or {}
            local pc = plantedCounts()
            local pnames = {} for n,t in pairs(targets) do if (tonumber(t) or 0) > 0 then pnames[#pnames+1]=n end end
            table.sort(pnames)
            local plines, ptot = {}, 0
            for _,n in ipairs(pnames) do local have=pc[n] or 0; ptot=ptot+have; plines[#plines+1]=("%s: %d/%d"):format(n, have, tonumber(targets[n]) or 0) end
            hPlant.Text = ("Seeds Planted vs Target (%d)"):format(ptot)
            lPlant.Text = joinTrunc(plines, 40)

            local eL, eT = equippedList(data)
            hEquip.Text = ("Equipped Pets (%d)"):format(eT)
            lEquip.Text = joinTrunc(eL, 30)

            local inv = (data and data.Inventory) or {}
            local sL,sT = summarize(inv, SEED_CATS)
            local pL,pT = summarize(inv, PET_CATS)
            local gL,gT = summarize(inv, GEAR_CATS)
            hSeeds.Text = ("Inventory - Seeds (%d)"):format(sT); lSeeds.Text = joinTrunc(sL, 60)
            hPets.Text  = ("Inventory - Pets (%d)"):format(pT);  lPets.Text  = joinTrunc(pL, 60)
            hGears.Text = ("Inventory - Gears (%d)"):format(gT); lGears.Text = joinTrunc(gL, 60)
        end

        print("[STATS] panel up")
        while active() and not closed do
            if sg.Enabled ~= true then sg.Enabled = true end       -- backup re-assert (signal above is the instant guard)
            if root.Visible ~= shown then root.Visible = shown end
            if shown then pcall(update) end
            if not (sg and sg.Parent) then break end
            task.wait(0.5)
        end
        pcall(function() sg:Destroy() end)
        if G.__GAG2_STATS == sg then G.__GAG2_STATS = nil end
        print("[STATS] panel closed.")
    end

    local function runGuard()
        local function active() return alive() end
        local function isNight()
            local w = workspace:GetAttribute("ActiveWeather")
            return type(w)=="string" and w:lower():find("moon") ~= nil
        end
        local function gardenCenter()
            local plot = getPlot(); if not plot then return nil end
            local sum, n = Vector3.new(), 0
            for _,pp in ipairs(CS:GetTagged("PlantArea")) do
                if pp:IsA("BasePart") and pp:IsDescendantOf(plot) then sum = sum + pp.Position; n = n + 1 end
            end
            if n == 0 then local cf = plot:GetBoundingBox(); return cf.Position end
            return (sum / n) + Vector3.new(0, 6, 0)
        end
        local function pivotCenter(why)
            local c = gardenCenter(); local char = lp.Character
            if c and char and char:FindFirstChild("HumanoidRootPart") then
                pcall(function() char:PivotTo(CFrame.new(c)) end)
                if why then print("[GUARD] pivot to garden center ("..why..")") end
            end
        end

        task.spawn(function()
            local VIM; pcall(function() VIM = game:GetService("VirtualInputManager") end)
            if not VIM then return end
            local function pressAnyKey()
                pcall(function()
                    VIM:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
                    VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    VIM:SendMouseButtonEvent(100,100,0,true,  game, 0)
                    VIM:SendMouseButtonEvent(100,100,0,false, game, 0)
                end)
            end
            local t0, announced = os.clock(), false
            while active() and os.clock()-t0 < 90 do
                if lp:GetAttribute("LoadingScreenActive") == true then
                    if not announced then print("[GUARD] auto-pressing through loading screen"); announced = true end
                    pressAnyKey(); task.wait(0.25)
                elseif lp:GetAttribute("OfflineCutscenePlaying") == true then
                    pcall(function() VIM:SendMouseButtonEvent(100,100,0,true,game,0) end)
                    local h = os.clock()
                    while active() and lp:GetAttribute("OfflineCutscenePlaying")==true and os.clock()-h < 1.5 do task.wait(0.05) end
                    pcall(function() VIM:SendMouseButtonEvent(100,100,0,false,game,0) end)
                    print("[GUARD] held to skip offline-growth cutscene"); task.wait(0.5)
                else
                    task.wait(0.3)
                end
            end
        end)

        task.spawn(function()
            local function trulySpawned()
                if lp:GetAttribute("LoadingScreenActive") == true then return false end
                if lp:GetAttribute("OfflineCutscenePlaying") == true then return false end
                if lp:GetAttribute("CutsceneInputBlocked") == true then return false end
                local char = lp.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                if not (hrp and hum) then return false end
                if hum.Health <= 0 then return false end
                local st = hum:GetState()
                if st == Enum.HumanoidStateType.Dead or st == Enum.HumanoidStateType.None then return false end
                return true
            end
            local t0 = os.clock()
            while active() and not trulySpawned() and os.clock()-t0 < 120 do task.wait(0.3) end
            if not active() then return end
            task.wait(1.0)   
            pivotCenter("after spawn")
            local wasNight = nil
            while active() do
                local n = isNight()
                if n then pivotCenter(wasNight ~= true and "night start" or nil) end  
                wasNight = n
                for _=1, (n and 12 or 3) do if not active() then return end task.wait(1) end
            end
        end)
        print("[GUARD] started (safe hold-to-skip + garden-center pivot + night hold)")
    end

    local function runFpsBoost(C)
        local function active() return alive() and Cfg.Misc ~= false end
        local Lighting = game:GetService("Lighting")
        local conns       = {}
        local removed     = {}   -- [plantsFolder] = plot (restore other gardens on stop)
        local hiddenChars = {}   -- [character] = parent (restore other players on stop)
        local myPlotName  = "Plot"..tostring(lp:GetAttribute("PlotId"))

        if C.FpsBoost ~= false then
            pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
            pcall(function() game:GetService("UserSettings"):GetService("UserGameSettings").SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end)
            pcall(function() Lighting.GlobalShadows = false end)
            pcall(function() Lighting.Technology = Enum.Technology.Compatibility end)
            for _,e in ipairs(Lighting:GetDescendants()) do
                if e:IsA("PostEffect") or e:IsA("Atmosphere") then pcall(function() e.Enabled = false end) end
            end
            local ter = workspace:FindFirstChildOfClass("Terrain")
            if ter then pcall(function() ter.WaterWaveSize=0; ter.WaterWaveSpeed=0; ter.WaterReflectance=0; ter.WaterTransparency=0.9; ter.Decoration=false end) end
            -- cheaper lighting: kill image-based lighting + clouds (Brightness left alone to avoid a dark screen)
            pcall(function() Lighting.EnvironmentDiffuseScale = 0; Lighting.EnvironmentSpecularScale = 0 end)
            if ter then local cl = ter:FindFirstChildOfClass("Clouds"); if cl then pcall(function() cl:Destroy() end) end end

            -- Misc may start before spawn -> wait for PlotId so we never mistake our OWN garden
            -- for an "other" one (which would un-parent our own Plants and break harvest).
            for _=1,60 do if lp:GetAttribute("PlotId") or not active() then break end task.wait(0.5) end
            myPlotName = "Plot"..tostring(lp:GetAttribute("PlotId"))
            local function removePlot(plot)
                if plot.Name == myPlotName then return end
                local pf = plot:FindFirstChild("Plants")
                if pf and not removed[pf] then removed[pf] = plot; pcall(function() pf.Parent = nil end) end
            end
            local gardens = workspace:WaitForChild("Gardens", 30)
            if gardens then
                for _,plot in ipairs(gardens:GetChildren()) do if active() then removePlot(plot) end end
                conns[#conns+1] = gardens.ChildAdded:Connect(function(plot)
                    if active() and plot.Name ~= myPlotName then
                        local pf = plot:WaitForChild("Plants", 30)
                        if pf and active() then removePlot(plot) end
                    end
                end)
                -- (removed gardens.DescendantAdded backup: it fired for EVERY fruit growing in every
                -- garden = constant CPU. ChildAdded above already removes other gardens' Plants.)
            end

            local function killFx(d)
                if d:IsA("ParticleEmitter") or d:IsA("Beam") or d:IsA("Trail") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
                    pcall(function() d.Enabled = false end)
                elseif d:IsA("BasePart") then
                    pcall(function() d.LocalTransparencyModifier = 1; d.CastShadow = false end)
                end
            end
            for _,fn in ipairs({"RainDrops","RainSplashes","LightningEffects","StormRainDrops","StormSplashes"}) do
                local f = workspace:FindFirstChild(fn)
                if f then
                    for _,d in ipairs(f:GetDescendants()) do killFx(d) end
                    conns[#conns+1] = f.DescendantAdded:Connect(function(d) if active() then killFx(d) end end)
                end
            end
            for _,ln in ipairs({"RainEffect","LightningEffect","RainbowEffect","FlameEffect","StarEffect"}) do
                local e = Lighting:FindFirstChild(ln)
                if e and e:IsA("PostEffect") then
                    pcall(function() e.Enabled = false end)
                    conns[#conns+1] = e:GetPropertyChangedSignal("Enabled"):Connect(function() if active() and e.Enabled then pcall(function() e.Enabled=false end) end end)
                end
            end

            local function flatten(d)
                if d:IsA("BasePart") then
                    pcall(function() d.Material = Enum.Material.SmoothPlastic; d.Reflectance = 0; d.CastShadow = false end)
                    if d:IsA("MeshPart") then pcall(function() d.TextureID = "" end) end       -- mesh texture
                elseif d:IsA("SpecialMesh") then pcall(function() d.TextureId = "" end)          -- legacy mesh texture
                elseif d:IsA("Decal") or d:IsA("Texture") then pcall(function() d.Transparency = 1 end)
                elseif d:IsA("SurfaceAppearance") then pcall(function() d:Destroy() end)         -- PBR maps
                elseif d:IsA("Sound") or d:IsA("SoundGroup") then pcall(function() d.Volume = 0 end)   -- mute SFX/music
                elseif d:IsA("ParticleEmitter") or d:IsA("Trail") or d:IsA("Beam") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
                    pcall(function() d.Enabled = false end)                                       -- kill ALL particles/fx
                end
            end
            local function flattenSubtree(root)
                if not root then return end
                local n = 0
                for _,d in ipairs(root:GetDescendants()) do
                    if not active() then return end
                    flatten(d); n = n + 1; if n % 300 == 0 then task.wait() end
                end
            end
            -- mute sounds in SoundService (outside workspace) + new ones there
            for _,s in ipairs(game:GetService("SoundService"):GetDescendants()) do flatten(s) end
            conns[#conns+1] = game:GetService("SoundService").DescendantAdded:Connect(function(d) if active() then flatten(d) end end)
            -- keep new workspace instances low-poly/quiet (scoped to workspace, not game-wide = less overhead)
            conns[#conns+1] = workspace.DescendantAdded:Connect(function(d) if active() then flatten(d) end end)
            task.spawn(function()
                flattenSubtree(workspace)   -- whole map + your garden + decorations + every visible texture
                print("[MISC] low-poly + sound-mute applied (whole workspace)")
            end)

            -- (#2) nuke transient cosmetic VFX models (harvest/sell pops, blizzard beams); they
            -- respawn constantly with nonstop harvest, so removing them on spawn frees real FPS
            local JUNK = { PopVFXModel = true, BlizzardBeams = true, PopVFX = true }
            local function killJunk(c) if JUNK[c.Name] then pcall(function() c:Destroy() end) end end
            for _,c in ipairs(workspace:GetChildren()) do killJunk(c) end
            conns[#conns+1] = workspace.ChildAdded:Connect(function(c) if active() then killJunk(c) end end)

            -- (#4) hide OTHER players' characters: un-parent them (transparency wouldn't free FPS).
            -- Restored on stop. If it ever causes client errors, just turn Misc/FpsBoost off.
            local Plrs = game:GetService("Players")
            local function hideChar(ch) if ch and ch.Parent then hiddenChars[ch] = ch.Parent; pcall(function() ch.Parent = nil end) end end
            local function onPlr(p)
                if p == lp then return end
                if p.Character then hideChar(p.Character) end
                conns[#conns+1] = p.CharacterAdded:Connect(function(ch) if active() then task.wait(0.3); hideChar(ch) end end)
            end
            for _,p in ipairs(Plrs:GetPlayers()) do onPlr(p) end
            conns[#conns+1] = Plrs.PlayerAdded:Connect(function(p) if active() then onPlr(p) end end)

            do local n=0 for _ in pairs(removed) do n=n+1 end
               print(("[MISC] fps boost applied (quality lowest, shadows/effects off, %d other gardens removed, particles+weather off, sfx muted)"):format(n)) end
        end

        -- keepalive + cleanup (FPS boost only): restore other gardens + players on stop
        while active() do task.wait(2) end
        for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
        for pf,plot in pairs(removed) do pcall(function() pf.Parent = plot end) end          -- restore other gardens
        for ch,par in pairs(hiddenChars) do pcall(function() ch.Parent = par end) end        -- restore other players
        print("[MISC] fps boost stopped (other gardens + players restored)")
    end

    -- The rest of Misc (character guard / anti-fling / anti-afk / auto-reconnect / redeem) runs
    -- only AFTER spawn -- unlike FpsBoost which starts at execute.
    local function runMisc(C)
        local function active() return alive() and Cfg.Misc ~= false end
        local conns = {}

        -- CHARACTER GUARD: anchor HRP on NIGHT/moon (freeze: exploit flings can't throw you out of
        -- the garden, players can't shove you) / during a grab (true anti-gravity = no fall); else
        -- clamp abnormal velocity (anti-fling). Anchoring still lets grabbers set CFrame.
        do
            local RunService = game:GetService("RunService")
            local MAXV = 100
            local function gardenCenter()
                local plot=getPlot(); if not plot then return nil end
                local sum,n=Vector3.new(),0
                for _,pp in ipairs(CS:GetTagged("PlantArea")) do if pp:IsA("BasePart") and pp:IsDescendantOf(plot) then sum=sum+pp.Position; n=n+1 end end
                if n==0 then local ok,cf=pcall(function() return plot:GetBoundingBox() end); if ok then return cf.Position end return nil end
                return (sum/n)+Vector3.new(0,6,0)
            end
            local center, centerAt = nil, 0
            conns[#conns+1] = RunService.Heartbeat:Connect(function()
                if not active() then return end
                local ch = lp.Character
                local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local w = workspace:GetAttribute("ActiveWeather")
                local night = type(w) == "string" and w:lower():find("moon") ~= nil
                local grabbing = os.clock() < grabUntil
                local hold = night or grabbing
                if hrp.Anchored ~= hold then pcall(function() hrp.Anchored = hold end) end
                if night and not grabbing then
                    -- HARD anti-steal: Anchored alone is only visual on our screen (a fling that writes
                    -- CFrame, or that owns the part, still drags us server-side). We own our own
                    -- character, so re-asserting CFrame EVERY frame back to the garden center wins the
                    -- replication fight -> other players' fling/push can't pull us out of the garden.
                    if (not center) or (os.clock()-centerAt > 5) then local c=gardenCenter(); if c then center=c; centerAt=os.clock() end end
                    if center then pcall(function() hrp.CFrame = CFrame.new(center) * (hrp.CFrame - hrp.CFrame.Position) end) end
                    pcall(function() hrp.AssemblyLinearVelocity=Vector3.zero; hrp.AssemblyAngularVelocity=Vector3.zero end)
                elseif not hold then
                    center = nil
                    if hrp.AssemblyLinearVelocity.Magnitude  > MAXV then pcall(function() hrp.AssemblyLinearVelocity  = Vector3.zero end) end
                    if hrp.AssemblyAngularVelocity.Magnitude > MAXV then pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end) end
                end
            end)
            print("[MISC] character guard armed (HARD night freeze re-pin + anti-gravity on grab + anti-fling)")
        end

        if C.AntiAfk then
            local okVIM, VIM = pcall(function() return game:GetService("VirtualInputManager") end)
            local function jump()
                if okVIM and VIM then
                    pcall(function() VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game); task.wait(0.06); VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game) end)
                else
                    local c = lp.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
                    if h then pcall(function() h:ChangeState(Enum.HumanoidStateType.Jumping) end) end
                end
            end
            conns[#conns+1] = lp.Idled:Connect(function() if active() then jump() end end)
            task.spawn(function() while active() do for _=1, math.max(5, 600) do if not active() then return end task.wait(1) end jump() end end)
            print(("[MISC] anti-afk armed (jump every %ds; VIM=%s)"):format(600, tostring(okVIM and VIM~=nil)))
        end

        if C.AutoReconnect then
            local TP = game:GetService("TeleportService")
            local GuiService = game:GetService("GuiService")
            local rejoining = false
            local function rejoin()
                if rejoining then return end; rejoining = true
                task.wait(0.5)
                pcall(function() TP:Teleport(game.PlaceId, lp) end)
            end
            conns[#conns+1] = GuiService.ErrorMessageChanged:Connect(function(msg)
                if msg and tostring(msg) ~= "" then task.spawn(rejoin) end
            end)
            print("[MISC] auto-reconnect armed (note: a hard network drop can kill the VM before it fires)")
        end

        while active() do task.wait(2) end
        for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
        pcall(function() local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if h then h.Anchored = false end end)  -- never leave frozen
        print("[MISC] stopped (character unfrozen)")
    end

    print("========================================================")
    print(("GAG2 ALL-IN-ONE  Plant=%s Harvest=%s Sell=%s CollectEventSeeds=%s Mail=%s Webhook=%s Misc=%s")
        :format(tostring(Cfg.Plant), tostring(Cfg.Harvest), tostring(Cfg.Sell), tostring(Cfg.CollectEventSeeds), tostring(Cfg.Mail), tostring(Cfg.Webhook), tostring(Cfg.Misc)))
    print(("  +BuyGears=%s BuyPets=%s ExpandPlot=%s BuySlot=%s EquipPets=%s")
        :format(tostring(Cfg.BuyGears), tostring(Cfg.BuyPets), tostring(Cfg.ExpandPlot), tostring(Cfg.BuySlot), tostring(Cfg.EquipPets)))
    print("  Stop all: getgenv().__GAG2_ALL=false")
    print("========================================================")

    task.spawn(function() local ok,err=pcall(runGuard); if not ok then warn("[ALL] guard crashed: "..tostring(err)) end end)

    -- FpsBoost and Redeem-Codes run IMMEDIATELY on execute. FpsBoost drops graphics right away
    -- while still loading; Redeem fires its codes the moment you're spawned (it self-waits for the
    -- character internally). The rest of Misc (char guard / anti-afk / auto-reconnect) waits for
    -- spawn in the gated block below.
    if Cfg.Misc and (Cfg.MiscConfig or {}).FpsBoost ~= false then
        task.spawn(function() local ok,err=pcall(runFpsBoost, Cfg.MiscConfig or {}); if not ok then warn("[ALL] fps-boost crashed: "..tostring(err)) end end)
    end
    if Cfg.Misc then   -- SetFPS: cap FPS via setfpscap (0 = disabled / leave FPS untouched)
        local n = tonumber((Cfg.MiscConfig or {}).SetFPS) or 0
        if n > 0 then
            local sfc = (typeof(setfpscap)=="function" and setfpscap) or (typeof(set_fps_cap)=="function" and set_fps_cap) or nil
            if sfc then pcall(sfc, n); print(("[ALL] FPS cap set to %d"):format(n)) else warn("[ALL] SetFPS: executor has no setfpscap()") end
        end
    end
    if Cfg.Misc and (Cfg.MiscConfig or {}).RedeemCodes then
        task.spawn(function() local ok,err=pcall(runRedeemCodes, Cfg.MiscConfig or {}); if not ok then warn("[ALL] redeem crashed: "..tostring(err)) end end)
    end
    if Cfg.Misc and (Cfg.MiscConfig or {}).StatsGUI ~= false then
        task.spawn(function() local ok,err=pcall(runStatsGui, Cfg.MiscConfig or {}); if not ok then warn("[ALL] stats-gui crashed: "..tostring(err)) end end)
    end

    task.spawn(function()
        local function ready()
            if not alive() then return false end
            local char = lp.Character
            if not (char and char:FindFirstChild("HumanoidRootPart")) then return false end
            if lp:GetAttribute("LoadingScreenActive") == true then return false end      -- still on loading screen
            if lp:GetAttribute("OfflineCutscenePlaying") == true then return false end    -- offline cutscene playing
            local plot = getPlot(); if not (plot and plot:FindFirstChild("Plants")) then return false end
            return true
        end
        local t0 = os.clock()
        while alive() and not ready() and os.clock()-t0 < 120 do task.wait(0.5) end
        if not alive() then return end
        print("[ALL] spawn + garden loaded -> starting subsystems"..(ready() and "" or " (timeout - starting anyway)"))

        if Cfg.Plant then task.spawn(function() local ok,err=pcall(runPlantBuy, Cfg.PlantConfig or {}); if not ok then warn("[ALL] plant crashed: "..tostring(err)) end end) end
        if Cfg.Harvest  then task.spawn(function()
            while alive() and Cfg.Harvest ~= false do
                local ok,err = pcall(runHarvest, Cfg.HarvestConfig or {})
                if not ok then warn("[ALL] harvest crashed: "..tostring(err).." - restarting in 3s") end
                if not (alive() and Cfg.Harvest ~= false) then break end
                task.wait(3)
            end
        end) end
        if Cfg.Sell     then task.spawn(function() local ok,err=pcall(runSell,     Cfg.SellConfig     or {}); if not ok then warn("[ALL] sell crashed: "..tostring(err)) end end) end
