end
-- Shared one-shot pivot to the CENTER of our garden (a single PivotTo teleport, NOT a freeze/anchor).
-- Used for: after-spawn, night start, gold/rainbow event end, and after a buypet tame.
local function gardenCenterPos()
  local plot = getPlot(); if not plot then return nil end
  local sum, n = Vector3.new(), 0
  for _,pp in ipairs(CS:GetTagged("PlantArea")) do
    if pp:IsA("BasePart") and pp:IsDescendantOf(plot) then sum = sum + pp.Position; n = n + 1 end
  end
  local raw
  if n > 0 then raw = sum / n
  else local ok,cf = pcall(function() return plot:GetBoundingBox() end); if ok then raw = cf.Position else return nil end end
  -- GROUND-SNAP (no hover): raycast down at the center X/Z to find the real plot floor, then stand
  -- the HRP ~3 studs above it (feet on ground). Exclude the character + every Plants folder, else
  -- the ray hits a plant canopy instead of the floor (verified: a single ray hit a plant at Y189).
  local excl = {}
  if lp.Character then excl[#excl+1] = lp.Character end
  local gardens = workspace:FindFirstChild("Gardens")
  if gardens then for _,g in ipairs(gardens:GetChildren()) do local pf = g:FindFirstChild("Plants"); if pf then excl[#excl+1] = pf end end end
  local params = RaycastParams.new()
  params.FilterType = Enum.RaycastFilterType.Exclude
  params.FilterDescendantsInstances = excl
  params.IgnoreWater = true
  local res = workspace:Raycast(Vector3.new(raw.X, raw.Y + 40, raw.Z), Vector3.new(0, -200, 0), params)
  local floorY = res and res.Position.Y or raw.Y
  return Vector3.new(raw.X, floorY + 3, raw.Z)
end
local function pivotGardenCenter(why)
  local c = gardenCenterPos()
  if not c then return end
  -- A SINGLE PivotTo gets reverted by the game ~1s later (verified live); re-assert for ~2s so it
  -- STICKS, the same way the plant/seed/tame loops keep re-teleporting every tick. Zero velocity
  -- each tick so there's no fall drift while holding position.
  local t0 = os.clock()
  while os.clock() - t0 < 2 do
    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then break end
    pcall(function() char:PivotTo(CFrame.new(c)); hrp.AssemblyLinearVelocity = Vector3.zero end)
    task.wait(0.1)
  end
  if why then print("[PIVOT] garden center ("..why..")") end
end
